{
  "name": "depth4",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "npm run dev --workspace=web",
    "dev:api": "cd apps/api && uv run uvicorn signal_api.main:app --reload --host 0.0.0.0 --port 8000",
    "build:web": "npm run build --workspace=web",
    "lint:web": "npm run lint --workspace=web",
    "test:e2e": "npm run test:e2e --workspace=web"
  },
  "engines": {
    "node": ">=18.18.0"
  }
}

# --- Supabase (public URL + service role for API worker; anon key in Next) ---
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# --- LLM: Anthropic and/or NVIDIA (NIM) ---
# For NVIDIA live testing, set: LLM_PROVIDER=nvidia and NVIDIA_API_KEY, see apps/api .env
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=
# API default is Haiku until you set a pricier id for launch (see apps/api .env.example).
ANTHROPIC_MODEL=claude-3-5-haiku-20241022
# DEPTH4_ENABLED=true | MIN_ACTIVE_USERS_FOR_DEPTH4=2 (apps/api — pause background LLM when too few actives)
# API model routing (apps/api): set KIMI_API_KEY + KIMI_MODEL=kimi-k2.6 for cheap/standard tasks; Opus via ANTHROPIC_MODEL_PREMIUM on escalation.
# KIMI_API_KEY=
# KIMI_MODEL=kimi-k2.6
# ANTHROPIC_MODEL_PREMIUM=claude-opus-4-7
# LLM_ROUTING_ESCALATION=true
# API premium budget (rough USD / process): 0 disables. See apps/api .env.example
# LLM_PREMIUM_DAILY_BUDGET_USD=0
# LLM_PREMIUM_HOURLY_BUDGET_USD=0
# Vercel cron `event-reasoning` uses ANTHROPIC_MODEL_PREMIUM then ANTHROPIC_MODEL (see apps/web model-routing.ts)
# For web admin LLM usage page: set INGEST_CRON_SECRET to same value as API (proxy to /admin/llm-usage)
NVIDIA_API_KEY=
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_MODEL=meta/llama-3.1-8b-instruct

# --- Redis (local / Upstash free tier — use TLS URL from Upstash dashboard) ---
REDIS_URL=redis://localhost:6379/0
# Upstash example: rediss://default:PASSWORD@REGION.upstash.io:6379

# --- App ---
FRONTEND_URL=http://localhost:3000
# API: optional POST /cron/ingest-once + X-Depth4-Ingest-Secret (see apps/api/.env.example)
INGEST_CRON_SECRET=
RSS_INTERVAL_SECONDS=60

# --- Stripe (optional) ---
STRIPE_API_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_INSTITUTIONAL=price_...

# --- OneSignal (PWA / mobile web push) ---
ONE_SIGNAL_APP_ID=
ONE_SIGNAL_API_KEY=

# Next (apps/web) — add to Vercel:
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Anonymous read of thesis workspace (middleware + read APIs). Omit in production unless intentional. Admin stays gated.
# DEPTH4_PUBLIC_READ_MODE=1
# NEXT_PUBLIC_DEPTH4_PUBLIC_READ_MODE=1
# Local: http://localhost:8000 | Production: https://YOUR-SERVICE.onrender.com (API from render.yaml)
NEXT_PUBLIC_API_URL=http://localhost:8000
# Vercel (apps/web): required for AI thesis expand proxy (/api/user/thesis-draft-expand) — copy from Render API INGEST_CRON_SECRET
# INGEST_CRON_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
NEXT_PUBLIC_ONESIGNAL_APP_ID=

# --- Thesis discovery cron (/api/cron/thesis-discovery) — optional tuning (defaults in code) ---
# CRITICAL: Rows are only written when a cluster passes BOTH gates (news-clustering.ts):
#   - distinct events in cluster >= THESIS_DISCOVERY_MIN_EVENTS (default 3)
#   - signal_score >= THESIS_DISCOVERY_SIGNAL_THRESHOLD (default 35)
# If your SQL shows 0 clusters but news exists, lower MIN_EVENTS (e.g. 1–2) for testing and/or
# lower SIGNAL_THRESHOLD. Otherwise candidates never hit thesis_discovery_clusters.
# THESIS_DISCOVERY_WINDOW_HOURS=24
# THESIS_DISCOVERY_MIN_EVENTS=3
# THESIS_DISCOVERY_SIGNAL_THRESHOLD=35
# THESIS_DISCOVERY_JACCARD_MERGE=0.32
# THESIS_DISCOVERY_JACCARD_SAME_TOPIC=0.14
# Emergency: persist top-N clusters by signal even when they fail min-events / score gate (internal testing).
# THESIS_DISCOVERY_SOFT_PERSIST=1
# THESIS_DISCOVERY_SOFT_PERSIST_CAP=25

# --- Promote discovery cron (/api/cron/promote-discovery) — candidate → promoted (run before event-reasoning) ---
# signal_score is stored 0–100; MIN_PROMOTION_SCORE=0.65 means 65 (same as 65).
# MIN_PROMOTION_SCORE=0.65
# DAILY_PROMOTION_LIMIT=3
# PROMOTION_ALLOWED_DOMAINS=policy,earnings,geopolitics,credit,commodities,central_banking,markets,macro,business,world_news
# PROMOTION_FRESH_HOURS=24
# Minimum clustered news ids per candidate (default 3). Internal testing: MIN_PROMOTION_MEMBER_COUNT=1
# MIN_PROMOTION_MEMBER_COUNT=3
# Internal testing: skip allowlist overlap entirely (any candidate that passes score + members promotes).
# PROMOTION_SKIP_DOMAIN_CHECK=1
# Softer: if inferDomainsFromCluster finds any tag, pass domain gate without allowlist match.
# PROMOTION_ALLOW_ANY_INFERRED_DOMAIN=1
#
# Cron auth (external schedulers e.g. cron-job.org): see apps/web/src/lib/cron-auth.ts
#   Authorization: Bearer <CRON_SECRET>  OR  Authorization: <CRON_SECRET> (no Bearer)
#   x-insider-flow-secret: <CRON_SECRET>  OR  x-cron-secret: <CRON_SECRET>
# Secrets may contain / and = — use a custom header value, not URL query strings.
# If production shows zero promoted clusters, check: (1) CRON_SECRET set on Vercel, (2) schedules exist
# (apps/web/vercel.json crons may be empty — add Vercel Cron jobs or external scheduler hitting these GET routes).
#
# Manual smoke (replace ORIGIN and CRON_SECRET):
# curl -sS -H "Authorization: Bearer $CRON_SECRET" "$ORIGIN/api/cron/thesis-discovery" | head -c 500
# curl -sS -H "Authorization: Bearer $CRON_SECRET" "$ORIGIN/api/cron/promote-discovery" | head -c 500
# curl -sS -H "Authorization: Bearer $CRON_SECRET" "$ORIGIN/api/cron/event-reasoning" | head -c 500
#
# SQL health checks: signal/supabase/queries/discovery_pipeline_health_48h.sql
#
# Backfill ai_generated registry rows for clusters that already have event_reasoning (one-time / repeat safe):
# curl -sS -H "Authorization: Bearer $CRON_SECRET" "$ORIGIN/api/cron/backfill-ai-thesis-registry?limit=100"

# --- Event reasoning cron (/api/cron/event-reasoning) — Anthropic from Next (Vercel) ---
# ANTHROPIC_API_KEY=
# Strong default in code is claude-opus-4-7; override if needed:
# ANTHROPIC_MODEL=claude-opus-4-7
# Production cron schedulers often time out at 30s; keep this at 1.
# EVENT_REASONING_CLUSTER_LIMIT=1
# EVENT_REASONING_MAX_TOKENS=4096

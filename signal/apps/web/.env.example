# --- Frontend (Next.js: only `NEXT_PUBLIC_*` is exposed to the browser) ---
# API base URL (empty = same origin). Set when the API is hosted on another domain.
NEXT_PUBLIC_API_BASE_URL=

# --- DEPTH4 internal roles (server-only; Phase 4E.1) ---
# Source of truth: Supabase `depth4_user_roles`. Defaults: DB-only (both flags off).
# DEPTH4_ROLE_ENV_FALLBACK=0   # emergency env-only grants (avoid in prod)
# DEPTH4_ROLE_ENV_BOOTSTRAP=0  # one-time migration: write env allowlists to DB
# DEPTH4_ADMIN_EMAILS=         # bootstrap only when BOOTSTRAP=1
# DEPTH4_OPERATOR_USER_IDS=    # bootstrap only when BOOTSTRAP=1
# Do not set NEXT_PUBLIC_DEPTH4_ADMIN_EMAILS or NEXT_PUBLIC_DEPTH4_OPERATOR_USER_IDS.

# --- Backend / server-only (documented for deploy + local dev) ---
# Anthropic model for thesis chat (cheap tier); consumed by `/api/theses/[slug]/chat` and related routes.
ANTHROPIC_MODEL_CHEAP=claude-3-5-haiku-latest

# Optional: stale alert for `/api/cron/ai-thesis-registry-health` when no new `ai_generated` rows in 24h (default 36).
# AI_THESIS_HEALTH_STALE_ALERT_HOURS=36

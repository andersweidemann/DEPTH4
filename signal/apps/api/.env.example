# Copy to .env (do not commit .env)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
REDIS_URL=redis://localhost:6379/0
FRONTEND_URL=http://localhost:3000

# Optional: POST https://<render-host>/cron/ingest-once with header X-Depth4-Ingest-Secret: <same value>
# wakes free-tier Render and runs one RSS+classify cycle (use UptimeRobot/Render Cron every ~10 min).
INGEST_CRON_SECRET=
# How often the in-process RSS loop sleeps between cycles (seconds).
RSS_INTERVAL_SECONDS=60

# --- LLM: pick one path ---
# Option A: Anthropic (default)
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Optional routing (recommended: cheap classify, better analysis)
# LLM_PROVIDER_CLASSIFY=nvidia
# LLM_PROVIDER_ANALYSIS=anthropic

# Option B: NVIDIA NIM / OpenAI-compatible (cheap pipeline tests; no Anthropic key needed)
# Create a key at https://build.nvidia.com/ (API section) — we never need you to paste it into chat;
# set NVIDIA_API_KEY only in Render or local .env.
# LLM_PROVIDER=nvidia
# NVIDIA_API_KEY=
# NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
# NVIDIA_MODEL=meta/llama-3.1-8b-instruct

# Option C: Kimi (Moonshot) — OpenAI-compatible /chat/completions
# Use as analysis provider: LLM_PROVIDER_ANALYSIS=kimi
# KIMI_API_KEY=
# KIMI_BASE_URL=https://api.moonshot.cn/v1
# KIMI_MODEL=

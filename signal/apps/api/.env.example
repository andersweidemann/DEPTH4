# Copy to .env (do not commit .env)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
REDIS_URL=redis://localhost:6379/0
FRONTEND_URL=http://localhost:3000

# Optional: POST https://<render-host>/cron/ingest-once with header X-Depth4-Ingest-Secret: <same value>
# runs one RSS+classify cycle (UptimeRobot / Render Cron) without keeping timers inside the API process.
INGEST_CRON_SECRET=

# --- DEPTH4 kill switch + active-user guard ---
# DEPTH4_ENABLED=false disables all DEPTH4 LLM (background + interactive API routes).
# MIN_ACTIVE_USERS_FOR_DEPTH4: background RSS/briefing/refinement/cron ingest pause when active-user
# proxy count is below this (see depth4_guard.get_active_user_count). Use 0 to disable the threshold.
# DEPTH4_ENABLED=true
# MIN_ACTIVE_USERS_FOR_DEPTH4=2
# GET /cron/depth4-status or GET /admin/depth4-status with X-Depth4-Ingest-Secret for guard snapshot.
# LLM_USAGE_STATS_ENABLED=true  # set false to skip Supabase llm_usage_stats upserts (logs unchanged)
# GET /admin/llm-usage?days=7 with X-Depth4-Ingest-Secret — aggregated LLM cost by provider/task/tier
# GET /admin/llm-ops-dashboard?days=7 — guard + spend by provider + recent rows (same header)

# --- Idle billing (no LLM while nobody drives the product) ---
# When false, the API does NOT start RSS/Yahoo/briefing/refinement background loops — no Anthropic/NVIDIA
# spend from idle timers. News still updates when: (1) cron hits /cron/ingest-once, or (2) a signed-in user
# clicks Refresh in the dashboard (POST /market/ingest-session, ~90s cooldown per user in Redis).
ENABLE_BACKGROUND_LLM_LOOPS=false
# If you turn continuous loops back on, sleep between RSS cycles (seconds).
RSS_INTERVAL_SECONDS=60

# --- LLM: quality-first (default) ---
# Leave LLM_PROVIDER_BACKGROUND unset so classify + consequence + repair + briefings + refinement + alert
# personalization use your classify/analysis routing below (typically Anthropic for best tree quality).
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=
# Default Anthropic id when Kimi is not used for a cheap/standard hop.
ANTHROPIC_MODEL=claude-3-5-haiku-20241022
# Premium / escalation target (Opus-class).
# ANTHROPIC_MODEL_PREMIUM=claude-opus-4-7
# Fallback Anthropic model when tier is cheap/standard but KIMI_* is unset.
# ANTHROPIC_MODEL_CHEAP=claude-3-5-haiku-20241022
# When false, no Opus escalation after a failed cheap attempt (debug only).
# LLM_ROUTING_ESCALATION=true

# Rough premium (ANTHROPIC_MODEL_PREMIUM) spend caps per API process — 0 disables that window.
# Exceeded: block escalation unless high_stakes; premium-first tasks degrade to cheap/standard caps.
# LLM_PREMIUM_DAILY_BUDGET_USD=0
# LLM_PREMIUM_HOURLY_BUDGET_USD=0

# Optional: on-demand "Premium personalize" still uses this provider (default anthropic).
LLM_PROVIDER_INTERACTIVE=anthropic

# Per-task overrides when NOT using LLM_PROVIDER_BACKGROUND (advanced).
# LLM_PROVIDER_CLASSIFY=anthropic
# LLM_PROVIDER_ANALYSIS=anthropic

# Optional: route ALL automated classify+analysis to one cheap provider (e.g. NVIDIA) — trades quality for cost.
# LLM_PROVIDER_BACKGROUND=nvidia
# NVIDIA_API_KEY=
# NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
# NVIDIA_MODEL=meta/llama-3.1-8b-instruct

# Option: Kimi (Moonshot) — OpenAI-compatible /chat/completions
# LLM_PROVIDER_ANALYSIS=kimi
# KIMI_API_KEY=
# KIMI_BASE_URL=https://api.moonshot.cn/v1
# KIMI_MODEL=kimi-k2.6

# Copy this file to `.env` (same directory) and fill in your real values.
# `.env` is gitignored; this `.env.example` is committed as documentation.
#
# Required for `python -m agents.run_loop` (LLM calls):
ANTHROPIC_API_KEY=sk-ant-api03-REPLACE_ME

# Only needed if you flip `llm.provider: openai` in config.yaml:
# OPENAI_API_KEY=sk-REPLACE_ME

# Optional, but strongly recommended for the Scout agent - raises the GitHub
# search rate limit from 10 req/min unauthenticated to 30 req/min, and unlocks
# a larger page size. Create at https://github.com/settings/tokens (classic or
# fine-grained). Only needs `public_repo` scope.
# GITHUB_TOKEN=ghp_REPLACE_ME

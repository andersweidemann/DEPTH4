# Optional: override default API endpoints
# POLYMARKET_DATA_API=https://data-api.polymarket.com
# POLYMARKET_GAMMA_API=https://gamma-api.polymarket.com
# POLYMARKET_CLOB_API=https://clob.polymarket.com

# Where to store the local cache
WHALES_DB_PATH=./data/whales.db

# Polite rate limiting (requests per second)
WHALES_RATE_LIMIT_RPS=20

# Optional: webhook URL for new-trade alerts
# WHALES_ALERT_WEBHOOK=https://hooks.slack.com/services/...

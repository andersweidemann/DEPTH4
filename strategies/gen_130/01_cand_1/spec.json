{
  "hypothesis": "Breakouts from the Asia range during the London session can be profitable",
  "regime_filter": {
    "type": "session",
    "params": {
      "start_hour": 7,
      "end_hour": 10
    }
  },
  "entry_rule": {
    "type": "asia_london_breakout",
    "params": {
      "asia_range_period": 6,
      "london_breakout_period": 1
    }
  },
  "exit_rule": {
    "type": "tp_sl_time_stop",
    "params": {
      "tp": "fixed_pips",
      "sl": "fixed_pips",
      "time_stop": 60
    }
  },
  "sizing_rule": {
    "type": "fixed_fraction",
    "params": {
      "fraction": 0.01
    }
  }
}
{
  "hypothesis": "Price bouncing off the Bollinger Bands can be a profitable trading opportunity",
  "regime_filter": {
    "type": "bb_width",
    "params": {
      "min_width": 10
    }
  },
  "entry_rule": {
    "type": "bb_bounce",
    "params": {
      "bb_period": 20,
      "bb_deviation": 1.75
    }
  },
  "exit_rule": {
    "type": "tp_sl_time_stop",
    "params": {
      "tp": "middle_bb",
      "sl": "1.5_atr",
      "time_stop": 30
    }
  },
  "sizing_rule": {
    "type": "fixed_fraction",
    "params": {
      "fraction": 0.01
    }
  }
}
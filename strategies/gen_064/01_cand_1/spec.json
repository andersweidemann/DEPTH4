{
  "hypothesis": "Asia-London range expansion occurs on GER40 M15 with breakout and retest patterns",
  "regime_filter": {
    "type": "session_mask",
    "params": {
      "session": "asia_london"
    }
  },
  "entry_rule": {
    "type": "breakout_retest",
    "params": {
      "range_atr_min": 0.5,
      "range_atr_max": 2.0,
      "breakout_atr": 1.2,
      "retest_atr": 0.2
    }
  },
  "exit_rule": {
    "type": "tp_sl_time",
    "params": {
      "tp": "fixed_pips",
      "sl": "fixed_pips",
      "time_stop": 20
    }
  },
  "sizing_rule": {
    "type": "fixed_fraction",
    "params": {
      "fraction": 0.02
    }
  }
}
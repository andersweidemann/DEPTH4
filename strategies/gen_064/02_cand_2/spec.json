{
  "hypothesis": "Bollinger Band touch-and-bounce reversal occurs on US500 M5 with RSI confirmation",
  "regime_filter": {
    "type": "rsi_percentile",
    "params": {
      "period": 7,
      "percentile": 50
    }
  },
  "entry_rule": {
    "type": "bb_touch_bounce",
    "params": {
      "bb_period": 20,
      "bb_deviation": 2.0,
      "rsi_period": 7,
      "rsi_thresholds": [
        30,
        70
      ]
    }
  },
  "exit_rule": {
    "type": "tp_sl_time",
    "params": {
      "tp": "opposite_bb",
      "sl": "1.5_atr",
      "time_stop": 25
    }
  },
  "sizing_rule": {
    "type": "fixed_fraction",
    "params": {
      "fraction": 0.015
    }
  }
}
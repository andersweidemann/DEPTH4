{
  "name": "GER40_Donchian_Breakout_M15",
  "family": "breakout",
  "symbol": "GER40",
  "timeframe": "M15",
  "hypothesis": "On GER40 M15 during the European cash session, a 20-bar Donchian breakout with ADX(14) rising above 22 and ATR above median produces trend-following expectancy of >=1.8R before reversal, while the session filter avoids overnight thin-liquidity fake breaks.",
  "regime_filter": {
    "primitives": [
      "adx",
      "atr_percentile",
      "session_mask"
    ],
    "rules": [
      {
        "type": "session_mask",
        "window_utc": "07:00-16:30"
      },
      {
        "type": "adx",
        "period": 14,
        "min": 22
      },
      {
        "type": "atr_percentile",
        "period": 14,
        "lookback": 300,
        "min_pct": 40
      }
    ]
  },
  "entry": {
    "signal_primitives": [
      "donchian",
      "ema",
      "adx"
    ],
    "rules": [
      "LONG: close > Donchian_high(20)[1] AND close > EMA(50).",
      "SHORT: close < Donchian_low(20)[1] AND close < EMA(50).",
      "Require ADX(14) rising (ADX[0] > ADX[3]).",
      "Skip entry if current bar range > 3*ATR14 (exhaustion guard)."
    ]
  },
  "exit": {
    "sl": {
      "type": "atr",
      "mult": 2.0,
      "period": 14
    },
    "tp": {
      "type": "atr",
      "mult": 4.0,
      "period": 14
    },
    "time_stop": {
      "bars": 48,
      "action": "close_at_market"
    },
    "trailing": {
      "type": "atr",
      "mult": 2.5,
      "activate_at_r": 1.5
    }
  },
  "sizing": {
    "type": "risk_pct",
    "risk_per_trade_pct": 0.5,
    "max_concurrent_positions": 1
  },
  "params": {
    "donchian_period": 20,
    "ema_period": 50,
    "adx_period": 14,
    "adx_min": 22,
    "atr_period": 14
  },
  "acceptance_targets": {
    "pf_min": 2.0,
    "sharpe_min": 1.5,
    "max_dd_pct": 15.0,
    "trades_min": 200
  }
}
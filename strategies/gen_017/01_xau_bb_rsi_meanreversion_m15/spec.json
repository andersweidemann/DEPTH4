{
  "name": "XAU_BB_RSI_MeanReversion_M15",
  "family": "mean_reversion",
  "symbol": "XAUUSD",
  "timeframe": "M15",
  "hypothesis": "On XAUUSD M15, closes outside BB(20,2.0) with simultaneous RSI(7) extreme (<10 or >90), filtered by BB-width above the 30th percentile and active session, revert to the 20-SMA midline more often than they extend, yielding positive expectancy with a 1.5x ATR stop.",
  "regime_filter": {
    "primitives": [
      "bb_width",
      "adx",
      "session_mask"
    ],
    "rules": [
      {
        "type": "bb_width",
        "period": 20,
        "dev": 2.0,
        "min_percentile": 30,
        "lookback": 500
      },
      {
        "type": "adx",
        "period": 14,
        "max": 28,
        "note": "avoid strong trend regimes"
      },
      {
        "type": "session_mask",
        "window_utc": "07:00-20:00"
      }
    ]
  },
  "entry": {
    "signal_primitives": [
      "bollinger",
      "rsi"
    ],
    "rules": [
      "LONG: close < lower_BB(20,2.0) AND RSI(7) < 10.",
      "SHORT: close > upper_BB(20,2.0) AND RSI(7) > 90.",
      "Cooldown: no new entry within 3 bars of last close.",
      "No new entry if open position in same direction."
    ]
  },
  "exit": {
    "sl": {
      "type": "atr",
      "mult": 1.5,
      "period": 14
    },
    "tp": {
      "type": "indicator_level",
      "target": "middle_BB_20",
      "min_r": 1.0
    },
    "time_stop": {
      "bars": 24,
      "action": "close_at_market"
    },
    "trailing": null
  },
  "sizing": {
    "type": "risk_pct",
    "risk_per_trade_pct": 0.5,
    "max_concurrent_positions": 1
  },
  "params": {
    "bb_period": 20,
    "bb_dev": 2.0,
    "rsi_period": 7,
    "rsi_long_thr": 10,
    "rsi_short_thr": 90,
    "atr_period": 14,
    "cooldown_bars": 3
  },
  "acceptance_targets": {
    "pf_min": 2.0,
    "sharpe_min": 1.5,
    "max_dd_pct": 15.0,
    "trades_min": 200
  }
}
{
  "hypothesis": "The RSI(7) indicator can be used to identify overbought and oversold conditions",
  "regime_filter": {
    "type": "rsi",
    "params": {
      "period": 7,
      "thresholds": [
        30,
        70
      ]
    }
  },
  "entry_rules": {
    "long": {
      "condition": "rsi(7) < 30"
    },
    "short": {
      "condition": "rsi(7) > 70"
    }
  },
  "exit_rules": {
    "tp": {
      "type": "fixed",
      "params": {
        "pips": 30
      }
    },
    "sl": {
      "type": "fixed",
      "params": {
        "pips": 15
      }
    },
    "time_stop": {
      "type": "bars",
      "params": {
        "num_bars": 20
      }
    }
  },
  "sizing_rules": {
    "type": "fixed",
    "params": {
      "size": 0.05
    }
  }
}
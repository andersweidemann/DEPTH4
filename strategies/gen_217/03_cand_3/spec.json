{
  "hypothesis": "Mean reversion occurs when price reaches extreme RSI readings with a specific Donchian channel setup",
  "regime_filter": {
    "type": "donchian_channel",
    "params": {
      "period": 20,
      "threshold": 1.0
    }
  },
  "entry_rule": {
    "type": "rsi_donchian_mean_reversion",
    "params": {
      "rsi_period": 7,
      "rsi_thresholds": [
        10,
        90
      ],
      "donchian_period": 20
    }
  },
  "exit_rule": {
    "type": "opposite_donchian_tp",
    "params": {
      "sl_multiplier": 1.2,
      "time_stop_bars": 20
    }
  },
  "sizing_rule": {
    "type": "fixed_size",
    "params": {
      "size": 0.05
    }
  }
}
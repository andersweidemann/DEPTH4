{
  "hypothesis": "Breakouts occur on GER40 M15 after an Asia-London range expansion.",
  "regime_filter": {
    "type": "asia_london_range",
    "params": {
      "min_range_atr": 0.5,
      "max_range_atr": 2.0
    }
  },
  "entry_rules": {
    "long": {
      "condition": "breakout > upper_range and displacement > 1.2 * atr(14)"
    },
    "short": {
      "condition": "breakout < lower_range and displacement > 1.2 * atr(14)"
    }
  },
  "exit_rules": {
    "sl": {
      "type": "fixed",
      "params": {
        "pips": 100
      }
    },
    "tp": {
      "type": "fixed",
      "params": {
        "pips": 500
      }
    },
    "time_stop": {
      "type": "bars",
      "params": {
        "num_bars": 20
      }
    }
  },
  "sizing_rules": {
    "type": "fixed",
    "params": {
      "size": 0.01
    }
  }
}
{
  "hypothesis": "Asia-London range expansion leads to breakout opportunities",
  "regime_filter": {
    "type": "session",
    "params": {
      "start_hour": 7,
      "end_hour": 10
    }
  },
  "entry_rule": {
    "type": "breakout",
    "params": {
      "range_atr_min": 0.5,
      "range_atr_max": 2.0,
      "breakout_atr_multiplier": 1.2
    }
  },
  "exit_rule": {
    "type": "tp_sl",
    "params": {
      "tp_pips": 500,
      "sl_pips": 100
    }
  },
  "sizing_rule": {
    "type": "fixed_risk",
    "params": {
      "risk_fraction": 0.02
    }
  }
}
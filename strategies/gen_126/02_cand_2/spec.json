{
  "hypothesis": "Bollinger Band touch-and-bounce reversal occurs during high volatility",
  "regime_filter": {
    "type": "bb_width_percentile",
    "params": {
      "percentile": 70,
      "lookback": 20
    }
  },
  "symbol": "BTCUSD",
  "timeframe": "M5",
  "entry_rule": {
    "type": "bb_touch",
    "params": {
      "bb_period": 20,
      "bb_deviation": 2.0
    }
  },
  "exit_rule": {
    "type": "tp_sl_time",
    "params": {
      "tp": "opposite_bb",
      "sl": "1.5_atr",
      "time_stop": 30
    }
  },
  "sizing_rule": {
    "type": "fixed_fraction",
    "params": {
      "fraction": 0.01
    }
  }
}
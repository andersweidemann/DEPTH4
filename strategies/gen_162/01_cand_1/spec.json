{
  "hypothesis": "Asia-London range expansion occurs on GER40 M15",
  "regime_filter": {
    "type": "session",
    "params": {
      "session": "london"
    }
  },
  "entry_rules": {
    "long": {
      "condition": "breakout > 1.2 * atr(14) && breakout > 0.5 * range_atr"
    },
    "short": {
      "condition": "breakout < -1.2 * atr(14) && breakout < -0.5 * range_atr"
    }
  },
  "exit_rules": {
    "sl": {
      "type": "fixed",
      "params": {
        "pips": 100
      }
    },
    "tp": {
      "type": "fixed",
      "params": {
        "pips": 500
      }
    },
    "time_stop": {
      "type": "bars",
      "params": {
        "bars": 20
      }
    }
  },
  "sizing_rules": {
    "type": "fixed",
    "params": {
      "size": 0.1
    }
  }
}
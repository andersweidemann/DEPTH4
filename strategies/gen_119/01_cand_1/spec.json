{
  "hypothesis": "Breakouts occur during the London session after an Asia range expansion",
  "regime_filter": {
    "type": "session",
    "params": {
      "session": "london"
    }
  },
  "entry_rules": {
    "long": {
      "condition": "breakout > 0 && asia_range < 2 * atr(14)"
    },
    "short": {
      "condition": "breakout < 0 && asia_range < 2 * atr(14)"
    }
  },
  "exit_rules": {
    "sl": {
      "type": "fixed",
      "params": {
        "pips": 100
      }
    },
    "tp": {
      "type": "fixed",
      "params": {
        "pips": 500
      }
    },
    "time_stop": {
      "type": "bars",
      "params": {
        "num_bars": 20
      }
    }
  },
  "sizing_rules": {
    "type": "fixed",
    "params": {
      "lots": 0.1
    }
  }
}
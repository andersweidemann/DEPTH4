{
  "hypothesis": "ATR-based volatility filters can identify profitable mean reversion trades",
  "regime_filter": {
    "type": "atr_percentile",
    "params": {
      "percentile": 50,
      "lookback": 20
    }
  },
  "entry_rules": {
    "long": {
      "condition": "close < lower_bb && atr(14) > 20"
    },
    "short": {
      "condition": "close > upper_bb && atr(14) > 20"
    }
  },
  "exit_rules": {
    "sl": {
      "type": "fixed",
      "params": {
        "pips": 150
      }
    },
    "tp": {
      "type": "fixed",
      "params": {
        "pips": 300
      }
    },
    "time_stop": {
      "type": "bars",
      "params": {
        "num_bars": 30
      }
    }
  },
  "sizing_rules": {
    "type": "fixed",
    "params": {
      "lots": 0.05
    }
  }
}
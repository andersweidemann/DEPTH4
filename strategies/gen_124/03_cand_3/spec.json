{
  "hypothesis": "Mean reversion strategy with ATR-based stop loss is effective on US500 M15",
  "regime_filter": {
    "type": "session_mask",
    "params": {
      "session": "us"
    }
  },
  "entry_rule": {
    "type": "mean_reversion",
    "params": {
      "bb_period": 20,
      "bb_deviation": 1.75,
      "rsi_period": 7,
      "rsi_thresholds": [
        10,
        90
      ]
    }
  },
  "exit_rule": {
    "type": "multi_exit",
    "params": {
      "take_profit": {
        "type": "opposite_bb",
        "params": {}
      },
      "stop_loss": {
        "type": "atr_based",
        "params": {
          "atr_period": 14,
          "atr_multiplier": 1.5
        }
      },
      "time_stop": {
        "type": "fixed_bars",
        "params": {
          "bars": 30
        }
      }
    }
  },
  "sizing_rule": {
    "type": "fixed_fraction",
    "params": {
      "fraction": 0.02
    }
  }
}
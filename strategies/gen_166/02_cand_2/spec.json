{
  "hypothesis": "Bollinger Band touch-and-bounce reversal is effective on XAUUSD M15",
  "regime_filter": {
    "type": "bb_width",
    "params": {
      "min_width": 0.01,
      "max_width": 0.05
    }
  },
  "entry_rule": {
    "type": "bb_touch",
    "params": {
      "bb_period": 20,
      "bb_deviation": 2.0
    }
  },
  "exit_rule": {
    "type": "tp_sl_time",
    "params": {
      "tp": "opposite_bb",
      "sl": "1.5_atr",
      "time_stop": 30
    }
  },
  "sizing_rule": {
    "type": "fixed_fraction",
    "params": {
      "fraction": 0.01
    }
  }
}
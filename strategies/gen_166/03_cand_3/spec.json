{
  "hypothesis": "Mean reversion occurs when price reaches extreme RSI readings with high ATR on US500 M5",
  "regime_filter": {
    "type": "atr_percentile",
    "params": {
      "percentile": 70,
      "lookback": 100
    }
  },
  "entry_rule": {
    "type": "rsi_atr",
    "params": {
      "rsi_period": 7,
      "rsi_thresholds": [
        10,
        90
      ],
      "atr_period": 14
    }
  },
  "exit_rule": {
    "type": "tp_sl_time",
    "params": {
      "tp": "fixed_pips",
      "tp_pips": 200,
      "sl": "1.5_atr",
      "time_stop": 30
    }
  },
  "sizing_rule": {
    "type": "fixed_fraction",
    "params": {
      "fraction": 0.01
    }
  }
}
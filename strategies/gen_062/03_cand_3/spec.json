{
  "hypothesis": "Mean reversion occurs when price reaches extreme deviations from its mean with extreme RSI readings",
  "regime_filter": {
    "type": "volatility",
    "params": {
      "atr_period": 14,
      "atr_threshold": 20
    }
  },
  "entry_rule": {
    "type": "mean_reversion",
    "params": {
      "bb_period": 20,
      "bb_deviation": 1.75,
      "rsi_period": 7,
      "rsi_thresholds": [
        10,
        90
      ]
    }
  },
  "exit_rule": {
    "type": "tp_sl",
    "params": {
      "tp_pips": 50,
      "sl_pips": 100
    }
  },
  "sizing_rule": {
    "type": "fixed_size",
    "params": {
      "size": 0.1
    }
  }
}
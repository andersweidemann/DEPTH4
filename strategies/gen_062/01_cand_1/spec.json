{
  "hypothesis": "London breakout occurs after Asia range consolidation",
  "regime_filter": {
    "type": "session",
    "params": {
      "start_hour": 7,
      "end_hour": 10
    }
  },
  "entry_rule": {
    "type": "london_breakout",
    "params": {
      "asia_range_hours": [
        0,
        6
      ],
      "breakout_threshold": 0.5
    }
  },
  "exit_rule": {
    "type": "tp_sl",
    "params": {
      "tp_pips": 50,
      "sl_pips": 100
    }
  },
  "sizing_rule": {
    "type": "fixed_size",
    "params": {
      "size": 0.1
    }
  }
}
{
  "hypothesis": "Bollinger Band touch-and-bounce reversal is profitable on XAUUSD M5",
  "regime_filter": {
    "type": "bb_width",
    "params": {
      "bb_period": 20,
      "bb_deviation": 1.75,
      "min_width": 0.5
    }
  },
  "entry_rules": {
    "long": {
      "condition": "close > lower_bb && close < lower_bb + 0.2 * atr(14)"
    },
    "short": {
      "condition": "close < upper_bb && close > upper_bb - 0.2 * atr(14)"
    }
  },
  "exit_rules": {
    "sl": {
      "type": "atr",
      "params": {
        "atr_period": 14,
        "atr_multiplier": 1.5
      }
    },
    "tp": {
      "type": "opposite_bb"
    },
    "time_stop": {
      "type": "bars",
      "params": {
        "bars": 30
      }
    }
  },
  "sizing_rules": {
    "type": "fixed",
    "params": {
      "size": 0.1
    }
  }
}
{
  "hypothesis": "Mean reversion occurs on US500 M15 when price reaches extreme RSI readings",
  "regime_filter": {
    "type": "rsi",
    "params": {
      "rsi_period": 7,
      "rsi_threshold": 90
    }
  },
  "entry_rules": {
    "long": {
      "condition": "rsi(7) < 10"
    },
    "short": {
      "condition": "rsi(7) > 90"
    }
  },
  "exit_rules": {
    "sl": {
      "type": "atr",
      "params": {
        "atr_period": 14,
        "atr_multiplier": 1.5
      }
    },
    "tp": {
      "type": "fixed",
      "params": {
        "pips": 200
      }
    },
    "time_stop": {
      "type": "hours",
      "params": {
        "hours": 2
      }
    }
  },
  "sizing_rules": {
    "type": "risk",
    "params": {
      "risk_percent": 2
    }
  }
}
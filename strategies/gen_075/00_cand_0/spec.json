{
  "hypothesis": "Mean reversion occurs in XAUUSD on M5 when price closes outside Bollinger Bands with extreme RSI readings",
  "regime_filter": {
    "type": "bb_width_percentile",
    "params": {
      "bb_period": 20,
      "bb_deviation": 1.75,
      "percentile": 30
    }
  },
  "entry_rule": {
    "type": "mean_reversion",
    "params": {
      "rsi_period": 7,
      "rsi_thresholds": [
        10,
        90
      ]
    }
  },
  "exit_rule": {
    "type": "multi_exit",
    "params": {
      "tp": {
        "type": "opposite_bb"
      },
      "sl": {
        "type": "atr",
        "params": {
          "atr_period": 14,
          "atr_multiplier": 1.5
        }
      },
      "time_stop": {
        "type": "bars",
        "params": {
          "bars": 30
        }
      }
    }
  },
  "sizing_rule": {
    "type": "fixed_fraction",
    "params": {
      "fraction": 0.01
    }
  }
}
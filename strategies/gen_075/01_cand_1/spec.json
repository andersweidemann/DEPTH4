{
  "hypothesis": "London breakout occurs in GER40 on M15 when price breaks out of Asia range with sufficient volatility",
  "regime_filter": {
    "type": "atr_percentile",
    "params": {
      "atr_period": 14,
      "percentile": 50
    }
  },
  "entry_rule": {
    "type": "london_breakout",
    "params": {
      "asia_range_hours": [
        0,
        6
      ],
      "london_breakout_hours": [
        7,
        10
      ],
      "min_range_atr": 0.5,
      "max_range_atr": 2.0
    }
  },
  "exit_rule": {
    "type": "multi_exit",
    "params": {
      "tp": {
        "type": "fixed_pips",
        "params": {
          "pips": 100
        }
      },
      "sl": {
        "type": "fixed_pips",
        "params": {
          "pips": 50
        }
      },
      "time_stop": {
        "type": "bars",
        "params": {
          "bars": 60
        }
      }
    }
  },
  "sizing_rule": {
    "type": "fixed_fraction",
    "params": {
      "fraction": 0.02
    }
  }
}
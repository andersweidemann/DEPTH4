{
  "hypothesis": "The London session volatility can be captured using a combination of technical indicators",
  "regime_filter": {
    "type": "session",
    "params": {
      "start": "07:00",
      "end": "10:00"
    }
  },
  "entry_rules": {
    "long": {
      "condition": "close > sma(20) && rsi(7) > 50"
    },
    "short": {
      "condition": "close < sma(20) && rsi(7) < 50"
    }
  },
  "exit_rules": {
    "sl": {
      "type": "fixed",
      "params": {
        "distance": 1.5
      }
    },
    "tp": {
      "type": "fixed",
      "params": {
        "distance": 300
      }
    },
    "time_stop": {
      "type": "fixed",
      "params": {
        "bars": 30
      }
    }
  },
  "sizing_rules": {
    "type": "fixed",
    "params": {
      "size": 0.015
    }
  }
}
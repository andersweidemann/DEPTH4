{
  "hypothesis": "Breakouts occur when price closes outside the Asia range with sufficient volatility",
  "regime_filter": {
    "type": "atr_percentile",
    "params": {
      "percentile": 50,
      "lookback": 14
    }
  },
  "entry_rules": {
    "long": {
      "condition": "close > asia_high && atr(14) > atr_percentile"
    },
    "short": {
      "condition": "close < asia_low && atr(14) > atr_percentile"
    }
  },
  "exit_rules": {
    "sl": {
      "type": "fixed",
      "params": {
        "distance": 100
      }
    },
    "tp": {
      "type": "fixed",
      "params": {
        "distance": 500
      }
    },
    "time_stop": {
      "type": "fixed",
      "params": {
        "bars": 20
      }
    }
  },
  "sizing_rules": {
    "type": "fixed",
    "params": {
      "size": 0.01
    }
  }
}
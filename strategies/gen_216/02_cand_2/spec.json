{
  "hypothesis": "Price reverts to the mean when it reaches extreme deviations from the Bollinger Band mean",
  "regime_filter": {
    "type": "bb_width_percentile",
    "params": {
      "percentile": 70,
      "lookback": 20
    }
  },
  "entry_rules": {
    "long": {
      "condition": "close < lower_bb && rsi(7) < 20"
    },
    "short": {
      "condition": "close > upper_bb && rsi(7) > 80"
    }
  },
  "exit_rules": {
    "sl": {
      "type": "fixed",
      "params": {
        "distance": 1.2
      }
    },
    "tp": {
      "type": "middle_bb"
    },
    "time_stop": {
      "type": "fixed",
      "params": {
        "bars": 40
      }
    }
  },
  "sizing_rules": {
    "type": "fixed",
    "params": {
      "size": 0.02
    }
  }
}
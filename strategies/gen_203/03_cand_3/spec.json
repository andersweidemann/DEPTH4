{
  "hypothesis": "The RSI can be used to identify overbought and oversold conditions, and trade reversals",
  "regime_filter": {
    "type": "rsi",
    "params": {
      "rsi_period": 7,
      "rsi_threshold": 70
    }
  },
  "entry_rules": {
    "long": {
      "condition": "rsi(7) < 30"
    },
    "short": {
      "condition": "rsi(7) > 70"
    }
  },
  "exit_rules": {
    "stop_loss": {
      "type": "atr",
      "params": {
        "atr_period": 14,
        "atr_multiplier": 1.5
      }
    },
    "take_profit": {
      "type": "fixed",
      "params": {
        "pips": 50
      }
    },
    "time_stop": {
      "type": "bars",
      "params": {
        "bars": 30
      }
    }
  },
  "sizing_rules": {
    "type": "fixed",
    "params": {
      "size": 0.01
    }
  }
}
{
  "hypothesis": "Breakouts occur after a period of consolidation, and can be traded using a Donchian channel",
  "regime_filter": {
    "type": "donchian_channel",
    "params": {
      "donchian_period": 20
    }
  },
  "entry_rules": {
    "long": {
      "condition": "close > donchian_high"
    },
    "short": {
      "condition": "close < donchian_low"
    }
  },
  "exit_rules": {
    "stop_loss": {
      "type": "atr",
      "params": {
        "atr_period": 14,
        "atr_multiplier": 1.5
      }
    },
    "take_profit": {
      "type": "fixed",
      "params": {
        "pips": 50
      }
    },
    "time_stop": {
      "type": "bars",
      "params": {
        "bars": 30
      }
    }
  },
  "sizing_rules": {
    "type": "fixed",
    "params": {
      "size": 0.01
    }
  }
}
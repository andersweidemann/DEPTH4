{
  "hypothesis": "The Asia-London range expansion strategy can be used to trade breakouts during the London session",
  "regime_filter": {
    "type": "session",
    "params": {
      "session": "london"
    }
  },
  "entry_rules": {
    "long": {
      "condition": "close > asia_high"
    },
    "short": {
      "condition": "close < asia_low"
    }
  },
  "exit_rules": {
    "stop_loss": {
      "type": "atr",
      "params": {
        "atr_period": 14,
        "atr_multiplier": 1.5
      }
    },
    "take_profit": {
      "type": "fixed",
      "params": {
        "pips": 50
      }
    },
    "time_stop": {
      "type": "bars",
      "params": {
        "bars": 30
      }
    }
  },
  "sizing_rules": {
    "type": "fixed",
    "params": {
      "size": 0.01
    }
  }
}
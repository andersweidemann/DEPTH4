{
  "name": "Volatility Squeeze",
  "symbols": [
    "GER40"
  ],
  "timeframes": [
    "M15"
  ],
  "hypothesis": "Volatility expansion after contraction",
  "regime_filter": "atr_percentile(14) < 20",
  "entry_rules": {
    "long": "close > upper_bollinger_band(20, 2.0) and atr(14) > atr(14)[1]",
    "short": "close < lower_bollinger_band(20, 2.0) and atr(14) > atr(14)[1]"
  },
  "exit_rules": {
    "stop_loss": "1.5 * atr(14)",
    "take_profit": "2 * atr(14)",
    "time_stop": "30 minutes"
  },
  "sizing": {
    "fixed_size": 0.1
  }
}
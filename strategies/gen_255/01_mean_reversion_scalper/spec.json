{
  "name": "Mean Reversion Scalper",
  "symbols": [
    "GER40"
  ],
  "timeframes": [
    "M15"
  ],
  "hypothesis": "Mean reversion after extreme price deviations",
  "regime_filter": "bb_width_percentile(20, 2.0) > 30",
  "entry_rules": {
    "long": "close < lower_bollinger_band(20, 2.0) and rsi(7) < 10",
    "short": "close > upper_bollinger_band(20, 2.0) and rsi(7) > 90"
  },
  "exit_rules": {
    "stop_loss": "1.5 * atr(14)",
    "take_profit": "opposite_bollinger_band(20, 2.0)",
    "time_stop": "30 minutes"
  },
  "sizing": {
    "fixed_size": 0.1
  }
}
{
  "hypothesis": "Mean reversion occurs when RSI reaches extreme levels on GER40 M5",
  "regime_filter": {
    "type": "adx_filter",
    "params": {
      "min_adx": 20,
      "max_adx": 50
    }
  },
  "entry_rule": {
    "type": "rsi_extremes",
    "params": {
      "rsi_period": 7,
      "rsi_thresholds": [
        10,
        90
      ]
    }
  },
  "exit_rule": {
    "type": "take_profit_and_stop_loss",
    "params": {
      "take_profit": "opposite_rsi_level",
      "stop_loss": "1.5 * atr(14)",
      "time_stop": 25
    }
  },
  "sizing_rule": {
    "type": "fixed_fraction",
    "params": {
      "fraction": 0.02
    }
  }
}
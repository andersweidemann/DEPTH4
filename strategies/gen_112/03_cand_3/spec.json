{
  "hypothesis": "A combination of RSI and Bollinger Bands can be used to trade mean reversion on BTCUSD",
  "regime_filter": {
    "type": "rsi_percentile",
    "params": {
      "percentile": 20,
      "lookback": 14
    }
  },
  "entry_rules": [
    {
      "type": "long",
      "condition": "rsi(14) < 30 && close < lower_bb"
    },
    {
      "type": "short",
      "condition": "rsi(14) > 70 && close > upper_bb"
    }
  ],
  "exit_rules": {
    "sl": {
      "type": "fixed",
      "params": {
        "distance": 150
      }
    },
    "tp": {
      "type": "opposite_bb"
    },
    "time_stop": {
      "type": "hours",
      "params": {
        "num_hours": 4
      }
    }
  },
  "sizing_rules": {
    "type": "risk",
    "params": {
      "risk_percentage": 1.5
    }
  }
}
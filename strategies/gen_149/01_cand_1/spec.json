{
  "hypothesis": "Breakouts from the Asia range during the London session are profitable",
  "regime_filter": {
    "type": "session",
    "params": {
      "start_hour": 7,
      "end_hour": 10
    }
  },
  "entry_rules": {
    "long": {
      "condition": "close > upper_range && displacement > 1.2 * atr(14)"
    },
    "short": {
      "condition": "close < lower_range && displacement < -1.2 * atr(14)"
    }
  },
  "exit_rules": {
    "tp": {
      "type": "fixed_pips",
      "params": {
        "pips": 100
      }
    },
    "sl": {
      "type": "fixed_pips",
      "params": {
        "pips": 50
      }
    },
    "time_stop": {
      "type": "bars",
      "params": {
        "num_bars": 20
      }
    }
  },
  "sizing_rules": {
    "type": "fixed_size",
    "params": {
      "size": 0.1
    }
  }
}
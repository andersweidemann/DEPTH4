{
  "hypothesis": "RSI extremes during high-volatility regimes are mean-reversion opportunities",
  "regime_filter": {
    "type": "atr_percentile",
    "params": {
      "percentile": 70
    }
  },
  "entry_rules": {
    "long": {
      "condition": "rsi(7) < 10 && close < lower_bb"
    },
    "short": {
      "condition": "rsi(7) > 90 && close > upper_bb"
    }
  },
  "exit_rules": {
    "tp": {
      "type": "middle_bb"
    },
    "sl": {
      "type": "atr",
      "params": {
        "multiplier": 2
      }
    },
    "time_stop": {
      "type": "bars",
      "params": {
        "num_bars": 40
      }
    }
  },
  "sizing_rules": {
    "type": "fixed_fraction",
    "params": {
      "fraction": 0.02
    }
  }
}
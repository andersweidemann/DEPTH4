{
  "hypothesis": "Donchian channel breakouts are profitable during trending regimes",
  "regime_filter": {
    "type": "adx",
    "params": {
      "threshold": 25
    }
  },
  "entry_rules": {
    "long": {
      "condition": "close > upper_dc && adx(14) > 25"
    },
    "short": {
      "condition": "close < lower_dc && adx(14) > 25"
    }
  },
  "exit_rules": {
    "tp": {
      "type": "fixed_pips",
      "params": {
        "pips": 150
      }
    },
    "sl": {
      "type": "fixed_pips",
      "params": {
        "pips": 75
      }
    },
    "time_stop": {
      "type": "bars",
      "params": {
        "num_bars": 30
      }
    }
  },
  "sizing_rules": {
    "type": "fixed_size",
    "params": {
      "size": 0.2
    }
  }
}
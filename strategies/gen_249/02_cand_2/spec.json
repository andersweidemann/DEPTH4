{
  "hypothesis": "Bollinger Band scalping is profitable on XAUUSD M5 during active sessions",
  "regime_filter": {
    "type": "session",
    "params": {
      "start_hour": 7,
      "end_hour": 20
    }
  },
  "entry_rule": {
    "type": "bb_rejection",
    "params": {
      "bb_period": 20,
      "bb_deviation": 2.0
    }
  },
  "exit_rule": {
    "type": "opposite_bb",
    "params": {}
  },
  "sl_rule": {
    "type": "atr",
    "params": {
      "period": 14,
      "multiplier": 1.5
    }
  },
  "tp_rule": {
    "type": "fixed",
    "params": {
      "pips": 50
    }
  },
  "time_stop": 30,
  "sizing_rule": {
    "type": "fixed",
    "params": {
      "lots": 0.1
    }
  }
}
{
  "hypothesis": "Volatility contraction leads to breakout opportunities",
  "regime_filter": {
    "type": "volatility",
    "params": {
      "lookback": 20,
      "threshold": 0.5
    }
  },
  "entry_rules": {
    "long": {
      "condition": "breakout > 0.5 * atr(14) && displacement > 1.2 * atr(14)"
    },
    "short": {
      "condition": "breakout < -0.5 * atr(14) && displacement < -1.2 * atr(14)"
    }
  },
  "exit_rules": {
    "sl": {
      "type": "fixed",
      "params": {
        "pips": 100
      }
    },
    "tp": {
      "type": "fixed",
      "params": {
        "pips": 500
      }
    },
    "time_stop": {
      "type": "hours",
      "params": {
        "num_hours": 2
      }
    }
  },
  "sizing_rules": {
    "type": "risk",
    "params": {
      "risk_percent": 2
    }
  }
}
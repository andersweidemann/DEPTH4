{
  "hypothesis": "Breakout occurs on BTCUSD M5 when price breaks out of Donchian channel with increased volatility",
  "regime_filter": {
    "type": "atr_percentile",
    "params": {
      "atr_period": 14,
      "percentile": 50
    }
  },
  "entry_rules": {
    "long": {
      "condition": "high > donchian_channel_high && atr(14) > atr_percentile(50)"
    },
    "short": {
      "condition": "low < donchian_channel_low && atr(14) > atr_percentile(50)"
    }
  },
  "exit_rules": {
    "sl": {
      "type": "fixed",
      "params": {
        "pips": 100
      }
    },
    "tp": {
      "type": "fixed",
      "params": {
        "pips": 500
      }
    },
    "time_stop": {
      "type": "hours",
      "params": {
        "hours": 2
      }
    }
  },
  "sizing_rules": {
    "type": "risk",
    "params": {
      "risk": 0.02
    }
  }
}
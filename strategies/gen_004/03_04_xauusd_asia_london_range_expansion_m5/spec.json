{
  "name": "04_xauusd_asia_london_range_expansion_m5",
  "hypothesis": "XAUUSD M5 breakouts from an Asia-session accumulation range (00:00-06:00 UTC) during the London window (07:00-11:00 UTC) capture liquidity-driven volatility expansion; ATR-normalized range gating filters chop days from trend days, yielding PF>=2.0 with sufficient sample.",
  "family": "session_breakout",
  "symbols": [
    "XAUUSD"
  ],
  "timeframes": [
    "M5"
  ],
  "regime_filter": {
    "type": "composite",
    "rules": [
      {
        "primitive": "session_mask",
        "window_utc": "07:00-11:00",
        "active": true
      },
      {
        "primitive": "atr_percentile",
        "period": 14,
        "lookback": 288,
        "min_pct": 30,
        "max_pct": 95
      },
      {
        "primitive": "adx",
        "period": 14,
        "min": 15
      }
    ]
  },
  "entry_rules": {
    "asia_range_window_utc": "00:00-06:00",
    "trade_window_utc": "07:00-11:00",
    "range_constraint": "0.5*ATR(14) <= (asia_high - asia_low) <= 2.0*ATR(14)",
    "long": "close > asia_high + 0.3*ATR(14) AND body >= 1.0*ATR(14)",
    "short": "close < asia_low - 0.3*ATR(14) AND body >= 1.0*ATR(14)",
    "first_signal_only_per_day": true
  },
  "exit_rules": {
    "stop_loss": "0.75 * ATR(14)",
    "take_profit": "2.5 * initial_risk",
    "breakeven_trigger": "1.0 R",
    "trailing": "2.0 * ATR(14) chandelier after 1.5 R",
    "time_stop_bars": 48,
    "force_flat_utc": "15:00"
  },
  "sizing": {
    "mode": "risk_pct_of_equity",
    "risk_per_trade_pct": 0.6,
    "max_concurrent_positions": 1,
    "pyramiding": 0
  },
  "params_to_search": {
    "breakout_atr_buffer": [
      0.2,
      0.3,
      0.5
    ],
    "body_atr_min": [
      0.8,
      1.0,
      1.2
    ],
    "range_atr_min": [
      0.4,
      0.5,
      0.7
    ],
    "range_atr_max": [
      1.8,
      2.0,
      2.5
    ],
    "sl_atr_mult": [
      0.6,
      0.75,
      1.0
    ],
    "tp_R": [
      2.0,
      2.5,
      3.0
    ]
  },
  "acceptance_notes": "M5 on XAUUSD + daily session setup generates ~1 trade/day nominal, but with range gating expect ~0.5/day => ~400 trades/3yr. Complements GER40 session breakout on a different symbol for portfolio diversity."
}
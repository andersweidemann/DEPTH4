{
  "hypothesis": "Bollinger Band touch-and-bounce reversal occurs on XAUUSD M15",
  "regime_filter": {
    "type": "bb_touch",
    "params": {
      "bb_period": 20,
      "bb_deviation": 2.0
    }
  },
  "entry_rules": {
    "long": {
      "condition": "close > lower_bb(20, 2.0) and rsi(7) < 30"
    },
    "short": {
      "condition": "close < upper_bb(20, 2.0) and rsi(7) > 70"
    }
  },
  "exit_rules": {
    "sl": {
      "type": "fixed",
      "params": {
        "pips": 50
      }
    },
    "tp": {
      "type": "fixed",
      "params": {
        "pips": 100
      }
    },
    "time_stop": {
      "type": "hours",
      "params": {
        "num_hours": 2
      }
    }
  },
  "sizing_rules": {
    "type": "proportional",
    "params": {
      "proportion": 0.02
    }
  }
}
{
  "hypothesis": "Bollinger Band touch-and-bounce reversal is profitable",
  "regime_filter": {
    "type": "bb_width",
    "params": {
      "min_width": 0.5,
      "max_width": 2.0
    }
  },
  "entry_rule": {
    "type": "bb_touch",
    "params": {
      "bb_period": 20,
      "bb_deviation": 2.0
    }
  },
  "exit_rule": {
    "type": "opposite_bb",
    "params": {}
  },
  "sl_rule": {
    "type": "atr",
    "params": {
      "atr_period": 14,
      "atr_multiplier": 1.2
    }
  },
  "tp_rule": {
    "type": "fixed_rr",
    "params": {
      "rr": 2.0
    }
  },
  "time_stop": 30,
  "sizing_rule": {
    "type": "fixed_fraction",
    "params": {
      "fraction": 0.015
    }
  }
}
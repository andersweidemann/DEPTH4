{
  "hypothesis": "London breakout strategy is profitable on GER40 M15 when Asia range is within 1-2 ATRs and breakout occurs within the first 9 bars of the London session",
  "regime_filter": {
    "type": "asia_range_atr",
    "params": {
      "atr_period": 14,
      "min_atr": 1,
      "max_atr": 2
    }
  },
  "entry_rules": {
    "long": {
      "condition": "breakout > upper_range && displacement > 1.2 * atr(14)"
    },
    "short": {
      "condition": "breakout < lower_range && displacement > 1.2 * atr(14)"
    }
  },
  "exit_rules": {
    "tp": {
      "type": "fixed",
      "params": {
        "pips": 500
      }
    },
    "sl": {
      "type": "fixed",
      "params": {
        "pips": 100
      }
    },
    "time_stop": {
      "type": "bars",
      "params": {
        "bars": 20
      }
    }
  },
  "sizing_rules": {
    "type": "fixed",
    "params": {
      "size": 0.1
    }
  }
}
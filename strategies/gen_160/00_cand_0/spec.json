{
  "hypothesis": "Mean reversion occurs on XAUUSD M5 when price touches the upper or lower Bollinger Band with RSI(7) in overbought/oversold territory",
  "regime_filter": {
    "type": "bb_width_percentile",
    "params": {
      "bb_period": 20,
      "bb_dev": 1.75,
      "percentile": 30
    }
  },
  "entry_rules": {
    "long": {
      "condition": "close < lower_bb && rsi(7) < 10"
    },
    "short": {
      "condition": "close > upper_bb && rsi(7) > 90"
    }
  },
  "exit_rules": {
    "tp": {
      "type": "opposite_bb",
      "params": {}
    },
    "sl": {
      "type": "atr",
      "params": {
        "atr_period": 14,
        "atr_mult": 1.5
      }
    },
    "time_stop": {
      "type": "bars",
      "params": {
        "bars": 30
      }
    }
  },
  "sizing_rules": {
    "type": "fixed",
    "params": {
      "size": 0.1
    }
  }
}
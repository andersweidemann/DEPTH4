{
  "hypothesis": "Mean reversion occurs on US500 M15 when price closes outside Bollinger Bands with extreme RSI readings",
  "regime_filter": {
    "type": "volatility",
    "params": {
      "min_vol": 10,
      "max_vol": 50
    }
  },
  "entry_rules": {
    "long": {
      "condition": "close < lower_bb && rsi(7) < 20"
    },
    "short": {
      "condition": "close > upper_bb && rsi(7) > 80"
    }
  },
  "exit_rules": {
    "sl": {
      "type": "fixed",
      "params": {
        "pips": 150
      }
    },
    "tp": {
      "type": "fixed",
      "params": {
        "pips": 300
      }
    },
    "time_stop": {
      "type": "bars",
      "params": {
        "bars": 25
      }
    }
  },
  "sizing_rules": {
    "type": "risk",
    "params": {
      "risk": 0.01
    }
  }
}
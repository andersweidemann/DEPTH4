{
  "hypothesis": "The Bollinger Band touch strategy is effective in XAUUSD on M15, capturing mean reversion when price touches the upper or lower band.",
  "regime_filter": {
    "type": "bb_width",
    "params": {
      "period": 20,
      "deviation": 1.75,
      "min_width": 0.5
    }
  },
  "entry_rules": {
    "long": {
      "condition": "close < lower_bb && rsi(7) < 10"
    },
    "short": {
      "condition": "close > upper_bb && rsi(7) > 90"
    }
  },
  "exit_rules": {
    "tp": {
      "type": "opposite_bb",
      "params": {}
    },
    "sl": {
      "type": "atr",
      "params": {
        "period": 14,
        "multiplier": 1.5
      }
    },
    "time_stop": {
      "type": "bars",
      "params": {
        "num_bars": 30
      }
    }
  },
  "sizing_rules": {
    "type": "fixed",
    "params": {
      "size": 0.1
    }
  }
}
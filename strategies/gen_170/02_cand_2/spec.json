{
  "hypothesis": "Bollinger Band touch-and-bounce reversal is effective on XAUUSD M15",
  "regime_filter": {
    "type": "bb_width",
    "params": {
      "bb_period": 20,
      "bb_dev": 2.0,
      "min_width": 10
    }
  },
  "entry_rule": {
    "type": "bb_touch",
    "params": {
      "rsi_period": 7,
      "rsi_thresholds": [
        20,
        80
      ]
    }
  },
  "exit_rule": {
    "type": "trailing_stop",
    "params": {
      "trail_pips": 100,
      "step_pips": 50
    }
  },
  "sizing_rule": {
    "type": "proportional",
    "params": {
      "proportion": 0.02
    }
  }
}
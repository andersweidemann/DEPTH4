{
  "hypothesis": "Breakouts occur during London session after Asia range expansion",
  "regime_filter": {
    "type": "session",
    "params": {
      "start_hour": 7,
      "end_hour": 10
    }
  },
  "entry_rule": {
    "type": "breakout",
    "params": {
      "asia_range_atr_min": 0.5,
      "asia_range_atr_max": 2.0,
      "london_breakout_displacement": 1.2
    }
  },
  "exit_rule": {
    "type": "tp_sl",
    "params": {
      "tp_pips": 500,
      "sl_pips": 100
    }
  },
  "sizing_rule": {
    "type": "fixed",
    "params": {
      "size": 0.1
    }
  }
}
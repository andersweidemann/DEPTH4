{
  "hypothesis": "Breakouts occur when price closes outside the Asia range with high volatility",
  "regime_filter": {
    "type": "atr_percentile",
    "params": {
      "period": 14,
      "percentile": 70
    }
  },
  "entry_rules": {
    "long": {
      "condition": "close > asia_range_high && atr(14) > atr_percentile",
      "params": {
        "asia_range_period": 6,
        "atr_period": 14
      }
    },
    "short": {
      "condition": "close < asia_range_low && atr(14) > atr_percentile",
      "params": {
        "asia_range_period": 6,
        "atr_period": 14
      }
    }
  },
  "exit_rules": {
    "sl": {
      "type": "fixed",
      "params": {
        "distance": 150
      }
    },
    "tp": {
      "type": "fixed",
      "params": {
        "distance": 300
      }
    },
    "time_stop": {
      "type": "fixed",
      "params": {
        "bars": 20
      }
    }
  },
  "sizing_rules": {
    "type": "fixed",
    "params": {
      "size": 0.2
    }
  }
}
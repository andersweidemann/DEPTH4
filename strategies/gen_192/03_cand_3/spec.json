{
  "hypothesis": "Breakouts occur when price closes outside the Donchian channel with high momentum",
  "regime_filter": {
    "type": "adx_percentile",
    "params": {
      "period": 14,
      "percentile": 70
    }
  },
  "entry_rules": {
    "long": {
      "condition": "close > donchian_channel_high && adx(14) > adx_percentile",
      "params": {
        "donchian_channel_period": 20,
        "adx_period": 14
      }
    },
    "short": {
      "condition": "close < donchian_channel_low && adx(14) > adx_percentile",
      "params": {
        "donchian_channel_period": 20,
        "adx_period": 14
      }
    }
  },
  "exit_rules": {
    "sl": {
      "type": "fixed",
      "params": {
        "distance": 150
      }
    },
    "tp": {
      "type": "fixed",
      "params": {
        "distance": 300
      }
    },
    "time_stop": {
      "type": "fixed",
      "params": {
        "bars": 20
      }
    }
  },
  "sizing_rules": {
    "type": "fixed",
    "params": {
      "size": 0.2
    }
  }
}
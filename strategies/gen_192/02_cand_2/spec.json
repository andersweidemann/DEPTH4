{
  "hypothesis": "Mean reversion occurs when price reaches extreme deviations from its mean with low volatility",
  "regime_filter": {
    "type": "bb_width_percentile",
    "params": {
      "period": 20,
      "percentile": 30
    }
  },
  "entry_rules": {
    "long": {
      "condition": "close < lower_bb && rsi(7) < 10 && bb_width < bb_width_percentile",
      "params": {
        "bb_period": 20,
        "bb_deviation": 1.75,
        "rsi_period": 7
      }
    },
    "short": {
      "condition": "close > upper_bb && rsi(7) > 90 && bb_width < bb_width_percentile",
      "params": {
        "bb_period": 20,
        "bb_deviation": 1.75,
        "rsi_period": 7
      }
    }
  },
  "exit_rules": {
    "sl": {
      "type": "fixed",
      "params": {
        "distance": 100
      }
    },
    "tp": {
      "type": "opposite_bb",
      "params": {
        "bb_period": 20,
        "bb_deviation": 1.75
      }
    },
    "time_stop": {
      "type": "fixed",
      "params": {
        "bars": 30
      }
    }
  },
  "sizing_rules": {
    "type": "fixed",
    "params": {
      "size": 0.1
    }
  }
}
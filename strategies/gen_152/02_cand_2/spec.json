{
  "hypothesis": "Price touching the Bollinger Band with a high RSI reading results in a mean reversion",
  "regime_filter": {
    "type": "bb_width",
    "params": {
      "min_width": 10
    }
  },
  "entry_rules": {
    "long": {
      "condition": "close < lower_bb && rsi(14) > 70"
    },
    "short": {
      "condition": "close > upper_bb && rsi(14) < 30"
    }
  },
  "exit_rules": {
    "sl": {
      "type": "atr",
      "params": {
        "multiplier": 2
      }
    },
    "tp": {
      "type": "middle_bb"
    },
    "time_stop": {
      "type": "bars",
      "params": {
        "num_bars": 40
      }
    }
  },
  "sizing_rules": {
    "type": "fixed",
    "params": {
      "size": 0.1
    }
  }
}
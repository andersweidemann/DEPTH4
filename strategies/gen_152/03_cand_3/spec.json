{
  "hypothesis": "The Donchian channel breakout is a profitable strategy during high volatility",
  "regime_filter": {
    "type": "atr_percentile",
    "params": {
      "percentile": 70
    }
  },
  "entry_rules": {
    "long": {
      "condition": "close > donchian_channel_high"
    },
    "short": {
      "condition": "close < donchian_channel_low"
    }
  },
  "exit_rules": {
    "sl": {
      "type": "fixed",
      "params": {
        "pips": 150
      }
    },
    "tp": {
      "type": "fixed",
      "params": {
        "pips": 300
      }
    },
    "time_stop": {
      "type": "bars",
      "params": {
        "num_bars": 30
      }
    }
  },
  "sizing_rules": {
    "type": "fixed",
    "params": {
      "size": 0.1
    }
  }
}
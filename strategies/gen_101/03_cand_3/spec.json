{
  "hypothesis": "Bollinger Band mean reversion strategy is profitable on BTCUSD M15 during low-volatility regimes",
  "regime_filter": {
    "type": "bb_width_percentile",
    "params": {
      "bb_period": 20,
      "bb_deviation": 1.75,
      "percentile": 70
    }
  },
  "entry_rule": {
    "type": "bb_rsi_mean_reversion",
    "params": {
      "rsi_period": 7,
      "rsi_thresholds": [
        20,
        80
      ]
    }
  },
  "exit_rule": {
    "type": "opposite_bb_tp",
    "params": {
      "sl_multiplier": 1.2,
      "time_stop_bars": 20
    }
  },
  "sizing_rule": {
    "type": "fixed_size",
    "params": {
      "size": 0.05
    }
  }
}
{
  "hypothesis": "Asia-London range expansion occurs on GER40 M15",
  "regime_filter": {
    "type": "session",
    "params": {
      "start_hour": 7,
      "end_hour": 10
    }
  },
  "entry_rules": {
    "long": {
      "condition": "breakout > 1.2 * atr && retest < 0.2 * atr"
    },
    "short": {
      "condition": "breakout < -1.2 * atr && retest > -0.2 * atr"
    }
  },
  "exit_rules": {
    "stop_loss": {
      "type": "fixed",
      "params": {
        "pips": 100
      }
    },
    "take_profit": {
      "type": "fixed",
      "params": {
        "pips": 500
      }
    },
    "time_stop": {
      "type": "hours",
      "params": {
        "num_hours": 2
      }
    }
  },
  "sizing_rules": {
    "type": "risk_percent",
    "params": {
      "risk_percent": 2
    }
  }
}
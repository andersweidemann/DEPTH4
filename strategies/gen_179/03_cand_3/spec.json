{
  "hypothesis": "Mean reversion occurs on US500 M15 when price closes outside Bollinger Bands with extreme RSI readings",
  "regime_filter": {
    "type": "adx",
    "params": {
      "period": 14,
      "threshold": 20
    }
  },
  "entry_rules": {
    "long": {
      "condition": "close < lower_bb && rsi < 10"
    },
    "short": {
      "condition": "close > upper_bb && rsi > 90"
    }
  },
  "exit_rules": {
    "stop_loss": {
      "type": "atr",
      "params": {
        "period": 14,
        "multiplier": 1.5
      }
    },
    "take_profit": {
      "type": "opposite_bb"
    },
    "time_stop": {
      "type": "bars",
      "params": {
        "num_bars": 30
      }
    }
  },
  "sizing_rules": {
    "type": "fixed",
    "params": {
      "size": 0.1
    }
  }
}
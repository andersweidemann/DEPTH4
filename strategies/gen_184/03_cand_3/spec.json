{
  "hypothesis": "Mean reversion occurs on BTCUSD M5 when price reaches extreme deviations from its mean with extreme RSI readings",
  "regime_filter": {
    "type": "bb_width_percentile",
    "params": {
      "bb_period": 20,
      "bb_deviation": 1.75,
      "percentile": 40
    }
  },
  "entry_rule": {
    "type": "mean_reversion",
    "params": {
      "rsi_period": 7,
      "rsi_thresholds": [
        15,
        85
      ]
    }
  },
  "exit_rule": {
    "type": "take_profit_stop_loss",
    "params": {
      "tp": "middle_bb",
      "sl": "1.2_atr",
      "time_stop": 25
    }
  },
  "sizing_rule": {
    "type": "fixed_fraction",
    "params": {
      "fraction": 0.005
    }
  }
}
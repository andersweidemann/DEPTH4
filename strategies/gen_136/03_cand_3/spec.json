{
  "hypothesis": "ATR-based volatility filters can improve mean reversion strategy performance",
  "regime_filter": {
    "type": "atr_percentile",
    "params": {
      "percentile": 50,
      "lookback": 14
    }
  },
  "entry_rule": {
    "type": "mean_reversion",
    "params": {
      "bb_period": 20,
      "bb_deviation": 1.75,
      "rsi_period": 7,
      "rsi_thresholds": [
        10,
        90
      ]
    }
  },
  "exit_rule": {
    "type": "tp_sl_time",
    "params": {
      "tp": "middle_bb",
      "sl": "1.5_atr",
      "time_stop": 25
    }
  },
  "sizing_rule": {
    "type": "fixed_fraction",
    "params": {
      "fraction": 0.012
    }
  }
}
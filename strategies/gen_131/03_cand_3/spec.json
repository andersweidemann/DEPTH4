{
  "hypothesis": "ATR-based volatility filters can improve the performance of a mean reversion strategy",
  "regime_filter": {
    "type": "atr_percentile",
    "params": {
      "percentile": 70,
      "lookback": 14
    }
  },
  "entry_rule": {
    "type": "rsi_mean_reversion",
    "params": {
      "rsi_period": 7,
      "rsi_thresholds": [
        20,
        80
      ]
    }
  },
  "exit_rule": {
    "type": "tp_sl",
    "params": {
      "tp_pips": 200,
      "sl_pips": 50
    }
  },
  "sizing_rule": {
    "type": "fixed_lot",
    "params": {
      "lot_size": 0.05
    }
  }
}
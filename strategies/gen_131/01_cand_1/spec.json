{
  "hypothesis": "Breakouts from the Asia range during the London session can be profitable",
  "regime_filter": {
    "type": "session_mask",
    "params": {
      "session": "london"
    }
  },
  "entry_rule": {
    "type": "asia_london_range_breakout",
    "params": {
      "asia_range_atr_min": 0.5,
      "asia_range_atr_max": 2.0,
      "breakout_atr_multiplier": 1.2
    }
  },
  "exit_rule": {
    "type": "tp_sl",
    "params": {
      "tp_pips": 500,
      "sl_pips": 100
    }
  },
  "sizing_rule": {
    "type": "fixed_lot",
    "params": {
      "lot_size": 0.1
    }
  }
}
{
  "hypothesis": "RSI extremes indicate mean reversion opportunities",
  "regime_filter": {
    "type": "rsi_extremes",
    "params": {
      "rsi_period": 7,
      "rsi_threshold": 10
    }
  },
  "entry_rule": {
    "type": "mean_reversion",
    "params": {
      "bb_period": 20,
      "bb_deviation": 1.75
    }
  },
  "exit_rule": {
    "type": "take_profit",
    "params": {
      "target": "opposite_bollinger_band"
    }
  },
  "stop_loss": {
    "type": "fixed",
    "params": {
      "distance": "1.5 * atr(14)"
    }
  },
  "time_stop": {
    "type": "fixed",
    "params": {
      "bars": 30
    }
  },
  "sizing": {
    "type": "fixed",
    "params": {
      "size": 0.01
    }
  }
}
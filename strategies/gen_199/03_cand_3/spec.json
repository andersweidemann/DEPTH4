{
  "hypothesis": "Donchian channels can be used to identify breakouts",
  "regime_filter": {
    "type": "donchian",
    "params": {
      "period": 20
    }
  },
  "entry_rules": {
    "long": {
      "condition": "high > donchian_high(20) and close > upper_bb(20, 1.75)"
    },
    "short": {
      "condition": "low < donchian_low(20) and close < lower_bb(20, 1.75)"
    }
  },
  "exit_rules": {
    "sl": {
      "type": "fixed",
      "params": {
        "pips": 100
      }
    },
    "tp": {
      "type": "fixed",
      "params": {
        "pips": 500
      }
    },
    "time_stop": {
      "type": "bars",
      "params": {
        "num_bars": 30
      }
    }
  },
  "sizing_rules": {
    "type": "fixed",
    "params": {
      "size": 0.01
    }
  }
}
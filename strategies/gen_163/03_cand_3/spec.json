{
  "hypothesis": "Retest of the broken range on US500 M15 leads to a continuation in the same direction",
  "regime_filter": {
    "type": "session",
    "params": {
      "start_hour": 9,
      "end_hour": 12
    }
  },
  "entry_rules": {
    "long": {
      "condition": "retest > 0 && close > high_broken_range"
    },
    "short": {
      "condition": "retest < 0 && close < low_broken_range"
    }
  },
  "exit_rules": {
    "stop_loss": {
      "type": "fixed",
      "params": {
        "distance": 150
      }
    },
    "take_profit": {
      "type": "fixed",
      "params": {
        "distance": 600
      }
    },
    "time_stop": {
      "type": "bars",
      "params": {
        "num_bars": 30
      }
    }
  },
  "sizing_rules": {
    "type": "fixed",
    "params": {
      "size": 0.15
    }
  }
}
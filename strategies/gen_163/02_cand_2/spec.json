{
  "hypothesis": "Mean reversion occurs on BTCUSD M5 when price closes outside the Bollinger Bands with an extreme RSI(7) reading",
  "regime_filter": {
    "type": "bb_width_percentile",
    "params": {
      "percentile": 40,
      "lookback": 100
    }
  },
  "entry_rules": {
    "long": {
      "condition": "close < lower_bb && rsi(7) < 15"
    },
    "short": {
      "condition": "close > upper_bb && rsi(7) > 85"
    }
  },
  "exit_rules": {
    "stop_loss": {
      "type": "atr",
      "params": {
        "multiplier": 2
      }
    },
    "take_profit": {
      "type": "middle_bb"
    },
    "time_stop": {
      "type": "bars",
      "params": {
        "num_bars": 25
      }
    }
  },
  "sizing_rules": {
    "type": "fixed",
    "params": {
      "size": 0.05
    }
  }
}
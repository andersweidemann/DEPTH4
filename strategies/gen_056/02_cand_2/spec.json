{
  "hypothesis": "The RSI(7) indicator can be used to identify overbought and oversold conditions, and a mean reversion strategy can be applied.",
  "regime_filter": {
    "type": "rsi",
    "params": {
      "period": 7,
      "threshold": 70
    }
  },
  "entry_rules": {
    "long": {
      "condition": "rsi(7) < 30"
    },
    "short": {
      "condition": "rsi(7) > 70"
    }
  },
  "exit_rules": {
    "tp": {
      "type": "opposite_rsi",
      "params": {
        "period": 7,
        "threshold": 30
      }
    },
    "sl": {
      "type": "atr",
      "params": {
        "period": 14,
        "multiplier": 1.5
      }
    },
    "time_stop": {
      "type": "bars",
      "params": {
        "num_bars": 30
      }
    }
  },
  "sizing_rules": {
    "type": "fixed",
    "params": {
      "size": 0.01
    }
  }
}
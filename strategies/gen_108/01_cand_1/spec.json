{
  "hypothesis": "Breakouts occur during London session with sufficient volatility",
  "regime_filter": {
    "type": "session",
    "params": {
      "start_hour": 7,
      "end_hour": 10
    }
  },
  "entry_rules": {
    "long": {
      "condition": "breakout > 0 && atr(14) > 10"
    },
    "short": {
      "condition": "breakout < 0 && atr(14) > 10"
    }
  },
  "exit_rules": {
    "sl": {
      "type": "fixed",
      "params": {
        "pips": 100
      }
    },
    "tp": {
      "type": "fixed",
      "params": {
        "pips": 500
      }
    },
    "time_stop": {
      "type": "hours",
      "params": {
        "num_hours": 2
      }
    }
  },
  "sizing_rules": {
    "type": "fixed",
    "params": {
      "amount": 0.1
    }
  }
}
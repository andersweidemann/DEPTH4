{
  "hypothesis": "Asia-London range expansion leads to profitable trades",
  "regime_filter": {
    "type": "asia_london_range",
    "params": {
      "min_range_atr": 0.5,
      "max_range_atr": 2.0
    }
  },
  "entry_rules": {
    "long": {
      "condition": "breakout > 0 && asia_range > min_range_atr * atr(14)"
    },
    "short": {
      "condition": "breakout < 0 && asia_range > min_range_atr * atr(14)"
    }
  },
  "exit_rules": {
    "sl": {
      "type": "atr",
      "params": {
        "multiplier": 1.2
      }
    },
    "tp": {
      "type": "opposite_bb"
    },
    "time_stop": {
      "type": "bars",
      "params": {
        "num_bars": 20
      }
    }
  },
  "sizing_rules": {
    "type": "fixed_fraction",
    "params": {
      "fraction": 0.02
    }
  }
}
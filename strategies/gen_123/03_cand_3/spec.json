{
  "hypothesis": "Donchian channel breakouts with ATR-based stops are profitable",
  "regime_filter": {
    "type": "atr_percentile",
    "params": {
      "percentile": 50,
      "lookback": 50
    }
  },
  "entry_rules": {
    "long": {
      "condition": "close > donchian_high"
    },
    "short": {
      "condition": "close < donchian_low"
    }
  },
  "exit_rules": {
    "sl": {
      "type": "atr",
      "params": {
        "multiplier": 1
      }
    },
    "tp": {
      "type": "fixed",
      "params": {
        "pips": 200
      }
    },
    "time_stop": {
      "type": "hours",
      "params": {
        "hours": 1
      }
    }
  },
  "sizing_rules": {
    "type": "risk",
    "params": {
      "risk": 0.01
    }
  }
}
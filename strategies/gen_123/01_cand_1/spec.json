{
  "hypothesis": "Breakouts from the Asia range during the London session are profitable",
  "regime_filter": {
    "type": "session",
    "params": {
      "start_hour": 7,
      "end_hour": 10
    }
  },
  "entry_rules": {
    "long": {
      "condition": "breakout > 0 && asia_range_high - asia_range_low > atr(14) * 0.5"
    },
    "short": {
      "condition": "breakout < 0 && asia_range_high - asia_range_low > atr(14) * 0.5"
    }
  },
  "exit_rules": {
    "sl": {
      "type": "fixed",
      "params": {
        "pips": 100
      }
    },
    "tp": {
      "type": "fixed",
      "params": {
        "pips": 500
      }
    },
    "time_stop": {
      "type": "hours",
      "params": {
        "hours": 2
      }
    }
  },
  "sizing_rules": {
    "type": "risk",
    "params": {
      "risk": 0.02
    }
  }
}
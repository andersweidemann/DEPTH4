{
  "hypothesis": "RSI extremes with Bollinger Band touches are mean reversion opportunities",
  "regime_filter": {
    "type": "bb_width",
    "params": {
      "min_width": 0.01,
      "max_width": 0.05
    }
  },
  "entry_rules": {
    "long": {
      "condition": "rsi(7) < 10 && close < lower_bb"
    },
    "short": {
      "condition": "rsi(7) > 90 && close > upper_bb"
    }
  },
  "exit_rules": {
    "sl": {
      "type": "atr",
      "params": {
        "multiplier": 2
      }
    },
    "tp": {
      "type": "middle_bb"
    },
    "time_stop": {
      "type": "bars",
      "params": {
        "bars": 20
      }
    }
  },
  "sizing_rules": {
    "type": "fixed",
    "params": {
      "size": 0.2
    }
  }
}
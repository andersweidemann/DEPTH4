{
  "hypothesis": "Bollinger Band touch-and-bounce reversal can be profitable",
  "regime_filter": {
    "type": "bb_width_percentile",
    "params": {
      "percentile": 50,
      "lookback": 20
    }
  },
  "symbol": "BTCUSD",
  "timeframe": "M5",
  "entry_rule": {
    "type": "bb_touch_bounce",
    "params": {
      "bb_period": 20,
      "bb_deviation": 2.0
    }
  },
  "exit_rule": {
    "type": "tp_sl_time",
    "params": {
      "tp": "200_pips",
      "sl": "50_pips",
      "time_stop": 30
    }
  },
  "sizing_rule": {
    "type": "fixed_fraction",
    "params": {
      "fraction": 0.01
    }
  }
}
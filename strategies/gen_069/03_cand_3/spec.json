{
  "hypothesis": "Momentum continuation occurs when price breaks out of the Donchian channel",
  "regime_filter": {
    "type": "adx",
    "params": {
      "threshold": 25
    }
  },
  "entry_rules": {
    "long": {
      "condition": "close > donchian_channel_high"
    },
    "short": {
      "condition": "close < donchian_channel_low"
    }
  },
  "exit_rules": {
    "tp": {
      "type": "fixed",
      "params": {
        "pips": 30
      }
    },
    "sl": {
      "type": "fixed",
      "params": {
        "pips": 15
      }
    },
    "time_stop": {
      "type": "hours",
      "params": {
        "num_hours": 1
      }
    }
  },
  "sizing_rules": {
    "type": "proportional",
    "params": {
      "proportion": 0.01
    }
  }
}
{
  "hypothesis": "Bollinger Band touch-and-bounce reversal occurs on XAUUSD M5",
  "regime_filter": {
    "type": "bb_width",
    "params": {
      "min_width": 10,
      "max_width": 50
    }
  },
  "entry_rules": {
    "long": {
      "condition": "close > lower_bb && close < upper_bb"
    },
    "short": {
      "condition": "close < upper_bb && close > lower_bb"
    }
  },
  "exit_rules": {
    "tp": {
      "type": "opposite_bb",
      "params": {}
    },
    "sl": {
      "type": "atr",
      "params": {
        "multiplier": 1.5
      }
    },
    "time_stop": {
      "type": "bars",
      "params": {
        "num_bars": 30
      }
    }
  },
  "sizing_rules": {
    "type": "fixed",
    "params": {
      "size": 0.1
    }
  }
}
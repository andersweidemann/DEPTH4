{
  "hypothesis": "Mean reversion occurs when price touches the upper or lower Bollinger Band with extreme RSI readings",
  "regime_filter": {
    "type": "bb_width_percentile",
    "params": {
      "percentile": 30,
      "lookback": 100
    }
  },
  "entry_rules": {
    "long": {
      "condition": "close < lower_bb(20, 1.75) and rsi(7) < 10"
    },
    "short": {
      "condition": "close > upper_bb(20, 1.75) and rsi(7) > 90"
    }
  },
  "exit_rules": {
    "sl": {
      "type": "atr",
      "params": {
        "multiplier": 1.5
      }
    },
    "tp": {
      "type": "opposite_bb"
    },
    "time_stop": {
      "type": "bars",
      "params": {
        "num_bars": 30
      }
    }
  },
  "sizing_rules": {
    "type": "fixed",
    "params": {
      "size": 0.01
    }
  }
}
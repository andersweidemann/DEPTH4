{
  "hypothesis": "The Asia-London range expansion strategy can be applied to XAUUSD and GER40",
  "regime_filter": {
    "type": "session",
    "params": {
      "session": "asia_london"
    }
  },
  "entry_rules": {
    "long": {
      "condition": "close > asia_range_high and close < london_range_high"
    },
    "short": {
      "condition": "close < asia_range_low and close > london_range_low"
    }
  },
  "exit_rules": {
    "sl": {
      "type": "atr",
      "params": {
        "multiplier": 1
      }
    },
    "tp": {
      "type": "fixed",
      "params": {
        "pips": 100
      }
    },
    "time_stop": {
      "type": "bars",
      "params": {
        "num_bars": 15
      }
    }
  },
  "sizing_rules": {
    "type": "fixed",
    "params": {
      "size": 0.01
    }
  }
}
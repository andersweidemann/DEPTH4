{
  "hypothesis": "Breakouts occur after a period of consolidation, and can be traded using a Donchian channel",
  "regime_filter": {
    "type": "donchian_channel",
    "params": {
      "length": 20
    }
  },
  "entry_rules": {
    "long": {
      "condition": "close > donchian_channel_high(20)"
    },
    "short": {
      "condition": "close < donchian_channel_low(20)"
    }
  },
  "exit_rules": {
    "sl": {
      "type": "atr",
      "params": {
        "multiplier": 2
      }
    },
    "tp": {
      "type": "fixed",
      "params": {
        "pips": 50
      }
    },
    "time_stop": {
      "type": "bars",
      "params": {
        "num_bars": 20
      }
    }
  },
  "sizing_rules": {
    "type": "proportional",
    "params": {
      "proportion": 0.02
    }
  }
}
{
  "hypothesis": "The RSI can be used to identify overbought and oversold conditions, and trade reversals",
  "regime_filter": {
    "type": "rsi",
    "params": {
      "length": 14,
      "thresholds": [
        30,
        70
      ]
    }
  },
  "entry_rules": {
    "long": {
      "condition": "rsi(14) < 30"
    },
    "short": {
      "condition": "rsi(14) > 70"
    }
  },
  "exit_rules": {
    "sl": {
      "type": "atr",
      "params": {
        "multiplier": 1.5
      }
    },
    "tp": {
      "type": "opposite_rsi",
      "params": {
        "thresholds": [
          30,
          70
        ]
      }
    },
    "time_stop": {
      "type": "bars",
      "params": {
        "num_bars": 20
      }
    }
  },
  "sizing_rules": {
    "type": "proportional",
    "params": {
      "proportion": 0.01
    }
  }
}
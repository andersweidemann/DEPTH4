{
  "hypothesis": "Breakouts from the Asia range during the London session are profitable",
  "regime_filter": {
    "type": "session",
    "params": {
      "start_hour": 7,
      "end_hour": 10
    }
  },
  "entry_rules": {
    "long": {
      "condition": "breakout > upper_range"
    },
    "short": {
      "condition": "breakout < lower_range"
    }
  },
  "exit_rules": {
    "sl": {
      "type": "pips",
      "params": {
        "num_pips": 100
      }
    },
    "tp": {
      "type": "pips",
      "params": {
        "num_pips": 500
      }
    },
    "time_stop": {
      "type": "bars",
      "params": {
        "num_bars": 20
      }
    }
  },
  "sizing_rules": {
    "type": "risk",
    "params": {
      "risk_percent": 2
    }
  }
}
{
  "hypothesis": "The Asia-London range expansion strategy is profitable on XAUUSD",
  "regime_filter": {
    "type": "atr_percentile",
    "params": {
      "percentile": 40
    }
  },
  "entry_rules": {
    "long": {
      "condition": "breakout > upper_range && rsi < 50"
    },
    "short": {
      "condition": "breakout < lower_range && rsi > 50"
    }
  },
  "exit_rules": {
    "sl": {
      "type": "pips",
      "params": {
        "num_pips": 150
      }
    },
    "tp": {
      "type": "pips",
      "params": {
        "num_pips": 600
      }
    },
    "time_stop": {
      "type": "bars",
      "params": {
        "num_bars": 30
      }
    }
  },
  "sizing_rules": {
    "type": "risk",
    "params": {
      "risk_percent": 1.5
    }
  }
}
{
  "hypothesis": "Price will reverse after touching the Bollinger Band with a high RSI reading",
  "regime_filter": {
    "type": "bb_width_percentile",
    "params": {
      "percentile": 50
    }
  },
  "entry_rules": {
    "long": {
      "condition": "close > upper_bb && rsi > 70"
    },
    "short": {
      "condition": "close < lower_bb && rsi < 30"
    }
  },
  "exit_rules": {
    "sl": {
      "type": "atr",
      "params": {
        "multiplier": 2
      }
    },
    "tp": {
      "type": "middle_bb"
    },
    "time_stop": {
      "type": "bars",
      "params": {
        "num_bars": 40
      }
    }
  },
  "sizing_rules": {
    "type": "fixed",
    "params": {
      "size": 0.02
    }
  }
}
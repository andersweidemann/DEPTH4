{
  "hypothesis": "Bollinger Band touch-and-bounce reversal strategy is profitable on XAUUSD M5",
  "regime_filter": {
    "type": "session",
    "params": {
      "start": "07:00",
      "end": "20:00"
    }
  },
  "entry_rule": {
    "type": "bb_touch_bounce",
    "params": {
      "bb_period": 20,
      "bb_deviation": 2.0
    }
  },
  "exit_rule": {
    "type": "tp_sl_time",
    "params": {
      "tp": "500_pips",
      "sl": "100_pips",
      "time_stop": 30
    }
  },
  "sizing_rule": {
    "type": "fixed_fraction",
    "params": {
      "fraction": 0.02
    }
  }
}
{
  "hypothesis": "Mean reversion strategy using RSI and Bollinger Bands is profitable on US500 M15",
  "regime_filter": {
    "type": "bb_width_percentile",
    "params": {
      "bb_period": 20,
      "bb_deviation": 1.75,
      "percentile": 30
    }
  },
  "entry_rule": {
    "type": "mean_reversion_rsi",
    "params": {
      "rsi_period": 7,
      "rsi_thresholds": [
        10,
        90
      ],
      "bb_period": 20,
      "bb_deviation": 1.75
    }
  },
  "exit_rule": {
    "type": "tp_sl_time",
    "params": {
      "tp": "opposite_bb",
      "sl": "1.5_atr",
      "time_stop": 60
    }
  },
  "sizing_rule": {
    "type": "fixed_fraction",
    "params": {
      "fraction": 0.01
    }
  }
}
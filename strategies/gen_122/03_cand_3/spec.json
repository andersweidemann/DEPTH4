{
  "hypothesis": "Mean reversion occurs when RSI reaches extreme levels on GER40 M5",
  "regime_filter": {
    "type": "atr_percentile",
    "params": {
      "percentile": 50,
      "lookback": 14
    }
  },
  "entry_rule": {
    "type": "rsi_extremes",
    "params": {
      "rsi_period": 7,
      "rsi_thresholds": [
        10,
        90
      ]
    }
  },
  "exit_rule": {
    "type": "tp_sl_time",
    "params": {
      "tp": "opposite_rsi",
      "sl": "1.5_atr",
      "time_stop": 20
    }
  },
  "sizing_rule": {
    "type": "fixed",
    "params": {
      "size": 0.05
    }
  }
}
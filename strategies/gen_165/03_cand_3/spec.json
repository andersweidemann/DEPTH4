{
  "hypothesis": "Mean reversion occurs on US500 M15 when price reaches the upper or lower Bollinger Band with RSI(14) in oversold or overbought territory",
  "regime_filter": {
    "type": "adx",
    "params": {
      "threshold": 20
    }
  },
  "entry_rules": {
    "long": {
      "condition": "close < lower_bb && rsi(14) < 30"
    },
    "short": {
      "condition": "close > upper_bb && rsi(14) > 70"
    }
  },
  "exit_rules": {
    "tp": {
      "type": "opposite_bb",
      "params": {}
    },
    "sl": {
      "type": "atr",
      "params": {
        "multiplier": 1.5
      }
    },
    "time_stop": {
      "type": "bars",
      "params": {
        "num_bars": 30
      }
    }
  },
  "sizing_rules": {
    "type": "fixed",
    "params": {
      "size": 0.1
    }
  }
}
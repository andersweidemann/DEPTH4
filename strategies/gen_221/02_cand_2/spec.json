{
  "hypothesis": "Price reverts to the mean after extreme movements",
  "regime_filter": {
    "type": "volatility",
    "params": {
      "threshold": 20
    }
  },
  "entry_rules": {
    "long": {
      "condition": "rsi < 30"
    },
    "short": {
      "condition": "rsi > 70"
    }
  },
  "exit_rules": {
    "sl": {
      "type": "fixed",
      "params": {
        "distance": 100
      }
    },
    "tp": {
      "type": "opposite_bb"
    },
    "time_stop": {
      "type": "fixed",
      "params": {
        "bars": 30
      }
    }
  },
  "sizing_rules": {
    "type": "fixed",
    "params": {
      "size": 0.1
    }
  }
}
{
  "hypothesis": "Breakouts occur when price displaces the Asia range by a significant amount",
  "regime_filter": {
    "type": "session",
    "params": {
      "start": "07:00",
      "end": "10:00"
    }
  },
  "entry_rules": {
    "long": {
      "condition": "displacement > 1.2 * atr"
    },
    "short": {
      "condition": "displacement < -1.2 * atr"
    }
  },
  "exit_rules": {
    "sl": {
      "type": "fixed",
      "params": {
        "distance": 100
      }
    },
    "tp": {
      "type": "fixed",
      "params": {
        "distance": 500
      }
    },
    "time_stop": {
      "type": "fixed",
      "params": {
        "bars": 30
      }
    }
  },
  "sizing_rules": {
    "type": "fixed",
    "params": {
      "size": 0.1
    }
  }
}
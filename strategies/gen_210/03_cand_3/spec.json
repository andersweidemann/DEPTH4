{
  "hypothesis": "Breakout of the Donchian channel on BTCUSD on M5 leads to a profitable trade",
  "regime_filter": {
    "type": "donchian_channel",
    "params": {
      "period": 20
    }
  },
  "entry_rules": {
    "long": {
      "condition": "close > upper_donchian_channel"
    },
    "short": {
      "condition": "close < lower_donchian_channel"
    }
  },
  "exit_rules": {
    "sl": {
      "type": "fixed",
      "params": {
        "pips": 100
      }
    },
    "tp": {
      "type": "fixed",
      "params": {
        "pips": 500
      }
    },
    "time_stop": {
      "type": "hours",
      "params": {
        "hours": 2
      }
    }
  },
  "sizing_rules": {
    "type": "fixed",
    "params": {
      "size": 0.1
    }
  }
}
{
  "hypothesis": "Breakout of the Asia range on GER40 on M15 leads to a profitable trade during the London session",
  "regime_filter": {
    "type": "session",
    "params": {
      "session": "london"
    }
  },
  "entry_rules": {
    "long": {
      "condition": "breakout_of_asia_range && close > upper_bb"
    },
    "short": {
      "condition": "breakout_of_asia_range && close < lower_bb"
    }
  },
  "exit_rules": {
    "sl": {
      "type": "fixed",
      "params": {
        "pips": 100
      }
    },
    "tp": {
      "type": "fixed",
      "params": {
        "pips": 500
      }
    },
    "time_stop": {
      "type": "hours",
      "params": {
        "hours": 2
      }
    }
  },
  "sizing_rules": {
    "type": "fixed",
    "params": {
      "size": 0.1
    }
  }
}
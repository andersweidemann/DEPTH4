{
  "hypothesis": "Donchian channel breakout leads to trend continuation",
  "regime_filter": {
    "type": "adx",
    "params": {
      "min_adx": 20
    }
  },
  "entry_rules": {
    "long": {
      "condition": "close > upper_dc && adx(14) > 20"
    },
    "short": {
      "condition": "close < lower_dc && adx(14) > 20"
    }
  },
  "exit_rules": {
    "sl": {
      "type": "fixed",
      "params": {
        "pips": 150
      }
    },
    "tp": {
      "type": "fixed",
      "params": {
        "pips": 300
      }
    },
    "time_stop": {
      "type": "hours",
      "params": {
        "num_hours": 4
      }
    }
  },
  "sizing_rules": {
    "type": "risk_percent",
    "params": {
      "percent": 3
    }
  }
}
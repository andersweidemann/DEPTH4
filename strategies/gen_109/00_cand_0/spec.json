{
  "symbol": "XAUUSD",
  "timeframe": "M5",
  "hypothesis": "Mean reversion occurs when price closes outside Bollinger Bands with extreme RSI readings",
  "regime_filter": {
    "type": "bb_width_percentile",
    "params": {
      "percentile": 30
    }
  },
  "entry_rule": {
    "type": "mean_reversion",
    "params": {
      "bb_period": 20,
      "bb_deviation": 1.75,
      "rsi_period": 7,
      "rsi_thresholds": [
        10,
        90
      ]
    }
  },
  "exit_rule": {
    "type": "tp_sl_time",
    "params": {
      "tp": "opposite_bb",
      "sl": "1.5_atr",
      "time_stop": 30
    }
  },
  "sizing_rule": {
    "type": "fixed_fraction",
    "params": {
      "fraction": 0.01
    }
  }
}
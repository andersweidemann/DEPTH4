{
  "symbol": "BTCUSD",
  "timeframe": "M15",
  "hypothesis": "Mean reversion occurs when price reaches extreme deviations from its mean",
  "regime_filter": {
    "type": "atr_percentile",
    "params": {
      "percentile": 70
    }
  },
  "entry_rule": {
    "type": "mean_reversion",
    "params": {
      "bb_period": 20,
      "bb_deviation": 1.75,
      "rsi_period": 7,
      "rsi_thresholds": [
        10,
        90
      ]
    }
  },
  "exit_rule": {
    "type": "tp_sl_time",
    "params": {
      "tp": "middle_bb",
      "sl": "2_atr",
      "time_stop": 60
    }
  },
  "sizing_rule": {
    "type": "fixed_fraction",
    "params": {
      "fraction": 0.01
    }
  }
}
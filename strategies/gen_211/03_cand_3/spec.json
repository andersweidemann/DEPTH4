{
  "hypothesis": "Mean reversion occurs in US500 on M5 when price closes outside Bollinger Bands with extreme RSI readings",
  "regime_filter": {
    "type": "adx",
    "params": {
      "adx_period": 14,
      "adx_threshold": 20
    }
  },
  "entry_rules": {
    "long": {
      "condition": "close < lower_bb && rsi(7) < 10"
    },
    "short": {
      "condition": "close > upper_bb && rsi(7) > 90"
    }
  },
  "exit_rules": {
    "sl": {
      "type": "fixed",
      "params": {
        "distance": 100
      }
    },
    "tp": {
      "type": "fixed",
      "params": {
        "distance": 500
      }
    },
    "time_stop": {
      "type": "fixed",
      "params": {
        "bars": 30
      }
    }
  },
  "sizing_rules": {
    "type": "fixed",
    "params": {
      "size": 0.01
    }
  }
}
{
  "hypothesis": "Breakout of the Asia range on GER40 M15 leads to a profitable trade",
  "regime_filter": {
    "type": "session",
    "params": {
      "start_hour": 7,
      "start_minute": 0,
      "end_hour": 10,
      "end_minute": 0
    }
  },
  "entry_rules": {
    "long": {
      "condition": "close > asia_range_high"
    },
    "short": {
      "condition": "close < asia_range_low"
    }
  },
  "exit_rules": {
    "tp": {
      "type": "fixed",
      "params": {
        "pips": 50
      }
    },
    "sl": {
      "type": "fixed",
      "params": {
        "pips": 20
      }
    },
    "time_stop": {
      "type": "hours",
      "params": {
        "count": 2
      }
    }
  },
  "sizing_rules": {
    "type": "fixed",
    "params": {
      "size": 0.1
    }
  }
}
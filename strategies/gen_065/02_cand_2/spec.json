{
  "hypothesis": "RSI(7) extremes on US500 M5 indicate a mean reversion opportunity",
  "regime_filter": {
    "type": "rsi_extremes",
    "params": {
      "period": 7,
      "lower_threshold": 10,
      "upper_threshold": 90
    }
  },
  "entry_rules": {
    "long": {
      "condition": "rsi(7) < 10"
    },
    "short": {
      "condition": "rsi(7) > 90"
    }
  },
  "exit_rules": {
    "tp": {
      "type": "opposite_rsi_extreme"
    },
    "sl": {
      "type": "atr",
      "params": {
        "period": 14,
        "multiplier": 1.5
      }
    },
    "time_stop": {
      "type": "bars",
      "params": {
        "count": 30
      }
    }
  },
  "sizing_rules": {
    "type": "fixed",
    "params": {
      "size": 0.1
    }
  }
}
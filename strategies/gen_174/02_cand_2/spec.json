{
  "hypothesis": "Bollinger Band touch-and-bounce reversal occurs on XAUUSD M5 with high probability",
  "regime_filter": {
    "type": "bb_width_percentile",
    "params": {
      "period": 20,
      "percentile": 50
    }
  },
  "entry_rule": {
    "type": "bb_touch",
    "params": {
      "bb_period": 20,
      "bb_deviation": 2.0
    }
  },
  "exit_rule": {
    "type": "opposite_bb",
    "params": {
      "sl_multiplier": 1.2,
      "time_stop_bars": 20
    }
  },
  "sizing_rule": {
    "type": "fixed_fraction",
    "params": {
      "fraction": 0.015
    }
  }
}
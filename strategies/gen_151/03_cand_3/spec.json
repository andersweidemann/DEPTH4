{
  "hypothesis": "Mean reversion scalping using RSI and Bollinger Bands on GER40 M5",
  "regime_filter": {
    "type": "rsi_extremes",
    "params": {
      "threshold": 10
    }
  },
  "entry_rules": {
    "long": {
      "condition": "rsi(7) < 10 && close < lower_bb"
    },
    "short": {
      "condition": "rsi(7) > 90 && close > upper_bb"
    }
  },
  "exit_rules": {
    "tp": {
      "type": "fixed",
      "params": {
        "pips": 200
      }
    },
    "sl": {
      "type": "fixed",
      "params": {
        "pips": 50
      }
    },
    "time_stop": {
      "type": "minutes",
      "params": {
        "num_minutes": 30
      }
    }
  },
  "sizing_rules": {
    "type": "risk",
    "params": {
      "risk_percent": 1
    }
  }
}
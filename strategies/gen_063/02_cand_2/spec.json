{
  "hypothesis": "Bollinger Band touch-and-bounce occurs on XAUUSD M15 when price touches the band and closes back inside",
  "regime_filter": {
    "type": "session_mask",
    "params": {
      "session": "07:00-20:00"
    }
  },
  "entry_rule": {
    "type": "bb_touch_and_bounce",
    "params": {
      "bb_period": 20,
      "bb_deviation": 2.0,
      "touch_tolerance": 0.2
    }
  },
  "exit_rule": {
    "type": "multi_condition",
    "params": {
      "conditions": [
        {
          "type": "take_profit",
          "params": {
            "target": "0.5 * atr(14)"
          }
        },
        {
          "type": "stop_loss",
          "params": {
            "distance": "1.0 * atr(14)"
          }
        },
        {
          "type": "time_stop",
          "params": {
            "bars": 15
          }
        }
      ]
    }
  },
  "sizing_rule": {
    "type": "fixed_fraction",
    "params": {
      "fraction": 0.015
    }
  }
}
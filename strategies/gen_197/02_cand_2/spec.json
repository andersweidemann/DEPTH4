{
  "hypothesis": "Bollinger Band touch-and-bounce reversal occurs on XAUUSD M5 with 3-bar pattern",
  "regime_filter": {
    "type": "bb_width",
    "params": {
      "bb_period": 20,
      "bb_deviation": 2.0,
      "min_width": 10
    }
  },
  "entry_rule": {
    "type": "bb_touch_bounce",
    "params": {
      "bb_period": 20,
      "bb_deviation": 2.0
    }
  },
  "exit_rule": {
    "type": "tp_sl_time",
    "params": {
      "tp": "500_pips",
      "sl": "100_pips",
      "time_stop": 30
    }
  },
  "sizing_rule": {
    "type": "fixed_fraction",
    "params": {
      "fraction": 0.02
    }
  }
}
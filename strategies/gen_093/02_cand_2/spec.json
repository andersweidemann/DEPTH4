{
  "hypothesis": "Bollinger Band touch-and-bounce reversal occurs on XAUUSD M15",
  "regime_filter": {
    "type": "bb_width",
    "params": {
      "period": 20,
      "deviation": 2.0
    }
  },
  "entry_rules": {
    "long": {
      "condition": "close > lower_bb && rsi(7) < 10"
    },
    "short": {
      "condition": "close < upper_bb && rsi(7) > 90"
    }
  },
  "exit_rules": {
    "stop_loss": {
      "type": "atr",
      "params": {
        "period": 14,
        "multiplier": 1.5
      }
    },
    "take_profit": {
      "type": "opposite_bb"
    },
    "time_stop": {
      "type": "bars",
      "params": {
        "count": 30
      }
    }
  },
  "sizing_rules": {
    "type": "fixed",
    "params": {
      "size": 0.01
    }
  }
}
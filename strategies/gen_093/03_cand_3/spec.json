{
  "hypothesis": "Volatility capture occurs on US500 M5 when price breaks out of the Asia range",
  "regime_filter": {
    "type": "atr_percentile",
    "params": {
      "period": 14,
      "percentile": 50
    }
  },
  "entry_rules": {
    "long": {
      "condition": "breakout > 1.2 * atr(14) && close > upper_bb"
    },
    "short": {
      "condition": "breakout < -1.2 * atr(14) && close < lower_bb"
    }
  },
  "exit_rules": {
    "stop_loss": {
      "type": "fixed",
      "params": {
        "pips": 100
      }
    },
    "take_profit": {
      "type": "fixed",
      "params": {
        "pips": 500
      }
    },
    "time_stop": {
      "type": "bars",
      "params": {
        "count": 20
      }
    }
  },
  "sizing_rules": {
    "type": "risk",
    "params": {
      "risk": 0.02
    }
  }
}
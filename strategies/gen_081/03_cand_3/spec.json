{
  "hypothesis": "ATR-based breakout occurs during high-volatility regimes",
  "regime_filter": {
    "type": "atr_percentile",
    "params": {
      "atr_period": 14,
      "percentile": 70
    }
  },
  "entry_rule": {
    "type": "atr_breakout",
    "params": {
      "atr_multiplier": 2.0
    }
  },
  "exit_rule": {
    "type": "multi_exit",
    "params": {
      "take_profit": {
        "type": "fixed",
        "params": {
          "pips": 500
        }
      },
      "stop_loss": {
        "type": "fixed",
        "params": {
          "pips": 100
        }
      },
      "time_stop": {
        "type": "bars",
        "params": {
          "bars": 30
        }
      }
    }
  },
  "sizing_rule": {
    "type": "fixed",
    "params": {
      "size": 0.01
    }
  }
}
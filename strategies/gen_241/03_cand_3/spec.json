{
  "hypothesis": "BTCUSD M15 mean reversion can be profitable with an RSI-based strategy and a volatility filter",
  "regime_filter": {
    "type": "bb_width_percentile",
    "params": {
      "bb_period": 20,
      "bb_dev": 1.75,
      "percentile": 30
    }
  },
  "entry_rule": {
    "type": "rsi_mean_reversion",
    "params": {
      "rsi_period": 7,
      "rsi_thresholds": [
        10,
        90
      ]
    }
  },
  "exit_rule": {
    "type": "tp_sl_time",
    "params": {
      "tp": "opposite_bb",
      "sl": "1.5_atr",
      "time_stop": 30
    }
  },
  "sizing_rule": {
    "type": "fixed_fraction",
    "params": {
      "fraction": 0.02
    }
  }
}
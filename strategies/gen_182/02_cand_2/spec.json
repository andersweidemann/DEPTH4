{
  "hypothesis": "Mean reversion occurs in BTCUSD on M5 when price touches the upper or lower Bollinger Band with RSI(7) in overbought/oversold territory, and the ADX is above 25",
  "regime_filter": {
    "type": "adx",
    "params": {
      "period": 14,
      "threshold": 25
    }
  },
  "entry_rules": {
    "long": {
      "condition": "close < lower_bb && rsi(7) < 10 && adx(14) > 25"
    },
    "short": {
      "condition": "close > upper_bb && rsi(7) > 90 && adx(14) > 25"
    }
  },
  "exit_rules": {
    "sl": {
      "type": "atr",
      "params": {
        "period": 14,
        "multiplier": 1.5
      }
    },
    "tp": {
      "type": "opposite_bb"
    },
    "time_stop": {
      "type": "bars",
      "params": {
        "num_bars": 30
      }
    }
  },
  "sizing_rules": {
    "type": "fixed",
    "params": {
      "size": 0.01
    }
  }
}
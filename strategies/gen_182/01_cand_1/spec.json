{
  "hypothesis": "Breakout of the Asia range in GER40 on M15 leads to a profitable trade during the London session",
  "regime_filter": {
    "type": "session",
    "params": {
      "start_hour": 7,
      "end_hour": 10
    }
  },
  "entry_rules": {
    "long": {
      "condition": "breakout_of_asia_range && displacement_candle >= 1.2 * atr(14)"
    },
    "short": {
      "condition": "breakout_of_asia_range && displacement_candle <= -1.2 * atr(14)"
    }
  },
  "exit_rules": {
    "sl": {
      "type": "fixed",
      "params": {
        "pips": 100
      }
    },
    "tp": {
      "type": "fixed",
      "params": {
        "pips": 500
      }
    },
    "time_stop": {
      "type": "hours",
      "params": {
        "num_hours": 2
      }
    }
  },
  "sizing_rules": {
    "type": "fixed",
    "params": {
      "size": 0.01
    }
  }
}
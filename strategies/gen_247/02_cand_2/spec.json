{
  "hypothesis": "Price will revert to the mean after a strong trend identified by ADX",
  "regime_filter": {
    "type": "adx",
    "params": {
      "adx_threshold": 25
    }
  },
  "entry_rule": {
    "type": "adx_mean_reversion",
    "params": {
      "adx_period": 14,
      "rsi_period": 7,
      "rsi_thresholds": [
        30,
        70
      ]
    }
  },
  "exit_rule": {
    "type": "tp_sl_time",
    "params": {
      "tp": "middle_bb",
      "sl": "1.5_atr",
      "time_stop": 30
    }
  },
  "sizing_rule": {
    "type": "fixed_fraction",
    "params": {
      "fraction": 0.015
    }
  }
}
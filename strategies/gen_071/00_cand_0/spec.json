{
  "hypothesis": "Mean reversion occurs on XAUUSD M5 when price closes outside Bollinger Bands with extreme RSI readings.",
  "regime_filter": {
    "type": "bb_width_percentile",
    "params": {
      "percentile": 30,
      "lookback": 100
    }
  },
  "entry_rule": {
    "type": "mean_reversion",
    "params": {
      "bb_period": 20,
      "bb_deviation": 1.75,
      "rsi_period": 7,
      "rsi_thresholds": [
        10,
        90
      ]
    }
  },
  "exit_rule": {
    "type": "multi_exit",
    "params": {
      "take_profit": {
        "type": "opposite_bb",
        "params": {}
      },
      "stop_loss": {
        "type": "atr",
        "params": {
          "atr_period": 14,
          "atr_multiplier": 1.5
        }
      },
      "time_stop": {
        "type": "bars",
        "params": {
          "bars": 30
        }
      }
    }
  },
  "sizing_rule": {
    "type": "fixed",
    "params": {
      "size": 0.1
    }
  }
}
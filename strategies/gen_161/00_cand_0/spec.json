{
  "hypothesis": "Mean reversion occurs on XAUUSD M5 when price touches the upper or lower Bollinger Band with RSI(7) in overbought/oversold territory",
  "regime_filter": {
    "type": "bb_width_percentile",
    "params": {
      "bb_period": 20,
      "bb_deviation": 1.75,
      "percentile": 30
    }
  },
  "entry_rule": {
    "type": "mean_reversion",
    "params": {
      "bb_period": 20,
      "bb_deviation": 1.75,
      "rsi_period": 7,
      "rsi_thresholds": [
        10,
        90
      ]
    }
  },
  "exit_rule": {
    "type": "multi_condition",
    "params": {
      "conditions": [
        {
          "type": "take_profit",
          "params": {
            "tp_price": "opposite_bb"
          }
        },
        {
          "type": "stop_loss",
          "params": {
            "sl_price": "1.5_atr"
          }
        },
        {
          "type": "time_stop",
          "params": {
            "time_stop_bar": 30
          }
        }
      ]
    }
  },
  "sizing_rule": {
    "type": "fixed_fraction",
    "params": {
      "fraction": 0.01
    }
  }
}
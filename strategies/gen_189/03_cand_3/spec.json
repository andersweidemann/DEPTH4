{
  "hypothesis": "Mean reversion occurs on US500 M5 when price closes outside Bollinger Bands with extreme RSI readings and high BB width",
  "regime_filter": {
    "type": "bb_width_percentile",
    "params": {
      "period": 20,
      "deviation": 1.75,
      "percentile": 70
    }
  },
  "entry_rule": {
    "type": "mean_reversion",
    "params": {
      "bb_period": 20,
      "bb_deviation": 1.75,
      "rsi_period": 7,
      "rsi_thresholds": [
        10,
        90
      ]
    }
  },
  "exit_rule": {
    "type": "take_profit_stop_loss",
    "params": {
      "take_profit": "middle_bollinger_band",
      "stop_loss": "1.5x_atr",
      "time_stop": 30
    }
  },
  "sizing_rule": {
    "type": "fixed_fraction",
    "params": {
      "fraction": 0.01
    }
  }
}
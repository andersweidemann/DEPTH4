{
  "hypothesis": "Bollinger Band touch-and-bounce reversal occurs on XAUUSD M15",
  "regime_filter": {
    "type": "session_filter",
    "params": {
      "session": "london"
    }
  },
  "entry_rule": {
    "type": "bb_touch_and_bounce",
    "params": {
      "bb_period": 20,
      "bb_deviation": 2.0
    }
  },
  "exit_rule": {
    "type": "take_profit_stop_loss",
    "params": {
      "take_profit": "opposite_bollinger_band",
      "stop_loss": "fixed_pips",
      "stop_loss_pips": 100,
      "time_stop": 30
    }
  },
  "sizing_rule": {
    "type": "fixed_fraction",
    "params": {
      "fraction": 0.01
    }
  }
}
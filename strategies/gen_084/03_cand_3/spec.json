{
  "hypothesis": "Mean reversion occurs when price closes outside Bollinger Bands with extreme RSI readings on US500 M5",
  "regime_filter": {
    "type": "adx",
    "params": {
      "period": 14,
      "threshold": 20
    }
  },
  "symbol": "US500",
  "timeframe": "M5",
  "entry_rule": {
    "type": "bb_rsi_mean_reversion",
    "params": {
      "bb_period": 20,
      "bb_deviation": 1.75,
      "rsi_period": 7,
      "rsi_thresholds": [
        10,
        90
      ]
    }
  },
  "exit_rule": {
    "type": "tp_sl",
    "params": {
      "tp": 500,
      "sl": 100
    }
  },
  "sizing_rule": {
    "type": "fixed",
    "params": {
      "size": 0.1
    }
  }
}
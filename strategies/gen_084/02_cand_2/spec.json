{
  "hypothesis": "Bollinger Band touch-and-bounce reversal occurs on XAUUSD M15",
  "regime_filter": {
    "type": "bb_width",
    "params": {
      "min_width": 0.5,
      "max_width": 2.0
    }
  },
  "symbol": "XAUUSD",
  "timeframe": "M15",
  "entry_rule": {
    "type": "bb_touch_bounce",
    "params": {
      "bb_period": 20,
      "bb_deviation": 2.0
    }
  },
  "exit_rule": {
    "type": "opposite_bb",
    "params": {
      "sl_multiplier": 1.5,
      "time_stop": 30
    }
  },
  "sizing_rule": {
    "type": "fixed_fraction",
    "params": {
      "fraction": 0.01
    }
  }
}
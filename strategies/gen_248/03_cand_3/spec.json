{
  "hypothesis": "Mean reversion scalping strategy using RSI and Bollinger Bands is profitable on US500 M5",
  "regime_filter": {
    "type": "rsi",
    "params": {
      "rsi_period": 7,
      "rsi_threshold": 70
    }
  },
  "entry_rules": {
    "long": {
      "condition": "close < lower_bb && rsi(7) < 30"
    },
    "short": {
      "condition": "close > upper_bb && rsi(7) > 70"
    }
  },
  "exit_rules": {
    "stop_loss": {
      "type": "fixed",
      "params": {
        "pips": 50
      }
    },
    "take_profit": {
      "type": "fixed",
      "params": {
        "pips": 200
      }
    },
    "time_stop": {
      "type": "minutes",
      "params": {
        "minutes": 30
      }
    }
  },
  "sizing_rules": {
    "type": "risk",
    "params": {
      "risk": 0.01
    }
  }
}
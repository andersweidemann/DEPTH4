{
  "hypothesis": "Bollinger Band touch-and-bounce reversals are profitable on XAUUSD M15",
  "regime_filter": {
    "type": "bb_width",
    "params": {
      "min_width": 10,
      "max_width": 50
    }
  },
  "entry_rules": {
    "long": {
      "condition": "close > lower_bb && bounce == true"
    },
    "short": {
      "condition": "close < upper_bb && bounce == true"
    }
  },
  "exit_rules": {
    "sl": {
      "type": "atr",
      "params": {
        "multiplier": 2
      }
    },
    "tp": {
      "type": "opposite_bb"
    },
    "time_stop": {
      "type": "bars",
      "params": {
        "num_bars": 20
      }
    }
  },
  "sizing_rules": {
    "type": "fixed_fraction",
    "params": {
      "fraction": 0.02
    }
  }
}
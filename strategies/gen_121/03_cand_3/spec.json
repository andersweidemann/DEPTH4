{
  "hypothesis": "ATR-based volatility filters can improve mean reversion strategy performance",
  "regime_filter": {
    "type": "atr_percentile",
    "params": {
      "percentile": 50,
      "lookback": 14
    }
  },
  "entry_rules": {
    "long": {
      "condition": "close < lower_bb && rsi(7) < 10 && atr(14) > atr_percentile"
    },
    "short": {
      "condition": "close > upper_bb && rsi(7) > 90 && atr(14) > atr_percentile"
    }
  },
  "exit_rules": {
    "sl": {
      "type": "atr",
      "params": {
        "multiplier": 1.5
      }
    },
    "tp": {
      "type": "opposite_bb"
    },
    "time_stop": {
      "type": "bars",
      "params": {
        "num_bars": 30
      }
    }
  },
  "sizing_rules": {
    "type": "fixed",
    "params": {
      "amount": 0.05
    }
  }
}
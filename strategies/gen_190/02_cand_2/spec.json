{
  "hypothesis": "Bollinger Band touch-and-bounce reversal strategy is profitable on XAUUSD M5 when price touches the upper or lower Bollinger Band and then closes back inside the band.",
  "regime_filter": {
    "type": "bb_touch",
    "params": {
      "bb_period": 20,
      "bb_deviation": 1.75
    }
  },
  "entry_rules": {
    "long": {
      "condition": "close > lower_bb && close[-1] < lower_bb"
    },
    "short": {
      "condition": "close < upper_bb && close[-1] > upper_bb"
    }
  },
  "exit_rules": {
    "tp": {
      "type": "opposite_bb",
      "params": {}
    },
    "sl": {
      "type": "atr",
      "params": {
        "atr_period": 14,
        "atr_multiplier": 1.5
      }
    },
    "time_stop": {
      "type": "bars",
      "params": {
        "bars": 30
      }
    }
  },
  "sizing_rules": {
    "type": "fixed",
    "params": {
      "size": 0.1
    }
  }
}
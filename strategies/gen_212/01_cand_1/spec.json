{
  "hypothesis": "Asia-London range expansion occurs in GER40 on M15",
  "regime_filter": {
    "type": "session",
    "params": {
      "start_hour": 7,
      "end_hour": 10
    }
  },
  "entry_rules": {
    "long": {
      "condition": "breakout > upper_range",
      "params": {
        "range_atr_min": 0.5,
        "range_atr_max": 2.0
      }
    },
    "short": {
      "condition": "breakout < lower_range",
      "params": {
        "range_atr_min": 0.5,
        "range_atr_max": 2.0
      }
    }
  },
  "exit_rules": {
    "sl": {
      "type": "fixed",
      "params": {
        "distance": 100
      }
    },
    "tp": {
      "type": "fixed",
      "params": {
        "distance": 500
      }
    },
    "time_stop": {
      "type": "fixed",
      "params": {
        "bars": 30
      }
    }
  },
  "sizing_rules": {
    "type": "fixed",
    "params": {
      "size": 0.1
    }
  }
}
{
  "hypothesis": "Bollinger Band touch-and-bounce reversal occurs in XAUUSD on M15",
  "regime_filter": {
    "type": "bb_width",
    "params": {
      "min_width": 10
    }
  },
  "entry_rules": {
    "long": {
      "condition": "close > lower_bb && close < lower_bb[1]",
      "params": {
        "bb_period": 20,
        "bb_dev": 2.0
      }
    },
    "short": {
      "condition": "close < upper_bb && close > upper_bb[1]",
      "params": {
        "bb_period": 20,
        "bb_dev": 2.0
      }
    }
  },
  "exit_rules": {
    "sl": {
      "type": "fixed",
      "params": {
        "distance": 100
      }
    },
    "tp": {
      "type": "opposite_bb",
      "params": {}
    },
    "time_stop": {
      "type": "fixed",
      "params": {
        "bars": 30
      }
    }
  },
  "sizing_rules": {
    "type": "fixed",
    "params": {
      "size": 0.1
    }
  }
}
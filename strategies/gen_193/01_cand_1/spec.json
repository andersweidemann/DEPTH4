{
  "hypothesis": "Breakout occurs on GER40 M15 when price breaks out of Asia range with high volatility",
  "regime_filter": {
    "type": "atr_percentile",
    "params": {
      "period": 14,
      "percentile": 70
    }
  },
  "entry_rules": {
    "long": {
      "condition": "high > asia_range_high and close > upper_bb(20, 2.0)"
    },
    "short": {
      "condition": "low < asia_range_low and close < lower_bb(20, 2.0)"
    }
  },
  "exit_rules": {
    "sl": {
      "type": "fixed",
      "params": {
        "pips": 100
      }
    },
    "tp": {
      "type": "fixed",
      "params": {
        "pips": 500
      }
    },
    "time_stop": {
      "type": "hours",
      "params": {
        "num_hours": 2
      }
    }
  },
  "sizing_rules": {
    "type": "risk_percent",
    "params": {
      "percent": 2
    }
  }
}
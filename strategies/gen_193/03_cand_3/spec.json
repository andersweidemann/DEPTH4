{
  "hypothesis": "Breakout occurs on US500 M15 when price breaks out of Donchian channel with high volatility",
  "regime_filter": {
    "type": "atr_percentile",
    "params": {
      "period": 14,
      "percentile": 80
    }
  },
  "entry_rules": {
    "long": {
      "condition": "high > donchian_channel_high and close > upper_bb(20, 2.0)"
    },
    "short": {
      "condition": "low < donchian_channel_low and close < lower_bb(20, 2.0)"
    }
  },
  "exit_rules": {
    "sl": {
      "type": "fixed",
      "params": {
        "pips": 150
      }
    },
    "tp": {
      "type": "fixed",
      "params": {
        "pips": 600
      }
    },
    "time_stop": {
      "type": "hours",
      "params": {
        "num_hours": 3
      }
    }
  },
  "sizing_rules": {
    "type": "risk_percent",
    "params": {
      "percent": 3
    }
  }
}
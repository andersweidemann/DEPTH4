{
  "hypothesis": "RSI extremes on BTCUSD M5 lead to mean reversion opportunities",
  "regime_filter": {
    "type": "atr_percentile",
    "params": {
      "atr_period": 14,
      "percentile": 50
    }
  },
  "entry_rules": {
    "long": {
      "condition": "rsi(7) < 20"
    },
    "short": {
      "condition": "rsi(7) > 80"
    }
  },
  "exit_rules": {
    "sl": {
      "type": "fixed",
      "params": {
        "distance": 200
      }
    },
    "tp": {
      "type": "fixed",
      "params": {
        "distance": 400
      }
    },
    "time_stop": {
      "type": "fixed",
      "params": {
        "bars": 15
      }
    }
  },
  "sizing": {
    "type": "fixed",
    "params": {
      "size": 0.05
    }
  }
}
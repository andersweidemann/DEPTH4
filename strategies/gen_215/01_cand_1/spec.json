{
  "hypothesis": "Breakout of Asia range on GER40 M15 leads to profitable trades",
  "regime_filter": {
    "type": "session",
    "params": {
      "start_hour": 7,
      "end_hour": 10
    }
  },
  "entry_rules": {
    "long": {
      "condition": "close > asia_range_high"
    },
    "short": {
      "condition": "close < asia_range_low"
    }
  },
  "exit_rules": {
    "sl": {
      "type": "fixed",
      "params": {
        "distance": 50
      }
    },
    "tp": {
      "type": "fixed",
      "params": {
        "distance": 100
      }
    },
    "time_stop": {
      "type": "fixed",
      "params": {
        "bars": 20
      }
    }
  },
  "sizing": {
    "type": "fixed",
    "params": {
      "size": 0.2
    }
  }
}
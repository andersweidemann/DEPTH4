{
  "hypothesis": "Breakouts occur on GER40 M15 during London session with high volatility",
  "regime_filter": {
    "type": "session",
    "params": {
      "start": "07:00",
      "end": "10:00"
    }
  },
  "entry_rules": {
    "long": {
      "condition": "close > upper_bb(20, 2.0) and atr(14) > 10"
    },
    "short": {
      "condition": "close < lower_bb(20, 2.0) and atr(14) > 10"
    }
  },
  "exit_rules": {
    "sl": {
      "type": "fixed",
      "params": {
        "distance": 2.0
      }
    },
    "tp": {
      "type": "fixed",
      "params": {
        "distance": 5.0
      }
    },
    "time_stop": {
      "type": "fixed",
      "params": {
        "bars": 20
      }
    }
  },
  "sizing_rules": {
    "type": "fixed",
    "params": {
      "size": 0.01
    }
  }
}
{
  "hypothesis": "Range expansion occurs on US500 M15 during Asia-London transition",
  "regime_filter": {
    "type": "asia_london_transition",
    "params": {
      "asia_start": "00:00",
      "asia_end": "06:00",
      "london_start": "07:00"
    }
  },
  "entry_rules": {
    "long": {
      "condition": "close > upper_donchian(20) and atr(14) > 5"
    },
    "short": {
      "condition": "close < lower_donchian(20) and atr(14) > 5"
    }
  },
  "exit_rules": {
    "sl": {
      "type": "fixed",
      "params": {
        "distance": 1.5
      }
    },
    "tp": {
      "type": "fixed",
      "params": {
        "distance": 4.0
      }
    },
    "time_stop": {
      "type": "fixed",
      "params": {
        "bars": 25
      }
    }
  },
  "sizing_rules": {
    "type": "fixed",
    "params": {
      "size": 0.01
    }
  }
}
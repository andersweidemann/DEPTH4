{
  "hypothesis": "Mean reversion occurs on BTCUSD M5 when RSI is oversold or overbought",
  "regime_filter": {
    "type": "rsi_extremes",
    "params": {
      "oversold": 30,
      "overbought": 70
    }
  },
  "entry_rules": {
    "long": {
      "condition": "rsi(14) < 30"
    },
    "short": {
      "condition": "rsi(14) > 70"
    }
  },
  "exit_rules": {
    "sl": {
      "type": "fixed",
      "params": {
        "distance": 1.0
      }
    },
    "tp": {
      "type": "fixed",
      "params": {
        "distance": 3.0
      }
    },
    "time_stop": {
      "type": "fixed",
      "params": {
        "bars": 15
      }
    }
  },
  "sizing_rules": {
    "type": "fixed",
    "params": {
      "size": 0.01
    }
  }
}
{
  "hypothesis": "Breakouts occur when price displaces the Asia range during the London session",
  "regime_filter": {
    "type": "session",
    "params": {
      "start_hour": 7,
      "end_hour": 10
    }
  },
  "entry_rules": {
    "long": {
      "condition": "displacement_candle > 1.2 * atr(14) && close > asia_high"
    },
    "short": {
      "condition": "displacement_candle < -1.2 * atr(14) && close < asia_low"
    }
  },
  "exit_rules": {
    "stop_loss": {
      "type": "fixed",
      "params": {
        "pips": 100
      }
    },
    "take_profit": {
      "type": "fixed",
      "params": {
        "pips": 500
      }
    },
    "time_stop": {
      "type": "bars",
      "params": {
        "num_bars": 20
      }
    }
  },
  "sizing_rules": {
    "type": "fixed",
    "params": {
      "size": 0.01
    }
  }
}
{
  "hypothesis": "Volatility contraction precedes expansion during the Asia-London transition",
  "regime_filter": {
    "type": "volatility_contraction",
    "params": {
      "threshold": 0.5
    }
  },
  "entry_rules": {
    "long": {
      "condition": "asia_range < atr(14) * 0.5 && london_displacement > 1.2 * atr(14)"
    },
    "short": {
      "condition": "asia_range < atr(14) * 0.5 && london_displacement < -1.2 * atr(14)"
    }
  },
  "exit_rules": {
    "stop_loss": {
      "type": "fixed",
      "params": {
        "pips": 100
      }
    },
    "take_profit": {
      "type": "fixed",
      "params": {
        "pips": 500
      }
    },
    "time_stop": {
      "type": "bars",
      "params": {
        "num_bars": 20
      }
    }
  },
  "sizing_rules": {
    "type": "fixed",
    "params": {
      "size": 0.01
    }
  }
}
{
  "hypothesis": "ATR-based volatility normalization improves trading performance",
  "regime_filter": {
    "type": "atr_percentile",
    "params": {
      "atr_period": 14,
      "percentile": 50
    }
  },
  "entry_rules": {
    "long": {
      "condition": "rsi(7) < 30 && close > sma(50)"
    },
    "short": {
      "condition": "rsi(7) > 70 && close < sma(50)"
    }
  },
  "exit_rules": {
    "sl": {
      "type": "atr",
      "params": {
        "atr_period": 14,
        "atr_multiplier": 1
      }
    },
    "tp": {
      "type": "fixed",
      "params": {
        "pips": 300
      }
    },
    "time_stop": {
      "type": "bars",
      "params": {
        "bars": 30
      }
    }
  },
  "sizing_rules": {
    "type": "risk",
    "params": {
      "risk": 0.01
    }
  }
}
{
  "hypothesis": "Donchian channel breakouts lead to trend following opportunities",
  "regime_filter": {
    "type": "donchian_channel",
    "params": {
      "channel_period": 20
    }
  },
  "entry_rules": {
    "long": {
      "condition": "close > donchian_channel_high"
    },
    "short": {
      "condition": "close < donchian_channel_low"
    }
  },
  "exit_rules": {
    "sl": {
      "type": "atr",
      "params": {
        "atr_period": 14,
        "atr_multiplier": 2
      }
    },
    "tp": {
      "type": "trailing",
      "params": {
        "trailing_pips": 200
      }
    },
    "time_stop": {
      "type": "bars",
      "params": {
        "bars": 40
      }
    }
  },
  "sizing_rules": {
    "type": "fixed",
    "params": {
      "size": 0.02
    }
  }
}
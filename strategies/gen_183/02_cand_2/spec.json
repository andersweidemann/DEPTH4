{
  "hypothesis": "Mean reversion occurs on US500 M5 when the RSI reaches extreme levels and the price is outside the Bollinger Bands.",
  "regime_filter": {
    "type": "rsi_extremes",
    "params": {
      "period": 7,
      "lower_threshold": 10,
      "upper_threshold": 90
    }
  },
  "entry_rules": {
    "long": {
      "condition": "rsi(7) < 10 and close < lower_bb(20, 1.75)"
    },
    "short": {
      "condition": "rsi(7) > 90 and close > upper_bb(20, 1.75)"
    }
  },
  "exit_rules": {
    "sl": {
      "type": "atr",
      "params": {
        "period": 14,
        "multiplier": 1.5
      }
    },
    "tp": {
      "type": "opposite_bb"
    },
    "time_stop": {
      "type": "bars",
      "params": {
        "num_bars": 30
      }
    }
  },
  "sizing": {
    "type": "fixed",
    "params": {
      "size": 0.1
    }
  }
}
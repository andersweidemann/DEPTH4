{
  "hypothesis": "Breakouts occur on GER40 M15 after a period of consolidation, as measured by ATR.",
  "regime_filter": {
    "type": "atr_percentile",
    "params": {
      "period": 14,
      "percentile": 50
    }
  },
  "entry_rules": {
    "long": {
      "condition": "close > upper_bb(20, 2.0) and atr(14) > atr(14)[1]"
    },
    "short": {
      "condition": "close < lower_bb(20, 2.0) and atr(14) > atr(14)[1]"
    }
  },
  "exit_rules": {
    "sl": {
      "type": "fixed",
      "params": {
        "pips": 100
      }
    },
    "tp": {
      "type": "fixed",
      "params": {
        "pips": 200
      }
    },
    "time_stop": {
      "type": "hours",
      "params": {
        "num_hours": 2
      }
    }
  },
  "sizing": {
    "type": "proportional",
    "params": {
      "proportion": 0.02
    }
  }
}
{
  "hypothesis": "Bollinger Band touch-and-bounce reversal occurs on US500 M15 with high probability",
  "regime_filter": {
    "type": "bb_touch",
    "params": {
      "bb_period": 20,
      "bb_deviation": 2.0
    }
  },
  "entry_rule": {
    "type": "bb_touch_and_bounce",
    "params": {
      "rsi_period": 7,
      "rsi_thresholds": [
        25,
        75
      ]
    }
  },
  "exit_rule": {
    "type": "take_profit_and_stop_loss",
    "params": {
      "take_profit": "opposite_bollinger_band",
      "stop_loss": "1.2x_atr",
      "time_stop": 45
    }
  },
  "sizing_rule": {
    "type": "fixed_fractional",
    "params": {
      "fraction": 0.025
    }
  }
}
{
  "hypothesis": "Asia-London range expansion occurs on XAUUSD M5 with high probability",
  "regime_filter": {
    "type": "asia_london_range",
    "params": {
      "asia_range_atr_min": 0.5,
      "asia_range_atr_max": 2.0
    }
  },
  "entry_rule": {
    "type": "range_expansion",
    "params": {
      "breakout_threshold": 1.2
    }
  },
  "exit_rule": {
    "type": "take_profit_and_stop_loss",
    "params": {
      "take_profit": "fixed_pips",
      "take_profit_pips": 150,
      "stop_loss": "fixed_pips",
      "stop_loss_pips": 75,
      "time_stop": 90
    }
  },
  "sizing_rule": {
    "type": "fixed_fractional",
    "params": {
      "fraction": 0.015
    }
  }
}
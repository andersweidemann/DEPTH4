{
  "hypothesis": "Price will revert to the mean after a strong trend",
  "regime_filter": {
    "type": "adx",
    "params": {
      "threshold": 30
    }
  },
  "entry_rules": {
    "long": {
      "condition": "adx > 30 && close < sma"
    },
    "short": {
      "condition": "adx > 30 && close > sma"
    }
  },
  "exit_rules": {
    "sl": {
      "type": "fixed",
      "params": {
        "distance": 100
      }
    },
    "tp": {
      "type": "sma"
    },
    "time_stop": {
      "type": "fixed",
      "params": {
        "bars": 30
      }
    }
  },
  "sizing_rules": {
    "type": "fixed",
    "params": {
      "size": 0.1
    }
  }
}
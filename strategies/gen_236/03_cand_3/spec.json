{
  "hypothesis": "Bollinger Band touch-and-bounce reversal occurs on XAUUSD M15",
  "regime_filter": {
    "type": "bb_width",
    "params": {
      "min_width": 10,
      "max_width": 50
    }
  },
  "entry_rules": {
    "long": {
      "condition": "close > lower_bb && rsi < 30"
    },
    "short": {
      "condition": "close < upper_bb && rsi > 70"
    }
  },
  "exit_rules": {
    "sl": {
      "type": "fixed",
      "params": {
        "distance": 100
      }
    },
    "tp": {
      "type": "opposite_bb"
    },
    "time_stop": {
      "type": "fixed",
      "params": {
        "bars": 30
      }
    }
  },
  "sizing_rules": {
    "type": "fixed",
    "params": {
      "size": 0.1
    }
  }
}
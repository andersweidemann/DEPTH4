{
  "hypothesis": "RSI extremes lead to mean reversion opportunities on GER40 M5",
  "regime_filter": {
    "type": "rsi_extremes",
    "params": {
      "threshold": 70
    }
  },
  "entry_rules": {
    "long": {
      "condition": "rsi(7) < 30"
    },
    "short": {
      "condition": "rsi(7) > 70"
    }
  },
  "exit_rules": {
    "stop_loss": {
      "type": "fixed",
      "params": {
        "pips": 100
      }
    },
    "take_profit": {
      "type": "fixed",
      "params": {
        "pips": 500
      }
    },
    "time_stop": {
      "type": "hours",
      "params": {
        "num_hours": 2
      }
    }
  },
  "sizing_rules": {
    "type": "fixed",
    "params": {
      "size": 0.01
    }
  }
}
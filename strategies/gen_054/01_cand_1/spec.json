{
  "hypothesis": "Breakouts occur during London session with sufficient volatility",
  "regime_filter": {
    "type": "session",
    "params": {
      "start_hour": 7,
      "end_hour": 10
    }
  },
  "entry_rules": {
    "long": {
      "condition": "close > upper_bb && atr(14) > 10"
    },
    "short": {
      "condition": "close < lower_bb && atr(14) > 10"
    }
  },
  "exit_rules": {
    "tp": {
      "type": "fixed",
      "params": {
        "pips": 50
      }
    },
    "sl": {
      "type": "fixed",
      "params": {
        "pips": 20
      }
    },
    "time_stop": {
      "type": "hours",
      "params": {
        "num_hours": 2
      }
    }
  },
  "sizing_rules": {
    "type": "proportional",
    "params": {
      "percentage": 0.02
    }
  }
}
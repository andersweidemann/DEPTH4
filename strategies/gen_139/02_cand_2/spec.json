{
  "hypothesis": "Price reversion occurs after a strong trend",
  "regime_filter": {
    "type": "adx",
    "params": {
      "threshold": 25
    }
  },
  "entry_rules": {
    "long": {
      "condition": "close > sma(20) && adx(14) > 25"
    },
    "short": {
      "condition": "close < sma(20) && adx(14) > 25"
    }
  },
  "exit_rules": {
    "sl": {
      "type": "atr",
      "params": {
        "multiplier": 2
      }
    },
    "tp": {
      "type": "fixed",
      "params": {
        "pips": 200
      }
    },
    "time_stop": {
      "type": "bars",
      "params": {
        "num_bars": 20
      }
    }
  },
  "sizing_rules": {
    "type": "fixed_fraction",
    "params": {
      "fraction": 0.02
    }
  }
}
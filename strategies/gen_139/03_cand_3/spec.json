{
  "hypothesis": "Bollinger Band touch-and-bounce reversal occurs",
  "regime_filter": {
    "type": "bb_width",
    "params": {
      "min_width": 10,
      "max_width": 50
    }
  },
  "entry_rules": {
    "long": {
      "condition": "close > lower_bb && close[-1] < lower_bb"
    },
    "short": {
      "condition": "close < upper_bb && close[-1] > upper_bb"
    }
  },
  "exit_rules": {
    "sl": {
      "type": "fixed",
      "params": {
        "pips": 50
      }
    },
    "tp": {
      "type": "opposite_bb"
    },
    "time_stop": {
      "type": "hours",
      "params": {
        "num_hours": 1
      }
    }
  },
  "sizing_rules": {
    "type": "fixed",
    "params": {
      "amount": 0.05
    }
  }
}
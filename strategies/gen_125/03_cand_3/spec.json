{
  "hypothesis": "ATR breakout on BTCUSD M5 leads to trend continuation",
  "regime_filter": {
    "type": "atr_percentile",
    "params": {
      "percentile": 70,
      "lookback": 50
    }
  },
  "entry_rules": {
    "long": {
      "condition": "high > atr_breakout_high && close > upper_bb"
    },
    "short": {
      "condition": "low < atr_breakout_low && close < lower_bb"
    }
  },
  "exit_rules": {
    "tp": {
      "type": "fixed",
      "params": {
        "pips": 100
      }
    },
    "sl": {
      "type": "fixed",
      "params": {
        "pips": 50
      }
    },
    "time_stop": {
      "type": "hours",
      "params": {
        "num_hours": 4
      }
    }
  },
  "sizing_rules": {
    "type": "risk",
    "params": {
      "risk_percent": 1.5
    }
  }
}
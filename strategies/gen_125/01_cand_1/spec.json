{
  "hypothesis": "Breakout of Asia range on GER40 M15 leads to continuation",
  "regime_filter": {
    "type": "session",
    "params": {
      "start_hour": 7,
      "end_hour": 10
    }
  },
  "entry_rules": {
    "long": {
      "condition": "high > asia_range_high && close > upper_bb"
    },
    "short": {
      "condition": "low < asia_range_low && close < lower_bb"
    }
  },
  "exit_rules": {
    "tp": {
      "type": "fixed",
      "params": {
        "pips": 50
      }
    },
    "sl": {
      "type": "fixed",
      "params": {
        "pips": 20
      }
    },
    "time_stop": {
      "type": "hours",
      "params": {
        "num_hours": 2
      }
    }
  },
  "sizing_rules": {
    "type": "risk",
    "params": {
      "risk_percent": 2
    }
  }
}
      "max_range_atr": 2.0
    }
  },
  "entry_rule": {
    "type": "london_breakout",
    "params": {
      "breakout_threshold": 0.5,
      "retest_threshold": 0.2
    }
  },
  "exit_rule": {
    "type": "tp_sl",
    "params": {
      "tp_pips": 500,
      "sl_pips": 100

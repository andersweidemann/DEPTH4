{
  "hypothesis": "The RSI indicator can be used to identify overbought and oversold conditions, leading to mean reversion",
  "regime_filter": {
    "type": "rsi",
    "params": {
      "period": 7,
      "threshold": 30
    }
  },
  "entry_rules": {
    "long": {
      "condition": "rsi(7) < 30"
    },
    "short": {
      "condition": "rsi(7) > 70"
    }
  },
  "exit_rules": {
    "sl": {
      "type": "atr",
      "params": {
        "multiplier": 1.5
      }
    },
    "tp": {
      "type": "opposite_rsi"
    },
    "time_stop": {
      "type": "bars",
      "params": {
        "num_bars": 30
      }
    }
  },
  "sizing_rules": {
    "type": "fixed",
    "params": {
      "size": 0.1
    }
  }
}
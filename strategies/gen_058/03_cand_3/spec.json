{
  "hypothesis": "The Donchian channel can be used to identify trend reversals",
  "regime_filter": {
    "type": "donchian_channel",
    "params": {
      "period": 20
    }
  },
  "entry_rules": {
    "long": {
      "condition": "close > donchian_channel_high"
    },
    "short": {
      "condition": "close < donchian_channel_low"
    }
  },
  "exit_rules": {
    "sl": {
      "type": "fixed",
      "params": {
        "distance": 50
      }
    },
    "tp": {
      "type": "fixed",
      "params": {
        "distance": 100
      }
    },
    "time_stop": {
      "type": "time",
      "params": {
        "hours": 2
      }
    }
  },
  "sizing_rules": {
    "type": "fixed",
    "params": {
      "size": 0.1
    }
  }
}
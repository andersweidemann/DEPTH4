{
  "hypothesis": "Breakout of the Asia range leads to a continuation of the trend during the London session",
  "regime_filter": {
    "type": "session",
    "params": {
      "start_hour": 7,
      "end_hour": 10
    }
  },
  "entry_rules": {
    "long": {
      "condition": "close > asia_range_high"
    },
    "short": {
      "condition": "close < asia_range_low"
    }
  },
  "exit_rules": {
    "sl": {
      "type": "fixed",
      "params": {
        "distance": 50
      }
    },
    "tp": {
      "type": "fixed",
      "params": {
        "distance": 100
      }
    },
    "time_stop": {
      "type": "time",
      "params": {
        "hours": 2
      }
    }
  },
  "sizing_rules": {
    "type": "fixed",
    "params": {
      "size": 0.1
    }
  }
}
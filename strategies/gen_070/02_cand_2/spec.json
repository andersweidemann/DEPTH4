{
  "hypothesis": "Mean reversion occurs when price reaches extreme deviations from its mean with high RSI readings",
  "regime_filter": {
    "type": "bb_width",
    "params": {
      "min_width": 10,
      "max_width": 50
    }
  },
  "symbol": "US500",
  "timeframe": "M5",
  "entry_rules": {
    "long": {
      "condition": "close < lower_bb && rsi(7) < 20"
    },
    "short": {
      "condition": "close > upper_bb && rsi(7) > 80"
    }
  },
  "exit_rules": {
    "tp": {
      "type": "middle_bb"
    },
    "sl": {
      "type": "atr",
      "params": {
        "multiplier": 2
      }
    },
    "time_stop": {
      "type": "bars",
      "params": {
        "num_bars": 20
      }
    }
  },
  "sizing": {
    "type": "fixed",
    "params": {
      "size": 0.2
    }
  }
}
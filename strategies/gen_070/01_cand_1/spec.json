{
  "hypothesis": "Breakout occurs when price closes outside the Asia range with sufficient volatility",
  "regime_filter": {
    "type": "atr_percentile",
    "params": {
      "percentile": 50,
      "lookback": 14
    }
  },
  "symbol": "GER40",
  "timeframe": "M15",
  "entry_rules": {
    "long": {
      "condition": "close > asia_high && atr(14) > atr_percentile"
    },
    "short": {
      "condition": "close < asia_low && atr(14) > atr_percentile"
    }
  },
  "exit_rules": {
    "tp": {
      "type": "fixed",
      "params": {
        "pips": 50
      }
    },
    "sl": {
      "type": "fixed",
      "params": {
        "pips": 20
      }
    },
    "time_stop": {
      "type": "hours",
      "params": {
        "hours": 2
      }
    }
  },
  "sizing": {
    "type": "proportional",
    "params": {
      "risk": 0.02
    }
  }
}
{
  "hypothesis": "Mean reversion occurs when price closes outside Bollinger Bands with extreme RSI readings",
  "regime_filter": {
    "type": "bb_width_percentile",
    "params": {
      "percentile": 30,
      "lookback": 20
    }
  },
  "entry_rule": {
    "type": "mean_reversion",
    "params": {
      "bb_period": 20,
      "bb_deviation": 1.75,
      "rsi_period": 7,
      "rsi_thresholds": [
        10,
        90
      ]
    }
  },
  "exit_rule": {
    "type": "take_profit",
    "params": {
      "target": "opposite_bb"
    }
  },
  "stop_loss": {
    "type": "atr",
    "params": {
      "multiplier": 1.5
    }
  },
  "time_stop": {
    "type": "bars",
    "params": {
      "num_bars": 30
    }
  },
  "sizing": {
    "type": "fixed",
    "params": {
      "size": 0.1
    }
  }
}
{
  "hypothesis": "Bollinger Band touch-and-bounce reversal occurs during high volatility",
  "regime_filter": {
    "type": "bb_width",
    "params": {
      "min_width": 0.5
    }
  },
  "entry_rule": {
    "type": "reversal",
    "params": {
      "bb_period": 20,
      "bb_deviation": 2.0,
      "reversal_threshold": 1.5
    }
  },
  "exit_rule": {
    "type": "take_profit",
    "params": {
      "target": "middle_bb"
    }
  },
  "stop_loss": {
    "type": "atr",
    "params": {
      "multiplier": 2.0
    }
  },
  "time_stop": {
    "type": "bars",
    "params": {
      "num_bars": 20
    }
  },
  "sizing": {
    "type": "fixed",
    "params": {
      "size": 0.2
    }
  }
}
{
  "hypothesis": "Breakouts occur during London session after Asia range consolidation",
  "regime_filter": {
    "type": "session",
    "params": {
      "session": "london"
    }
  },
  "entry_rules": {
    "long": {
      "condition": "breakout > upper_range && displacement > 1.2 * atr(14)"
    },
    "short": {
      "condition": "breakout < lower_range && displacement > 1.2 * atr(14)"
    }
  },
  "exit_rules": {
    "stop_loss": {
      "type": "fixed",
      "params": {
        "pips": 100
      }
    },
    "take_profit": {
      "type": "fixed",
      "params": {
        "pips": 500
      }
    },
    "time_stop": {
      "type": "hours",
      "params": {
        "num_hours": 2
      }
    }
  },
  "sizing_rules": {
    "type": "risk",
    "params": {
      "risk_percent": 2
    }
  }
}
{
  "hypothesis": "Asia-London range expansion occurs on GER40 M5",
  "regime_filter": {
    "type": "asia_range",
    "params": {
      "min_range_atr": 0.5,
      "max_range_atr": 2.0
    }
  },
  "entry_rules": {
    "long": {
      "condition": "breakout > upper_range && displacement > 1.2 * atr(14)"
    },
    "short": {
      "condition": "breakout < lower_range && displacement > 1.2 * atr(14)"
    }
  },
  "exit_rules": {
    "stop_loss": {
      "type": "fixed",
      "params": {
        "pips": 100
      }
    },
    "take_profit": {
      "type": "fixed",
      "params": {
        "pips": 500
      }
    },
    "time_stop": {
      "type": "hours",
      "params": {
        "num_hours": 2
      }
    }
  },
  "sizing_rules": {
    "type": "risk",
    "params": {
      "risk_percent": 2
    }
  }
}
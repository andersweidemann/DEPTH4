{
  "hypothesis": "Bollinger Band touch-and-bounce reversal strategy is profitable on XAUUSD M5.",
  "regime_filter": {
    "type": "bb_width",
    "params": {
      "min_width": 10,
      "max_width": 50
    }
  },
  "entry_rules": {
    "long": {
      "condition": "close > lower_bb && close < upper_bb"
    },
    "short": {
      "condition": "close < lower_bb && close > upper_bb"
    }
  },
  "exit_rules": {
    "stop_loss": {
      "type": "atr",
      "params": {
        "multiplier": 2
      }
    },
    "take_profit": {
      "type": "bb_touch"
    },
    "time_stop": {
      "type": "bars",
      "params": {
        "num_bars": 20
      }
    }
  },
  "sizing_rules": {
    "type": "fixed",
    "params": {
      "size": 0.05
    }
  }
}
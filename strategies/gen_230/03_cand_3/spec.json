{
  "hypothesis": "The mean reversion strategy using RSI and Bollinger Bands is effective in US500 on M5, with a volatility filter to avoid ranging markets.",
  "regime_filter": {
    "type": "volatility",
    "params": {
      "period": 14,
      "threshold": 20
    }
  },
  "entry_rules": {
    "long": {
      "condition": "rsi(7) < 30 && close < lower_bb"
    },
    "short": {
      "condition": "rsi(7) > 70 && close > upper_bb"
    }
  },
  "exit_rules": {
    "tp": {
      "type": "opposite_bb",
      "params": {}
    },
    "sl": {
      "type": "atr",
      "params": {
        "period": 14,
        "multiplier": 1.5
      }
    },
    "time_stop": {
      "type": "bars",
      "params": {
        "num_bars": 30
      }
    }
  },
  "sizing_rules": {
    "type": "fixed",
    "params": {
      "size": 0.01
    }
  }
}
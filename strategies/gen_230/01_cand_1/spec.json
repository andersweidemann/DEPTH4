{
  "hypothesis": "The Asia-London range expansion strategy is effective in GER40 on M15, with breakouts occurring within 9 bars of the London window start.",
  "regime_filter": {
    "type": "session",
    "params": {
      "start_hour": 7,
      "end_hour": 10
    }
  },
  "entry_rules": {
    "long": {
      "condition": "asia_range_breakout && displacement_candle >= 1.2 * atr(14) && breakout_bar >= 0.5 * atr(14)"
    },
    "short": {
      "condition": "asia_range_breakout && displacement_candle <= -1.2 * atr(14) && breakout_bar <= -0.5 * atr(14)"
    }
  },
  "exit_rules": {
    "tp": {
      "type": "fixed",
      "params": {
        "pips": 500
      }
    },
    "sl": {
      "type": "fixed",
      "params": {
        "pips": 100
      }
    },
    "time_stop": {
      "type": "bars",
      "params": {
        "num_bars": 20
      }
    }
  },
  "sizing_rules": {
    "type": "fixed",
    "params": {
      "size": 0.01
    }
  }
}
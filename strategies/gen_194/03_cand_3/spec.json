{
  "hypothesis": "Mean reversion on US500 M5 occurs when price closes outside Bollinger Bands with extreme RSI readings during Asian session",
  "regime_filter": {
    "type": "session",
    "params": {
      "start_hour": 0,
      "end_hour": 6
    }
  },
  "entry_rule": {
    "type": "mean_reversion",
    "params": {
      "bb_period": 20,
      "bb_deviation": 1.75,
      "rsi_period": 7,
      "rsi_thresholds": [
        10,
        90
      ]
    }
  },
  "exit_rule": {
    "type": "tp_sl_time",
    "params": {
      "tp": "opposite_bb",
      "sl": "1.5_atr",
      "time_stop": 30
    }
  },
  "sizing_rule": {
    "type": "fixed_risk",
    "params": {
      "risk": 0.01
    }
  }
}
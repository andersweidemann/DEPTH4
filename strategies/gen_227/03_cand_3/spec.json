{
  "hypothesis": "Mean reversion occurs when RSI reaches extreme levels during low volatility",
  "regime_filter": {
    "type": "bb_width_percentile",
    "params": {
      "percentile": 20,
      "lookback": 20
    }
  },
  "entry_rules": {
    "long": {
      "condition": "rsi < 20"
    },
    "short": {
      "condition": "rsi > 80"
    }
  },
  "exit_rules": {
    "sl": {
      "type": "fixed",
      "params": {
        "distance": 1.0
      }
    },
    "tp": {
      "type": "fixed",
      "params": {
        "distance": 2.0
      }
    },
    "time_stop": {
      "type": "fixed",
      "params": {
        "bars": 20
      }
    }
  },
  "sizing_rules": {
    "type": "fixed",
    "params": {
      "size": 0.01
    }
  }
}
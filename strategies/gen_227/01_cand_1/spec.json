{
  "hypothesis": "Asia-London range expansion leads to breakout opportunities",
  "regime_filter": {
    "type": "session",
    "params": {
      "start": "07:00",
      "end": "10:00"
    }
  },
  "entry_rules": {
    "long": {
      "condition": "breakout > 1.2 * atr"
    },
    "short": {
      "condition": "breakout < -1.2 * atr"
    }
  },
  "exit_rules": {
    "sl": {
      "type": "fixed",
      "params": {
        "distance": 100
      }
    },
    "tp": {
      "type": "fixed",
      "params": {
        "distance": 500
      }
    },
    "time_stop": {
      "type": "fixed",
      "params": {
        "bars": 20
      }
    }
  },
  "sizing_rules": {
    "type": "fixed",
    "params": {
      "size": 0.01
    }
  }
}
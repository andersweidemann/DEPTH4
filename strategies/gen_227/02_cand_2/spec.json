{
  "hypothesis": "Bollinger Band touch-and-bounce reversal occurs during high volatility",
  "regime_filter": {
    "type": "bb_width",
    "params": {
      "threshold": 2.0
    }
  },
  "entry_rules": {
    "long": {
      "condition": "close > upper_bb && rsi < 30"
    },
    "short": {
      "condition": "close < lower_bb && rsi > 70"
    }
  },
  "exit_rules": {
    "sl": {
      "type": "fixed",
      "params": {
        "distance": 1.5
      }
    },
    "tp": {
      "type": "opposite_bb"
    },
    "time_stop": {
      "type": "fixed",
      "params": {
        "bars": 30
      }
    }
  },
  "sizing_rules": {
    "type": "fixed",
    "params": {
      "size": 0.01
    }
  }
}
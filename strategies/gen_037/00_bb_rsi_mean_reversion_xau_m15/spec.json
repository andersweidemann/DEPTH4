{
  "name": "bb_rsi_mean_reversion_xau_m15",
  "hypothesis": "On XAUUSD M15, when price closes outside Bollinger Bands with extreme RSI(7) and BB-width is above its 30th percentile (volatility present, not dead chop), price reverts to the middle band within 30 bars with positive expectancy.",
  "family": "mean_reversion",
  "symbols": [
    "XAUUSD"
  ],
  "timeframes": [
    "M15"
  ],
  "signals": {
    "entry_long": "close < lower_bb(20, 2.0) AND rsi(7) < 15",
    "entry_short": "close > upper_bb(20, 2.0) AND rsi(7) > 85",
    "indicators": [
      "bollinger(20,2.0)",
      "rsi(7)",
      "bb_width(20,2.0)",
      "atr(14)"
    ]
  },
  "regime_filter": {
    "type": "bb_width_percentile",
    "lookback_bars": 500,
    "min_percentile": 30,
    "max_percentile": 95,
    "rationale": "Avoid dead-range chop (<30th) and chaotic expansions (>95th)."
  },
  "entry_rules": {
    "confirmation": "Signal bar must close; enter at next bar open.",
    "cooldown_bars": 3,
    "max_concurrent_positions": 1
  },
  "exit_rules": {
    "stop_loss": {
      "type": "atr_mult",
      "atr_period": 14,
      "mult": 1.8
    },
    "take_profit": {
      "type": "opposite_bb",
      "bb_period": 20,
      "bb_dev": 2.0
    },
    "time_stop": {
      "type": "bars",
      "n": 30
    },
    "breakeven": {
      "trigger_r": 1.0,
      "offset_r": 0.1
    }
  },
  "sizing": {
    "type": "risk_pct_of_equity",
    "risk_pct": 0.5,
    "min_lot": 0.01
  },
  "params_to_optimize": {
    "bb_dev": [
      1.75,
      2.0,
      2.25
    ],
    "rsi_period": [
      5,
      7,
      10
    ],
    "rsi_long_th": [
      10,
      15,
      20
    ],
    "rsi_short_th": [
      80,
      85,
      90
    ],
    "atr_sl_mult": [
      1.5,
      1.8,
      2.2
    ]
  },
  "diagnostics_required": [
    "bar_count_loaded",
    "indicator_nan_count_first_100_bars",
    "raw_signal_count_before_regime_filter",
    "raw_signal_count_after_regime_filter",
    "orders_submitted_vs_filled"
  ],
  "falsification_criteria": "PF < 1.3 OR trades < 200 OR max_dd > 15% on IS."
}
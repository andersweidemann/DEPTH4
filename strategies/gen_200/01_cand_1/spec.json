{
  "hypothesis": "Breakouts occur on GER40 M15 after Asia-London range expansion",
  "regime_filter": {
    "type": "session",
    "params": {
      "session_start": "07:00",
      "session_end": "10:00"
    }
  },
  "entry_rule": {
    "type": "breakout",
    "params": {
      "atr_period": 14,
      "min_range_atr": 0.5,
      "max_range_atr": 2.0
    }
  },
  "exit_rule": {
    "type": "take_profit",
    "params": {
      "tp_type": "fixed_pips",
      "tp_pips": 500,
      "sl_type": "fixed_pips",
      "sl_pips": 100
    }
  },
  "sizing_rule": {
    "type": "fixed_fraction",
    "params": {
      "fraction": 0.01
    }
  },
  "time_stop": 60
}
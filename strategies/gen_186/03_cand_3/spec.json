{
  "hypothesis": "Mean reversion occurs in BTCUSD on M5 when price closes outside Bollinger Bands with extreme RSI readings",
  "regime_filter": {
    "type": "volatility",
    "params": {
      "volatility_period": 14,
      "volatility_threshold": 50
    }
  },
  "entry_rules": {
    "long": {
      "condition": "close < lower_bb && rsi(7) < 20"
    },
    "short": {
      "condition": "close > upper_bb && rsi(7) > 80"
    }
  },
  "exit_rules": {
    "stop_loss": {
      "type": "fixed",
      "params": {
        "pips": 200
      }
    },
    "take_profit": {
      "type": "fixed",
      "params": {
        "pips": 1000
      }
    },
    "time_stop": {
      "type": "bars",
      "params": {
        "bars": 40
      }
    }
  },
  "sizing_rules": {
    "type": "fixed",
    "params": {
      "size": 0.01
    }
  }
}
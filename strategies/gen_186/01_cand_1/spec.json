{
  "hypothesis": "Asia-London range expansion occurs in GER40 on M15",
  "regime_filter": {
    "type": "session",
    "params": {
      "session_start": "07:00",
      "session_end": "10:00"
    }
  },
  "entry_rules": {
    "long": {
      "condition": "breakout > 0.5 * atr(14) && displacement > 1.2 * atr(14)"
    },
    "short": {
      "condition": "breakout < -0.5 * atr(14) && displacement < -1.2 * atr(14)"
    }
  },
  "exit_rules": {
    "stop_loss": {
      "type": "fixed",
      "params": {
        "pips": 100
      }
    },
    "take_profit": {
      "type": "fixed",
      "params": {
        "pips": 500
      }
    },
    "time_stop": {
      "type": "bars",
      "params": {
        "bars": 20
      }
    }
  },
  "sizing_rules": {
    "type": "fixed",
    "params": {
      "size": 0.01
    }
  }
}
{
  "hypothesis": "Asia-London range expansion strategy is profitable on GER40 M15",
  "regime_filter": {
    "type": "time_of_day",
    "params": {
      "start_hour": 7,
      "end_hour": 10
    }
  },
  "entry_rule": {
    "type": "range_expansion",
    "params": {
      "range_atr_min": 0.5,
      "range_atr_max": 2.0,
      "breakout_threshold": 1.2
    }
  },
  "exit_rule": {
    "type": "take_profit_and_stop_loss",
    "params": {
      "take_profit": "fixed_pips",
      "take_profit_pips": 500,
      "stop_loss": "fixed_pips",
      "stop_loss_pips": 100
    }
  },
  "sizing_rule": {
    "type": "fixed_size",
    "params": {
      "size": 0.1
    }
  }
}
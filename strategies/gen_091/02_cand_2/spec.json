{
  "hypothesis": "Bollinger Band touch-and-bounce reversal is profitable on XAUUSD M15",
  "regime_filter": {
    "type": "bb_width",
    "params": {
      "bb_period": 20,
      "bb_deviation": 2.0,
      "min_width": 0.01
    }
  },
  "entry_rule": {
    "type": "bb_touch_and_bounce",
    "params": {
      "rsi_period": 7,
      "rsi_thresholds": [
        10,
        90
      ]
    }
  },
  "exit_rule": {
    "type": "take_profit_and_stop_loss",
    "params": {
      "take_profit": "opposite_bollinger_band",
      "stop_loss": "1.5x_atr",
      "time_stop": 30
    }
  },
  "sizing_rule": {
    "type": "fixed_fraction",
    "params": {
      "fraction": 0.01
    }
  }
}
{
  "hypothesis": "Price reverts to the mean after a strong trend.",
  "regime_filter": {
    "type": "adx",
    "params": {
      "threshold": 20
    }
  },
  "symbol": "BTCUSD",
  "timeframe": "M5",
  "entry_rule": {
    "type": "adx_mean_reversion",
    "params": {
      "adx_period": 14,
      "rsi_period": 7,
      "rsi_thresholds": [
        30,
        70
      ]
    }
  },
  "exit_rule": {
    "type": "trailing_stop",
    "params": {
      "trailing_stop_pips": 100,
      "trailing_step_pips": 50
    }
  },
  "sizing_rule": {
    "type": "proportional",
    "params": {
      "proportion": 0.02
    }
  }
}
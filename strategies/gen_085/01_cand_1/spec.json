{
  "hypothesis": "Breakouts from the Asia range occur during the London session",
  "regime_filter": {
    "type": "session",
    "params": {
      "start_hour": 7,
      "end_hour": 10
    }
  },
  "entry_rule": {
    "type": "asia_london_breakout",
    "params": {
      "asia_range_start": 0,
      "asia_range_end": 6,
      "breakout_threshold": 1.2
    }
  },
  "exit_rule": {
    "type": "tp_sl_time",
    "params": {
      "tp": "fixed_pips",
      "tp_pips": 500,
      "sl": "fixed_pips",
      "sl_pips": 100,
      "time_stop": 60
    }
  },
  "sizing_rule": {
    "type": "fixed_fraction",
    "params": {
      "fraction": 0.01
    }
  }
}
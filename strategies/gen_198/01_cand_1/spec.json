{
  "hypothesis": "Breakouts occur on GER40 M15 after an Asia-London range expansion.",
  "regime_filter": {
    "type": "atr_range",
    "params": {
      "atr_period": 14,
      "min_range_atr": 0.5,
      "max_range_atr": 2.0
    }
  },
  "entry_rule": {
    "type": "breakout_retest",
    "params": {
      "breakout_threshold": 1.2,
      "retest_threshold": 0.2
    }
  },
  "exit_rule": {
    "type": "tp_sl_time",
    "params": {
      "tp": "fixed_pips",
      "tp_pips": 500,
      "sl": "fixed_pips",
      "sl_pips": 100,
      "time_stop": 60
    }
  },
  "sizing_rule": {
    "type": "fixed_fraction",
    "params": {
      "fraction": 0.01
    }
  }
}
{
  "hypothesis": "Breakout occurs when price breaks out of the Asia range with high volatility on GER40 M15",
  "regime_filter": {
    "type": "atr_percentile",
    "params": {
      "atr_period": 14,
      "percentile": 70
    }
  },
  "entry_rules": {
    "long": {
      "condition": "close > upper_range && atr(14) > atr_percentile(70)"
    },
    "short": {
      "condition": "close < lower_range && atr(14) > atr_percentile(70)"
    }
  },
  "exit_rules": {
    "stop_loss": {
      "type": "fixed",
      "params": {
        "pips": 100
      }
    },
    "take_profit": {
      "type": "fixed",
      "params": {
        "pips": 500
      }
    },
    "time_stop": {
      "type": "hours",
      "params": {
        "hours": 2
      }
    }
  },
  "sizing_rules": {
    "type": "risk",
    "params": {
      "risk_percent": 2
    }
  }
}
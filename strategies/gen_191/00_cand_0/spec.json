{
  "hypothesis": "Mean reversion occurs when price reaches extreme deviations from its mean with extreme RSI readings on XAUUSD M5",
  "regime_filter": {
    "type": "bb_width_percentile",
    "params": {
      "bb_period": 20,
      "bb_deviation": 1.75,
      "percentile": 30
    }
  },
  "entry_rules": {
    "long": {
      "condition": "close < lower_bb && rsi(7) < 10"
    },
    "short": {
      "condition": "close > upper_bb && rsi(7) > 90"
    }
  },
  "exit_rules": {
    "stop_loss": {
      "type": "atr",
      "params": {
        "atr_period": 14,
        "atr_multiplier": 1.5
      }
    },
    "take_profit": {
      "type": "opposite_bb"
    },
    "time_stop": {
      "type": "bars",
      "params": {
        "bars": 30
      }
    }
  },
  "sizing_rules": {
    "type": "fixed",
    "params": {
      "size": 0.01
    }
  }
}
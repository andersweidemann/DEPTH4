{
  "hypothesis": "Breakouts occur when price closes outside the Asia range with high momentum",
  "regime_filter": {
    "type": "session",
    "params": {
      "start_hour": 7,
      "end_hour": 10
    }
  },
  "entry_rules": {
    "long": {
      "condition": "close > asia_range_high && momentum(14) > 50"
    },
    "short": {
      "condition": "close < asia_range_low && momentum(14) < -50"
    }
  },
  "exit_rules": {
    "sl": {
      "type": "fixed",
      "params": {
        "pips": 100
      }
    },
    "tp": {
      "type": "fixed",
      "params": {
        "pips": 500
      }
    },
    "time_stop": {
      "type": "hours",
      "params": {
        "num_hours": 2
      }
    }
  },
  "sizing_rules": {
    "type": "risk",
    "params": {
      "risk_percent": 2
    }
  }
}
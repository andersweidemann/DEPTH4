{
  "hypothesis": "Price breaks out of the Donchian channel, and volatility is above a certain threshold.",
  "regime_filter": {
    "type": "donchian_channel",
    "params": {
      "period": 20
    }
  },
  "entry_rules": {
    "long": {
      "condition": "close > donchian_channel_high"
    },
    "short": {
      "condition": "close < donchian_channel_low"
    }
  },
  "exit_rules": {
    "stop_loss": {
      "type": "fixed",
      "params": {
        "pips": 100
      }
    },
    "take_profit": {
      "type": "fixed",
      "params": {
        "pips": 500
      }
    },
    "time_stop": {
      "type": "bars",
      "params": {
        "bars": 30
      }
    }
  },
  "sizing_rules": {
    "type": "fixed",
    "params": {
      "size": 0.01
    }
  }
}
{
  "hypothesis": "Bollinger Band touch-and-bounce reversal occurs on BTCUSD M5 with high RSI readings.",
  "regime_filter": {
    "type": "rsi_threshold",
    "params": {
      "rsi_period": 7,
      "threshold": 70
    }
  },
  "entry_rules": {
    "long": {
      "condition": "close > lower_bb && rsi(7) < 30"
    },
    "short": {
      "condition": "close < upper_bb && rsi(7) > 70"
    }
  },
  "exit_rules": {
    "sl": {
      "type": "atr",
      "params": {
        "atr_period": 14,
        "atr_multiplier": 2
      }
    },
    "tp": {
      "type": "opposite_bb"
    },
    "time_stop": {
      "type": "bars",
      "params": {
        "bars": 20
      }
    }
  },
  "sizing_rules": {
    "type": "fixed",
    "params": {
      "size": 0.01
    }
  }
}
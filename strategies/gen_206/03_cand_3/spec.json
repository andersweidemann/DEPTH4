{
  "hypothesis": "Mean reversion occurs when price reaches extreme deviations from its mean with extreme RSI readings on US500 M15.",
  "regime_filter": {
    "type": "bb_width_percentile",
    "params": {
      "bb_period": 20,
      "bb_deviation": 1.75,
      "percentile": 40
    }
  },
  "entry_rules": {
    "long": {
      "condition": "close < lower_bb && rsi(7) < 20"
    },
    "short": {
      "condition": "close > upper_bb && rsi(7) > 80"
    }
  },
  "exit_rules": {
    "sl": {
      "type": "atr",
      "params": {
        "atr_period": 14,
        "atr_multiplier": 1.5
      }
    },
    "tp": {
      "type": "middle_bb"
    },
    "time_stop": {
      "type": "hours",
      "params": {
        "hours": 1
      }
    }
  },
  "sizing_rules": {
    "type": "risk",
    "params": {
      "risk": 0.01
    }
  }
}
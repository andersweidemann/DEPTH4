{
  "hypothesis": "Breakout of Asia range occurs during London session with high volatility on GER40 M15.",
  "regime_filter": {
    "type": "atr_percentile",
    "params": {
      "atr_period": 14,
      "percentile": 70
    }
  },
  "entry_rules": {
    "long": {
      "condition": "high > asia_range_high && close > upper_bb"
    },
    "short": {
      "condition": "low < asia_range_low && close < lower_bb"
    }
  },
  "exit_rules": {
    "sl": {
      "type": "fixed",
      "params": {
        "pips": 100
      }
    },
    "tp": {
      "type": "fixed",
      "params": {
        "pips": 500
      }
    },
    "time_stop": {
      "type": "hours",
      "params": {
        "hours": 2
      }
    }
  },
  "sizing_rules": {
    "type": "risk",
    "params": {
      "risk": 0.02
    }
  }
}
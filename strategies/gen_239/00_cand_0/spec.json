{
  "hypothesis": "Mean reversion occurs in XAUUSD on M5 when price closes outside Bollinger Bands with extreme RSI readings",
  "regime_filter": {
    "type": "bb_width_percentile",
    "params": {
      "period": 20,
      "deviation": 1.75,
      "percentile": 30
    }
  },
  "entry_rules": {
    "long": {
      "condition": "close < lower_bb && rsi(7) < 10"
    },
    "short": {
      "condition": "close > upper_bb && rsi(7) > 90"
    }
  },
  "exit_rules": {
    "stop_loss": {
      "type": "atr",
      "params": {
        "period": 14,
        "multiplier": 1.5
      }
    },
    "take_profit": {
      "type": "opposite_bb"
    },
    "time_stop": {
      "type": "bars",
      "params": {
        "num_bars": 30
      }
    }
  },
  "sizing_rules": {
    "type": "fixed",
    "params": {
      "size": 0.01
    }
  }
}
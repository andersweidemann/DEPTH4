{
  "hypothesis": "Range trading works in BTCUSD on M15 when price is between the 20-period high and low",
  "regime_filter": {
    "type": "range",
    "params": {
      "period": 20
    }
  },
  "entry_rules": {
    "long": {
      "condition": "close > lower_range && rsi(14) < 30"
    },
    "short": {
      "condition": "close < upper_range && rsi(14) > 70"
    }
  },
  "exit_rules": {
    "stop_loss": {
      "type": "fixed",
      "params": {
        "pips": 50
      }
    },
    "take_profit": {
      "type": "opposite_range"
    },
    "time_stop": {
      "type": "hours",
      "params": {
        "num_hours": 1
      }
    }
  },
  "sizing_rules": {
    "type": "risk_percent",
    "params": {
      "percent": 1
    }
  }
}
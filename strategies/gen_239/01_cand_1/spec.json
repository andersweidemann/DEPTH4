{
  "hypothesis": "Breakouts occur in GER40 on M15 when price breaks out of the Asia range with high momentum",
  "regime_filter": {
    "type": "session",
    "params": {
      "start_hour": 7,
      "end_hour": 10
    }
  },
  "entry_rules": {
    "long": {
      "condition": "high > asia_range_high && momentum > 50"
    },
    "short": {
      "condition": "low < asia_range_low && momentum < -50"
    }
  },
  "exit_rules": {
    "stop_loss": {
      "type": "fixed",
      "params": {
        "pips": 100
      }
    },
    "take_profit": {
      "type": "fixed",
      "params": {
        "pips": 500
      }
    },
    "time_stop": {
      "type": "hours",
      "params": {
        "num_hours": 2
      }
    }
  },
  "sizing_rules": {
    "type": "risk_percent",
    "params": {
      "percent": 2
    }
  }
}
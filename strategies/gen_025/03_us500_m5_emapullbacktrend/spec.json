{
  "name": "US500_M5_EMAPullbackTrend",
  "family": "trend_pullback",
  "symbol": "US500",
  "timeframe": "M5",
  "hypothesis": "US500 M5 pullbacks to EMA(20) within an uptrend/downtrend (EMA20 > EMA50 > EMA200 or inverse) during the NY cash session produce high-probability continuation entries when RSI(14) re-crosses 50 from the pullback side.",
  "regime_filter": {
    "primitive": "classify",
    "rules": [
      {
        "name": "adx",
        "params": {
          "period": 14
        },
        "min": 20
      },
      {
        "name": "atr_percentile",
        "params": {
          "period": 14,
          "lookback": 200
        },
        "min": 25,
        "max": 90
      },
      {
        "name": "session_mask",
        "params": {
          "sessions": [
            "newyork"
          ],
          "start_utc": "13:30",
          "end_utc": "20:00"
        }
      }
    ]
  },
  "signals": {
    "entry": {
      "long": "EMA(20) > EMA(50) > EMA(200) AND low <= EMA(20) within last 3 bars AND RSI(14) crosses above 50 AND close > EMA(20)",
      "short": "EMA(20) < EMA(50) < EMA(200) AND high >= EMA(20) within last 3 bars AND RSI(14) crosses below 50 AND close < EMA(20)"
    },
    "primitives_used": [
      "ema",
      "rsi",
      "atr",
      "adx",
      "session_mask"
    ]
  },
  "exits": {
    "stop_loss": "1.3*ATR(14) below/above swing (entry +/- 1.3*ATR)",
    "take_profit": "2.6*ATR(14) (R:R 2.0)",
    "time_stop_bars": 30,
    "breakeven_trigger": "1.0*ATR(14) in favor",
    "trailing": "ATR trail 1.8*ATR after 1.0R"
  },
  "sizing": {
    "model": "risk_pct_of_equity",
    "risk_per_trade_pct": 0.5,
    "max_concurrent_positions": 1,
    "max_daily_trades": 3
  },
  "acceptance_targets": {
    "pf_min": 2.0,
    "sharpe_min": 1.5,
    "max_dd_pct": 15.0,
    "trades_min": 200
  }
}
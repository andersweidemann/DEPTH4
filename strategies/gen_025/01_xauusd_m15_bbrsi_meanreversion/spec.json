{
  "name": "XAUUSD_M15_BBRSI_MeanReversion",
  "family": "mean_reversion",
  "symbol": "XAUUSD",
  "timeframe": "M15",
  "hypothesis": "On XAUUSD M15, closes outside Bollinger(20, 2.0) coupled with RSI(7) extremes revert to the middle band when BB width is above its 30th percentile and ADX < 25 (non-trending regime).",
  "regime_filter": {
    "primitive": "classify",
    "rules": [
      {
        "name": "adx",
        "params": {
          "period": 14
        },
        "max": 25
      },
      {
        "name": "bb_width",
        "params": {
          "period": 20,
          "stdev": 2.0,
          "percentile_lookback": 200
        },
        "min_percentile": 30
      },
      {
        "name": "session_mask",
        "params": {
          "sessions": [
            "london",
            "newyork"
          ],
          "start_utc": "07:00",
          "end_utc": "20:00"
        }
      }
    ]
  },
  "signals": {
    "entry": {
      "long": "close < lower_BB(20, 2.0) AND RSI(7) < 12",
      "short": "close > upper_BB(20, 2.0) AND RSI(7) > 88"
    },
    "primitives_used": [
      "bollinger",
      "rsi",
      "atr",
      "bb_width",
      "session_mask",
      "adx"
    ],
    "cooldown_bars": 4
  },
  "exits": {
    "stop_loss": "1.5*ATR(14)",
    "take_profit": "middle_BB(20) touch OR opposite_BB touch (whichever first)",
    "time_stop_bars": 24,
    "min_rr": 1.0
  },
  "sizing": {
    "model": "risk_pct_of_equity",
    "risk_per_trade_pct": 0.5,
    "max_concurrent_positions": 1,
    "max_daily_trades": 3
  },
  "acceptance_targets": {
    "pf_min": 2.0,
    "sharpe_min": 1.5,
    "max_dd_pct": 15.0,
    "trades_min": 200
  }
}
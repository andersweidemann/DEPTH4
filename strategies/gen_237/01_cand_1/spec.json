{
  "hypothesis": "Breakouts occur during London session with high volatility",
  "regime_filter": {
    "type": "london_session",
    "params": {
      "start_hour": 7,
      "end_hour": 10
    }
  },
  "entry_rule": {
    "type": "breakout",
    "params": {
      "atr_period": 14,
      "atr_multiplier": 2
    }
  },
  "exit_rule": {
    "type": "tp_sl",
    "params": {
      "tp_pips": 500,
      "sl_pips": 100
    }
  },
  "sizing_rule": {
    "type": "fixed_size",
    "params": {
      "size": 0.1
    }
  }
}
{
  "hypothesis": "Mean reversion occurs on US500 M5 when RSI reaches extreme levels",
  "regime_filter": {
    "type": "rsi_extremes",
    "params": {
      "period": 7,
      "lower_threshold": 10,
      "upper_threshold": 90
    }
  },
  "entry_rules": {
    "long": {
      "condition": "rsi(7) < 10"
    },
    "short": {
      "condition": "rsi(7) > 90"
    }
  },
  "exit_rules": {
    "stop_loss": {
      "type": "atr",
      "params": {
        "period": 14,
        "multiplier": 1.5
      }
    },
    "take_profit": {
      "type": "fixed_rr",
      "params": {
        "rr": 1.5
      }
    },
    "time_stop": {
      "type": "bars",
      "params": {
        "num_bars": 20
      }
    }
  },
  "sizing_rules": {
    "type": "fixed_fraction",
    "params": {
      "fraction": 0.02
    }
  }
}
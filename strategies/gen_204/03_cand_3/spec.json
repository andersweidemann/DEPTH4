{
  "hypothesis": "Mean reversion occurs on BTCUSD M5 when price closes outside Bollinger Bands with extreme RSI readings",
  "regime_filter": {
    "type": "volatility_filter",
    "params": {
      "volatility_threshold": 50
    }
  },
  "entry_rule": {
    "type": "mean_reversion",
    "params": {
      "bb_period": 20,
      "bb_deviation": 1.75,
      "rsi_period": 7,
      "rsi_thresholds": [
        10,
        90
      ]
    }
  },
  "exit_rule": {
    "type": "take_profit_stop_loss",
    "params": {
      "take_profit": "opposite_bollinger_band",
      "stop_loss": "1.5x_atr",
      "time_stop": 30
    }
  },
  "sizing_rule": {
    "type": "fixed_size",
    "params": {
      "size": 0.05
    }
  }
}
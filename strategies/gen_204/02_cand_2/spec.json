{
  "hypothesis": "Bollinger Band touch-and-bounce reversal occurs on XAUUSD M5 with high probability",
  "regime_filter": {
    "type": "bb_width_percentile",
    "params": {
      "period": 20,
      "deviation": 2.0,
      "percentile": 50
    }
  },
  "entry_rule": {
    "type": "bb_touch",
    "params": {
      "bb_period": 20,
      "bb_deviation": 2.0,
      "touch_threshold": 0.5
    }
  },
  "exit_rule": {
    "type": "take_profit_stop_loss",
    "params": {
      "take_profit": "opposite_bollinger_band",
      "stop_loss": "1.5x_atr",
      "time_stop": 30
    }
  },
  "sizing_rule": {
    "type": "fixed_fraction",
    "params": {
      "fraction": 0.02
    }
  }
}
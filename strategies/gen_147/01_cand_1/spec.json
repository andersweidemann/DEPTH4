{
  "hypothesis": "Breakouts from the Asia range during the London session can be profitable",
  "regime_filter": {
    "type": "session",
    "params": {
      "start_hour": 7,
      "end_hour": 10
    }
  },
  "entry_rule": {
    "type": "asia_london_breakout",
    "params": {
      "asia_range_start": 0,
      "asia_range_end": 6,
      "breakout_threshold": 1.2
    }
  },
  "exit_rule": {
    "type": "trailing_stop",
    "params": {
      "atr_period": 14,
      "atr_multiplier": 1.5
    }
  },
  "stop_loss": {
    "type": "fixed",
    "params": {
      "pips": 100
    }
  },
  "take_profit": {
    "type": "fixed",
    "params": {
      "pips": 200
    }
  },
  "time_stop": {
    "type": "fixed",
    "params": {
      "bars": 60
    }
  },
  "sizing": {
    "type": "fixed",
    "params": {
      "lots": 0.1
    }
  }
}
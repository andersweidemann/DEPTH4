{
  "hypothesis": "Bollinger Band touch-and-bounce reversal is profitable on XAUUSD M15",
  "regime_filter": {
    "type": "bb_width",
    "params": {
      "period": 20,
      "deviation": 2.0
    }
  },
  "entry_rules": {
    "long": {
      "condition": "close > lower_bb && close[-1] < lower_bb"
    },
    "short": {
      "condition": "close < upper_bb && close[-1] > upper_bb"
    }
  },
  "exit_rules": {
    "sl": {
      "type": "atr",
      "params": {
        "period": 14,
        "multiplier": 1.5
      }
    },
    "tp": {
      "type": "opposite_bb"
    },
    "time_stop": {
      "type": "bars",
      "params": {
        "num_bars": 30
      }
    }
  },
  "sizing_rules": {
    "type": "fixed",
    "params": {
      "size": 0.1
    }
  }
}
{
  "hypothesis": "RSI divergence leads to a mean reversion opportunity on US500 M5",
  "regime_filter": {
    "type": "rsi",
    "params": {
      "period": 7,
      "threshold": 70
    }
  },
  "entry_rules": {
    "long": {
      "condition": "rsi(7) < 30 && close > lower_bb"
    },
    "short": {
      "condition": "rsi(7) > 70 && close < upper_bb"
    }
  },
  "exit_rules": {
    "sl": {
      "type": "atr",
      "params": {
        "period": 14,
        "multiplier": 1.5
      }
    },
    "tp": {
      "type": "opposite_bb"
    },
    "time_stop": {
      "type": "bars",
      "params": {
        "count": 30
      }
    }
  },
  "sizing_rules": {
    "type": "fixed",
    "params": {
      "size": 0.1
    }
  }
}
{
  "hypothesis": "Donchian channel breakout leads to a trend following opportunity on BTCUSD M5",
  "regime_filter": {
    "type": "donchian",
    "params": {
      "period": 20
    }
  },
  "entry_rules": {
    "long": {
      "condition": "close > donchian_high"
    },
    "short": {
      "condition": "close < donchian_low"
    }
  },
  "exit_rules": {
    "sl": {
      "type": "fixed",
      "params": {
        "distance": 100
      }
    },
    "tp": {
      "type": "fixed",
      "params": {
        "distance": 200
      }
    },
    "time_stop": {
      "type": "hours",
      "params": {
        "count": 2
      }
    }
  },
  "sizing_rules": {
    "type": "risk",
    "params": {
      "risk_percent": 2
    }
  }
}
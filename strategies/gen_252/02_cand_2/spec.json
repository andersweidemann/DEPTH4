{
  "hypothesis": "Bollinger Band touch-and-bounce reversal is effective on XAUUSD M15",
  "regime_filter": {
    "type": "bb_width",
    "params": {
      "bb_period": 20,
      "bb_deviation": 2.0,
      "min_width": 10
    }
  },
  "entry_rule": {
    "type": "bb_touch",
    "params": {
      "bb_period": 20,
      "bb_deviation": 2.0
    }
  },
  "exit_rule": {
    "type": "take_profit_stop_loss",
    "params": {
      "take_profit": 500,
      "stop_loss": 100,
      "time_stop": 60
    }
  },
  "sizing_rule": {
    "type": "fixed_fraction",
    "params": {
      "fraction": 0.01
    }
  }
}
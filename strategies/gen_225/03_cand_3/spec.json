{
  "hypothesis": "Volatility contraction precedes a breakout",
  "regime_filter": {
    "type": "bb_width",
    "params": {
      "threshold": 0.5
    }
  },
  "entry_rules": {
    "long": {
      "condition": "close > upper_bb && bb_width(20) < 0.5"
    },
    "short": {
      "condition": "close < lower_bb && bb_width(20) < 0.5"
    }
  },
  "exit_rules": {
    "sl": {
      "type": "fixed",
      "params": {
        "pips": 50
      }
    },
    "tp": {
      "type": "fixed",
      "params": {
        "pips": 200
      }
    },
    "time_stop": {
      "type": "hours",
      "params": {
        "num_hours": 1
      }
    }
  },
  "sizing_rules": {
    "type": "risk",
    "params": {
      "risk_percent": 1
    }
  }
}
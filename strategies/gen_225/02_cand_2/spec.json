{
  "hypothesis": "Price will revert to the mean after a strong trend",
  "regime_filter": {
    "type": "adx",
    "params": {
      "threshold": 25
    }
  },
  "entry_rules": {
    "long": {
      "condition": "close < lower_bb && adx(14) > 25"
    },
    "short": {
      "condition": "close > upper_bb && adx(14) > 25"
    }
  },
  "exit_rules": {
    "sl": {
      "type": "atr",
      "params": {
        "multiplier": 2
      }
    },
    "tp": {
      "type": "middle_bb"
    },
    "time_stop": {
      "type": "bars",
      "params": {
        "num_bars": 20
      }
    }
  },
  "sizing_rules": {
    "type": "fixed",
    "params": {
      "size": 0.02
    }
  }
}
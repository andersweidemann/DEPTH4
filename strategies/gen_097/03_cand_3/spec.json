{
  "hypothesis": "Mean reversion occurs when price reaches extreme deviations from its mean on US500 M5",
  "regime_filter": {
    "type": "volatility",
    "params": {
      "atr_period": 14,
      "min_atr": 10
    }
  },
  "entry_rule": {
    "type": "mean_reversion",
    "params": {
      "rsi_period": 7,
      "rsi_thresholds": [
        10,
        90
      ]
    }
  },
  "exit_rule": {
    "type": "take_profit_sl",
    "params": {
      "tp_pips": 500,
      "sl_pips": 100
    }
  },
  "sizing_rule": {
    "type": "fixed_risk",
    "params": {
      "risk_percent": 2
    }
  }
}
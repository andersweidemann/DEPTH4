{
  "hypothesis": "Bollinger Band touch-and-bounce reversal is profitable on XAUUSD M15",
  "regime_filter": {
    "type": "bb_width",
    "params": {
      "bb_period": 20,
      "bb_deviation": 2.0,
      "min_width": 10
    }
  },
  "entry_rule": {
    "type": "bb_touch_and_bounce",
    "params": {
      "rsi_period": 7,
      "rsi_thresholds": [
        10,
        90
      ]
    }
  },
  "exit_rule": {
    "type": "opposite_bb",
    "params": {
      "sl_multiplier": 1.5,
      "time_stop_bars": 30
    }
  },
  "sizing_rule": {
    "type": "fixed_fraction",
    "params": {
      "fraction": 0.01
    }
  }
}
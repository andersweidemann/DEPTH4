{
  "hypothesis": "ATR breakout during high volatility results in a profitable trade",
  "regime_filter": {
    "type": "atr_percentile",
    "params": {
      "atr_period": 14,
      "percentile": 80
    }
  },
  "entry_rule": {
    "type": "atr_breakout",
    "params": {
      "atr_multiplier": 2.0
    }
  },
  "exit_rule": {
    "type": "tp_sl",
    "params": {
      "tp_pips": 150,
      "sl_pips": 75
    }
  },
  "sizing_rule": {
    "type": "fixed_size",
    "params": {
      "size": 0.2
    }
  }
}
{
  "hypothesis": "Bollinger Band touch-and-bounce reversal occurs on US500 M15 with high probability",
  "regime_filter": {
    "type": "bb_width_percentile",
    "params": {
      "bb_period": 20,
      "bb_deviation": 1.75,
      "percentile": 30
    }
  },
  "entry_rules": {
    "long": {
      "condition": "close > lower_bb && close < upper_bb"
    },
    "short": {
      "condition": "close < upper_bb && close > lower_bb"
    }
  },
  "exit_rules": {
    "tp": {
      "type": "fixed",
      "params": {
        "pips": 50
      }
    },
    "sl": {
      "type": "fixed",
      "params": {
        "pips": 20
      }
    },
    "time_stop": {
      "type": "hours",
      "params": {
        "hours": 2
      }
    }
  },
  "sizing_rules": {
    "type": "risk",
    "params": {
      "risk": 0.02
    }
  }
}
{
  "hypothesis": "Bollinger Band touch-and-bounce reversal occurs on XAUUSD M15",
  "regime_filter": {
    "type": "symbol",
    "params": {
      "symbol": "XAUUSD"
    }
  },
  "entry_rule": {
    "type": "bb_touch",
    "params": {
      "bb_period": 20,
      "bb_deviation": 2.0,
      "touch_threshold": 0.2
    }
  },
  "exit_rule": {
    "type": "tp_sl_time",
    "params": {
      "tp": "fixed_pips",
      "sl": "fixed_pips",
      "time_stop": 30
    }
  },
  "sizing_rule": {
    "type": "fixed_fraction",
    "params": {
      "fraction": 0.02
    }
  }
}
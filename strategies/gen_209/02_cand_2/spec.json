{
  "hypothesis": "Asia-London range expansion occurs on XAUUSD M5 with high probability",
  "regime_filter": {
    "type": "atr_percentile",
    "params": {
      "period": 14,
      "percentile": 50
    }
  },
  "entry_rules": {
    "long": {
      "condition": "close > asia_high && rsi > 50"
    },
    "short": {
      "condition": "close < asia_low && rsi < 50"
    }
  },
  "exit_rules": {
    "stop_loss": {
      "type": "atr",
      "params": {
        "period": 14,
        "multiplier": 2
      }
    },
    "take_profit": {
      "type": "opposite_range"
    },
    "time_stop": {
      "type": "bars",
      "params": {
        "num_bars": 20
      }
    }
  },
  "sizing_rules": {
    "type": "fixed",
    "params": {
      "size": 0.01
    }
  }
}
{
  "hypothesis": "Bollinger Band touch-and-bounce reversal strategy is profitable on XAUUSD M15.",
  "regime_filter": {
    "type": "bb_width",
    "params": {
      "min_width": 10,
      "max_width": 50
    }
  },
  "entry_rule": {
    "type": "bb_touch_bounce",
    "params": {
      "bb_period": 20,
      "bb_deviation": 2.0
    }
  },
  "exit_rule": {
    "type": "tp_sl_time",
    "params": {
      "tp": "500_pips",
      "sl": "100_pips",
      "time_stop": 60
    }
  },
  "sizing_rule": {
    "type": "fixed_fraction",
    "params": {
      "fraction": 0.02
    }
  }
}
{
  "hypothesis": "Mean reversion occurs when price closes outside Bollinger Bands with extreme RSI readings",
  "regime_filter": {
    "type": "bb_width_percentile",
    "threshold": 30
  },
  "entry_rule": {
    "type": "mean_reversion",
    "bb_period": 20,
    "bb_deviation": 1.75,
    "rsi_period": 7,
    "rsi_thresholds": [
      10,
      90
    ]
  },
  "exit_rule": {
    "type": "opposite_bb",
    "sl_multiplier": 1.5,
    "time_stop": 30
  },
  "sizing_rule": {
    "type": "fixed_fraction",
    "fraction": 0.01
  }
}
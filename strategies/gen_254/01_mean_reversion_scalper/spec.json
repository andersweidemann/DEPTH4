{
  "name": "Mean Reversion Scalper",
  "hypothesis": "Mean reversion after extreme RSI readings",
  "regime_filter": "bb_width_percentile > 30",
  "symbols": [
    "GER40"
  ],
  "timeframes": [
    "M15"
  ],
  "entry_rules": {
    "long": "close < lower_bollinger_band(20, 1.75) AND rsi(7) < 10",
    "short": "close > upper_bollinger_band(20, 1.75) AND rsi(7) > 90"
  },
  "exit_rules": {
    "stop_loss": "1.5 * atr(14)",
    "take_profit": "opposite_bollinger_band",
    "time_stop": "30 bars"
  },
  "sizing": {
    "type": "fixed",
    "value": 0.1
  }
}
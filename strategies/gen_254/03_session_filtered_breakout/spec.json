{
  "name": "Session Filtered Breakout",
  "hypothesis": "Breakout during active sessions",
  "regime_filter": "session_mask(07:00-20:00)",
  "symbols": [
    "GER40"
  ],
  "timeframes": [
    "M15"
  ],
  "entry_rules": {
    "long": "close > upper_bollinger_band(20, 2.0) AND session_mask(07:00-20:00)",
    "short": "close < lower_bollinger_band(20, 2.0) AND session_mask(07:00-20:00)"
  },
  "exit_rules": {
    "stop_loss": "1.5 * atr(14)",
    "take_profit": "2 * atr(14)",
    "time_stop": "30 bars"
  },
  "sizing": {
    "type": "fixed",
    "value": 0.1
  }
}
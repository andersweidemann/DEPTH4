  },
  "exit_rules": {
    "stop_loss": "1.5 * atr(14)",
    "take_profit": "2 * atr(14)",
    "time_stop": "30 bars"
  },
  "sizing": {
    "type": "fixed",
    "value": 0.1
  }
}
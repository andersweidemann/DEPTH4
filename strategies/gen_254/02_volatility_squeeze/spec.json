{
  "name": "Volatility Squeeze",
  "hypothesis": "Volatility expansion after squeeze",
  "regime_filter": "atr_percentile < 20",
  "symbols": [
    "GER40"
  ],
  "timeframes": [
    "M15"
  ],
  "entry_rules": {
    "long": "close > upper_bollinger_band(20, 2.0) AND atr(14) < 20",

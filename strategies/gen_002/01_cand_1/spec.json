{
  "id": "gen2_ger40_asia_london_breakout_m5",
  "family": "session_breakout",
  "hypothesis": "On GER40 M5, after a contained Asia-session range (00:00-06:00 UTC) sized between 0.5x and 2.0x ATR, the first decisive break of that range during the London window (07:00-10:00 UTC) with body>=1.2x ATR extends far enough to clear 1R with PF>=1.5.",
  "symbols": [
    "GER40"
  ],
  "timeframes": [
    "M5"
  ],
  "signals": [
    {
      "name": "atr14",
      "primitive": "atr",
      "params": {
        "period": 14
      }
    },
    {
      "name": "asia_range",
      "primitive": "donchian",
      "params": {
        "period": 72,
        "session_start_utc": "00:00",
        "session_end_utc": "06:00"
      }
    },
    {
      "name": "breakout_levels",
      "primitive": "atr_breakout_levels",
      "params": {
        "base": "asia_range",
        "buffer_atr_mult": 0.5
      }
    },
    {
      "name": "asia_sess",
      "primitive": "session_mask",
      "params": {
        "start_utc": "00:00",
        "end_utc": "06:00"
      }
    },
    {
      "name": "london_sess",
      "primitive": "session_mask",
      "params": {
        "start_utc": "07:00",
        "end_utc": "10:00"
      }
    }
  ],
  "entry_rules": {
    "long": "london_sess==1 AND close > asia_range.high + 0.5*atr14 AND candle_body >= 1.2*atr14 AND first_breakout_of_day==true AND (asia_range.high - asia_range.low) between 0.5*atr14 and 2.0*atr14",
    "short": "london_sess==1 AND close < asia_range.low - 0.5*atr14 AND candle_body >= 1.2*atr14 AND first_breakout_of_day==true AND (asia_range.high - asia_range.low) between 0.5*atr14 and 2.0*atr14",
    "max_entries_per_day": 1
  },
  "exit_rules": {
    "stop_loss": "0.75 * atr14 from entry",
    "take_profit": "2.5 * atr14 from entry (R multiple ~3.3)",
    "time_stop_bars": 36,
    "trailing": "chandelier: entry + 2*atr14 once 1R reached"
  },
  "regime_filter": {
    "primitive": "classify",
    "params": {
      "adx_period": 14,
      "adx_min": 18,
      "atr_pct_min": 0.3,
      "atr_pct_max": 0.95
    },
    "rule": "trade only when classify() returns trending_or_expanding regime"
  },
  "sizing": {
    "type": "risk_percent",
    "risk_per_trade_pct": 0.75,
    "max_concurrent_positions": 1,
    "max_spread_points": 30
  },
  "parameters_to_optimize": {
    "buffer_atr_mult": [
      0.3,
      0.5,
      0.7
    ],
    "body_atr_mult": [
      1.0,
      1.2,
      1.5
    ],
    "sl_atr_mult": [
      0.6,
      0.75,
      1.0
    ],
    "tp_atr_mult": [
      2.0,
      2.5,
      3.0
    ],
    "london_end_utc": [
      "09:30",
      "10:00",
      "11:00"
    ]
  },
  "inspiration_refs": [
    "asia-london-range-expansion-xauusd",
    "dax10_strategy_fixed_BEST"
  ],
  "diversity_tag": "session_breakout"

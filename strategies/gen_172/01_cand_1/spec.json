{
  "hypothesis": "Breakouts occur when price closes outside the Asia range with sufficient volatility",
  "regime_filter": {
    "type": "atr",
    "params": {
      "period": 14,
      "min_range_atr": 0.5,
      "max_range_atr": 2.0
    }
  },
  "entry_rules": {
    "long": {
      "condition": "close > high_asia_range"
    },
    "short": {
      "condition": "close < low_asia_range"
    }
  },
  "exit_rules": {
    "tp": {
      "type": "fixed",
      "params": {
        "pips": 500
      }
    },
    "sl": {
      "type": "fixed",
      "params": {
        "pips": 100
      }
    },
    "time_stop": {
      "type": "hours",
      "params": {
        "num_hours": 2.5
      }
    }
  },
  "sizing_rules": {
    "type": "fixed",
    "params": {
      "size": 0.01
    }
  }
}
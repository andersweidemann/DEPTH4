{
  "hypothesis": "Breakouts on GER40 M15 occur after an Asia range expansion, with a higher probability of success when ATR is above its 50th percentile",
  "regime_filter": {
    "type": "atr_percentile",
    "params": {
      "atr_period": 14,
      "percentile": 50
    }
  },
  "entry_rules": {
    "long": {
      "condition": "breakout > upper_range && atr(14) > atr_percentile(50)"
    },
    "short": {
      "condition": "breakout < lower_range && atr(14) > atr_percentile(50)"
    }
  },
  "exit_rules": {
    "sl": {
      "type": "fixed",
      "params": {
        "pips": 50
      }
    },
    "tp": {
      "type": "fixed",
      "params": {
        "pips": 100
      }
    },
    "time_stop": {
      "type": "hours",
      "params": {
        "hours": 2
      }
    }
  },
  "sizing_rules": {
    "type": "proportional",
    "params": {
      "proportion": 0.02
    }
  }
}
{
  "hypothesis": "Trend following works on BTCUSD M5 when using a combination of moving averages.",
  "regime_filter": {
    "type": "adx_threshold",
    "params": {
      "period": 14,
      "threshold": 20
    }
  },
  "entry_rule": {
    "type": "trend_following",
    "params": {
      "ma_short": 10,
      "ma_long": 30
    }
  },
  "exit_rule": {
    "type": "tp_sl_time",
    "params": {
      "tp": "fixed_pips",
      "sl": "fixed_pips",
      "time_stop": 30
    }
  },
  "sizing_rule": {
    "type": "fixed_fraction",
    "params": {
      "fraction": 0.02
    }
  }
}
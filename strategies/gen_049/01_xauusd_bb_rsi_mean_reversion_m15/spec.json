{
  "id": "gen49_cand01_xau_bb_rsi_meanrev",
  "name": "XAUUSD BB+RSI Mean Reversion M15",
  "hypothesis": "On XAUUSD M15 during London-NY overlap, a close outside BB(20, 2.0) coupled with RSI(7) extreme (<15 long / >85 short) reverts to the middle band with positive expectancy, provided BB width is above its 40th percentile (avoiding dead chop).",
  "family": "mean_reversion",
  "symbol": "XAUUSD",
  "timeframe": "M15",
  "regime_filter": {
    "primitive": "classify",
    "rules": [
      {
        "name": "adx_not_strong_trend",
        "primitive": "adx",
        "period": 14,
        "max": 28
      },
      {
        "name": "vol_active",
        "primitive": "bb_width",
        "period": 20,
        "dev": 2.0,
        "lookback": 400,
        "min_percentile": 40
      },
      {
        "name": "session",
        "primitive": "session_mask",
        "tz": "UTC",
        "start": "07:00",
        "end": "20:00"
      }
    ],
    "combine": "all"
  },
  "entries": {
    "long": {
      "description": "Close below lower BB with extreme RSI oversold",
      "primitives": [
        {
          "type": "bollinger",
          "period": 20,
          "dev": 2.0
        },
        {
          "type": "rsi",
          "period": 7
        }
      ],
      "conditions": [
        "close < bb_lower",
        "rsi7 < 15",
        "bars_since_last_entry >= 6"
      ]
    },
    "short": {
      "description": "Mirror upper BB + RSI overbought",
      "primitives": [
        {
          "type": "bollinger",
          "period": 20,
          "dev": 2.0
        },
        {
          "type": "rsi",
          "period": 7
        }
      ],
      "conditions": [
        "close > bb_upper",
        "rsi7 > 85",
        "bars_since_last_entry >= 6"
      ]
    }
  },
  "exits": {
    "stop_loss": {
      "type": "atr",
      "period": 14,
      "mult": 1.5,
      "anchor": "entry"
    },
    "take_profit": {
      "type": "bb_middle",
      "period": 20
    },
    "time_stop": {
      "bars": 24,
      "action": "market_close"
    },
    "trailing": null
  },
  "sizing": {
    "method": "risk_pct_per_trade",
    "risk_pct": 0.5,
    "max_concurrent": 1,
    "max_daily_trades": 3
  },
  "notes": "Ported concept from mean-reversion-scalper-v3 (MIT, port_allowed) adapted to XAUUSD M15. Looser RSI thresholds than EURUSD version to account for gold's trendier nature. Relies on BB-width percentile filter to avoid dead regimes."
}
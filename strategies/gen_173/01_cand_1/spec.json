{
  "hypothesis": "The Asia-London range expansion strategy is effective on GER40 M15, with breakouts occurring within 9 bars of the London window start.",
  "regime_filter": {
    "type": "session",
    "params": {
      "start_hour": 7,
      "end_hour": 10
    }
  },
  "entry_rules": {
    "long": {
      "condition": "breakout > upper_range and displacement > 1.2 * atr(14)"
    },
    "short": {
      "condition": "breakout < lower_range and displacement > 1.2 * atr(14)"
    }
  },
  "exit_rules": {
    "tp": {
      "type": "fixed",
      "params": {
        "pips": 500
      }
    },
    "sl": {
      "type": "fixed",
      "params": {
        "pips": 100
      }
    },
    "time_stop": {
      "type": "bars",
      "params": {
        "bars": 20
      }
    }
  },
  "sizing": {
    "type": "fixed",
    "params": {
      "size": 0.01
    }
  }
}
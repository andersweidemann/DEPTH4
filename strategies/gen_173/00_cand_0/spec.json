{
  "hypothesis": "Mean reversion occurs on XAUUSD M5 when price touches the upper or lower Bollinger Band with RSI(7) in overbought or oversold territory, and volatility is above the 30th percentile.",
  "regime_filter": {
    "type": "bb_width_percentile",
    "params": {
      "period": 20,
      "percentile": 30
    }
  },
  "entry_rules": {
    "long": {
      "condition": "close < lower_bb(20, 1.75) and rsi(7) < 10"
    },
    "short": {
      "condition": "close > upper_bb(20, 1.75) and rsi(7) > 90"
    }
  },
  "exit_rules": {
    "tp": {
      "type": "opposite_bb",
      "params": {
        "period": 20,
        "deviation": 1.75
      }
    },
    "sl": {
      "type": "atr",
      "params": {
        "period": 14,
        "multiplier": 1.5
      }
    },
    "time_stop": {
      "type": "bars",
      "params": {
        "bars": 30
      }
    }
  },
  "sizing": {
    "type": "fixed",
    "params": {
      "size": 0.01
    }
  }
}
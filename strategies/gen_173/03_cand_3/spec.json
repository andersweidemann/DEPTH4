{
  "hypothesis": "The RSI-based mean reversion strategy is effective on US500 M5, with mean reversion occurring when RSI(7) is in overbought or oversold territory.",
  "regime_filter": {
    "type": "rsi",
    "params": {
      "period": 7,
      "threshold": 70
    }
  },
  "entry_rules": {
    "long": {
      "condition": "rsi(7) < 30"
    },
    "short": {
      "condition": "rsi(7) > 70"
    }
  },
  "exit_rules": {
    "tp": {
      "type": "fixed",
      "params": {
        "pips": 200
      }
    },
    "sl": {
      "type": "fixed",
      "params": {
        "pips": 50
      }
    },
    "time_stop": {
      "type": "bars",
      "params": {
        "bars": 10
      }
    }
  },
  "sizing": {
    "type": "fixed",
    "params": {
      "size": 0.01
    }
  }
}
{
  "hypothesis": "Breakout of the Asia range on GER40 M15 leads to a continuation of the trend.",
  "regime_filter": {
    "type": "session",
    "params": {
      "start": "07:00",
      "end": "10:00"
    }
  },
  "entry_rules": {
    "long": {
      "condition": "close > asia_range_high"
    },
    "short": {
      "condition": "close < asia_range_low"
    }
  },
  "exit_rules": {
    "tp": {
      "type": "fixed",
      "params": {
        "pips": 50
      }
    },
    "sl": {
      "type": "fixed",
      "params": {
        "pips": 20
      }
    },
    "time_stop": {
      "type": "hours",
      "params": {
        "count": 2
      }
    }
  },
  "sizing": {
    "type": "proportional",
    "params": {
      "percentage": 2
    }
  }
}
{
  "hypothesis": "ATR breakout on BTCUSD M15 indicates increased volatility and potential trend continuation.",
  "regime_filter": {
    "type": "atr",
    "params": {
      "period": 14,
      "threshold": 20
    }
  },
  "entry_rules": {
    "long": {
      "condition": "close > atr_breakout_high"
    },
    "short": {
      "condition": "close < atr_breakout_low"
    }
  },
  "exit_rules": {
    "tp": {
      "type": "fixed",
      "params": {
        "pips": 100
      }
    },
    "sl": {
      "type": "atr",
      "params": {
        "period": 14,
        "multiplier": 1
      }
    },
    "time_stop": {
      "type": "hours",
      "params": {
        "count": 4
      }
    }
  },
  "sizing": {
    "type": "proportional",
    "params": {
      "percentage": 1
    }
  }
}
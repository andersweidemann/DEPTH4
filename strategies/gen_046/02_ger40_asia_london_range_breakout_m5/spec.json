{
  "name": "ger40_asia_london_range_breakout_m5",
  "family": "breakout",
  "hypothesis": "On GER40 M5, the Asia session (00:00-06:00 UTC) range compression, when it falls within 0.5-2.0x ATR(14), tends to expand directionally during the London open window (07:00-10:00 UTC). A displacement breakout with body >=1.2x ATR and close >=0.5x ATR beyond the range produces positive expectancy with PF>=2.0.",
  "symbol": "GER40",
  "timeframe": "M5",
  "regime_filter": {
    "primitive": "atr_percentile",
    "params": {
      "atr_period": 14,
      "lookback": 500,
      "min_percentile": 0.25,
      "max_percentile": 0.95
    }
  },
  "entry": {
    "long": {
      "type": "range_breakout",
      "rules": [
        {
          "primitive": "session_mask",
          "params": {
            "build_window": {
              "start": "00:00",
              "end": "06:00",
              "tz": "UTC"
            },
            "trade_window": {
              "start": "07:00",
              "end": "10:00",
              "tz": "UTC"
            }
          },
          "condition": "in_trade_window"
        },
        {
          "primitive": "donchian",
          "params": {
            "source": "asia_session_hl"
          },
          "condition": "close > asia_high + 0.5*atr14"
        },
        {
          "primitive": "atr",
          "params": {
            "period": 14
          },
          "condition": "candle_body >= 1.2*atr14"
        },
        {
          "primitive": "atr",
          "params": {
            "period": 14,
            "range_ratio_min": 0.5,
            "range_ratio_max": 2.0
          },
          "condition": "asia_range/atr14 in [0.5,2.0]"
        }
      ],
      "max_bars_from_london_open": 9,
      "one_trade_per_day": true
    },
    "short": {
      "type": "range_breakout",
      "rules": [
        {
          "primitive": "session_mask",
          "params": {
            "build_window": {
              "start": "00:00",
              "end": "06:00",
              "tz": "UTC"
            },
            "trade_window": {
              "start": "07:00",
              "end": "10:00",
              "tz": "UTC"
            }
          },
          "condition": "in_trade_window"
        },
        {
          "primitive": "donchian",
          "params": {
            "source": "asia_session_hl"
          },
          "condition": "close < asia_low - 0.5*atr14"
        },
        {
          "primitive": "atr",
          "params": {
            "period": 14
          },
          "condition": "candle_body >= 1.2*atr14"
        },
        {
          "primitive": "atr",
          "params": {
            "period": 14,
            "range_ratio_min": 0.5,
            "range_ratio_max": 2.0
          },
          "condition": "asia_range/atr14 in [0.5,2.0]"
        }
      ],
      "max_bars_from_london_open": 9,
      "one_trade_per_day": true
    }
  },
  "exit": {
    "sl": {
      "type": "atr",
      "params": {
        "atr_period": 14,
        "multiplier": 1.5
      }
    },
    "tp": {
      "type": "atr",
      "params": {
        "atr_period": 14,
        "multiplier": 3.0
      }
    },
    "time_stop": {
      "type": "session_end",
      "value": "16:00_UTC"
    }
  },
  "sizing": {
    "type": "risk_pct",
    "risk_per_trade_pct": 0.75,
    "max_positions": 1
  },
  "notes": "Adapted from asia-london-range-expansion scout card (XAUUSD->GER40). CRITICAL: verify broker server timezone vs UTC; log Asia H/L values per day and 'trade_window_open' counter to diagnose zero-trade failures from prior gen. Also verify GER40 symbol alias (DE40/DAX40)."
}
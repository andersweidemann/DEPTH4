{
  "hypothesis": "Price bounces off Bollinger Bands",
  "regime_filter": {
    "type": "bb_width_percentile",
    "params": {
      "bb_period": 20,
      "bb_deviation": 2.0,
      "percentile": 50
    }
  },
  "entry_rule": {
    "type": "bollinger_bounce",
    "params": {
      "rsi_period": 7,
      "rsi_thresholds": [
        20,
        80
      ]
    }
  },
  "exit_rule": {
    "type": "take_profit_and_stop_loss",
    "params": {
      "take_profit": "50_pips",
      "stop_loss": "50_pips",
      "time_stop": 20
    }
  },
  "sizing_rule": {
    "type": "fixed_fraction",
    "params": {
      "fraction": 0.02
    }
  }
}
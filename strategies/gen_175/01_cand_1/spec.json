{
  "hypothesis": "Breakouts occur after consolidation during the Asia session",
  "regime_filter": {
    "type": "session_mask",
    "params": {
      "session": "london"
    }
  },
  "entry_rule": {
    "type": "breakout",
    "params": {
      "atr_period": 14,
      "min_range_atr": 0.5,
      "max_range_atr": 2.0
    }
  },
  "exit_rule": {
    "type": "take_profit_and_stop_loss",
    "params": {
      "take_profit": "100_pips",
      "stop_loss": "100_pips",
      "time_stop": 30
    }
  },
  "sizing_rule": {
    "type": "fixed_size",
    "params": {
      "size": 0.1
    }
  }
}
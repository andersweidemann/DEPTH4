{
  "hypothesis": "Bollinger Band touch-and-bounce reversal occurs in XAUUSD on M15",
  "regime_filter": {
    "type": "bb_width",
    "params": {
      "bb_period": 20,
      "bb_deviation": 2.0,
      "min_width": 0.05
    }
  },
  "entry_rules": {
    "long": {
      "condition": "close > lower_bb && close < upper_bb"
    },
    "short": {
      "condition": "close < upper_bb && close > lower_bb"
    }
  },
  "exit_rules": {
    "sl": {
      "type": "fixed",
      "params": {
        "distance": 100
      }
    },
    "tp": {
      "type": "opposite_bb",
      "params": {}
    },
    "time_stop": {
      "type": "fixed",
      "params": {
        "bars": 30
      }
    }
  },
  "sizing_rules": {
    "type": "fixed",
    "params": {
      "size": 0.01
    }
  }
}
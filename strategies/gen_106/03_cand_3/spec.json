{
  "hypothesis": "ATR-based breakout occurs during low volatility",
  "regime_filter": {
    "type": "atr",
    "params": {
      "threshold": 10
    }
  },
  "entry_rules": {
    "long": {
      "condition": "breakout > upper_atr && time >= 09:00 && time < 12:00"
    },
    "short": {
      "condition": "breakout < lower_atr && time >= 09:00 && time < 12:00"
    }
  },
  "exit_rules": {
    "stop_loss": {
      "type": "fixed",
      "params": {
        "pips": 50
      }
    },
    "take_profit": {
      "type": "fixed",
      "params": {
        "pips": 200
      }
    },
    "time_stop": {
      "type": "hours",
      "params": {
        "num_hours": 1
      }
    }
  },
  "sizing_rules": {
    "type": "fixed",
    "params": {
      "size": 0.1
    }
  }
}
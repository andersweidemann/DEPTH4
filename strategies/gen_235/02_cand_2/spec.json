{
  "hypothesis": "Price reverts to mean after extreme movements",
  "regime_filter": {
    "type": "volatility_gate",
    "params": {
      "threshold": 1.5
    }
  },
  "entry_rule": {
    "type": "mean_reversion",
    "params": {
      "bb_period": 20,
      "bb_deviation": 1.75,
      "rsi_period": 7,
      "rsi_thresholds": [
        20,
        80
      ]
    }
  },
  "exit_rule": {
    "type": "tp_sl_time",
    "params": {
      "tp": "middle_bb",
      "sl": "1.2_atr",
      "time_stop": 45
    }
  },
  "sizing_rule": {
    "type": "fixed_fraction",
    "params": {
      "fraction": 0.015
    }
  }
}
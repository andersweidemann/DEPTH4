{
  "name": "XAUUSD_M15_BBRSIMeanReversion",
  "hypothesis": "On XAUUSD M15, extreme BB(20,2.0) excursions combined with RSI(7) extremes during active sessions with sufficient volatility revert to the middle band within 30 bars, producing a positive-expectancy scalp.",
  "symbol": "XAUUSD",
  "timeframe": "M15",
  "family": "mean_reversion",
  "regime_filter": {
    "type": "composite",
    "rules": [
      {
        "primitive": "bb_width",
        "period": 20,
        "stddev": 2.0,
        "percentile_min": 30,
        "lookback": 200
      },
      {
        "primitive": "adx",
        "period": 14,
        "op": "<=",
        "value": 25
      },
      {
        "primitive": "session_mask",
        "sessions": [
          "london",
          "ny"
        ],
        "window_utc": "07:00-20:00"
      }
    ]
  },
  "entry_rules": {
    "long": [
      "bar[-2] close > lower_BB(20,2.0)",
      "bar[-1] low <= lower_BB(20,2.0)",
      "bar[0] close > lower_BB(20,2.0)",
      "RSI(7) at bar[-1] < 15"
    ],
    "short": [
      "bar[-2] close < upper_BB(20,2.0)",
      "bar[-1] high >= upper_BB(20,2.0)",
      "bar[0] close < upper_BB(20,2.0)",
      "RSI(7) at bar[-1] > 85"
    ]
  },
  "exit_rules": {
    "stop_loss": "1.5 * ATR(14) from entry",
    "take_profit": "middle_BB(20) touch OR opposite BB, whichever first",
    "time_stop": "close after 30 M15 bars (~7.5h)",
    "trailing": "none"
  },
  "sizing": {
    "method": "risk_per_trade",
    "risk_pct": 0.5,
    "max_concurrent": 1,
    "cooldown_bars": 3
  },
  "params": {
    "bb_period": 20,
    "bb_stddev": 2.0,
    "rsi_period": 7,
    "rsi_long_max": 15,
    "rsi_short_min": 85,
    "atr_period": 14,
    "sl_atr_mult": 1.5,
    "bb_width_percentile_min": 30,
    "time_stop_bars": 30
  },
  "falsification": "Reject if win-rate<50% combined with avg_win/avg_loss<1.2, or if >40% of trades hit time_stop (indicating regime filter failure)."
}
{
  "hypothesis": "Mean reversion occurs when RSI reaches extreme levels on GER40 M5",
  "regime_filter": {
    "type": "rsi_extremes",
    "params": {
      "rsi_period": 7,
      "rsi_thresholds": [
        10,
        90
      ]
    }
  },
  "entry_rule": {
    "type": "rsi_mean_reversion",
    "params": {
      "rsi_period": 7,
      "rsi_thresholds": [
        10,
        90
      ]
    }
  },
  "exit_rule": {
    "type": "tp_sl_time",
    "params": {
      "tp": "fixed_pips",
      "sl": "fixed_pips",
      "time_stop": 30
    }
  },
  "sizing_rule": {
    "type": "fixed_fraction",
    "params": {
      "fraction": 0.02
    }
  }
}
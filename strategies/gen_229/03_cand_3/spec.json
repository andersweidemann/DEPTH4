{
  "hypothesis": "Breakouts occur in BTCUSD during the US session when price breaks out of the Asia range with high momentum",
  "regime_filter": {
    "type": "session",
    "params": {
      "start_hour": 14,
      "end_hour": 17
    }
  },
  "entry_rules": {
    "long": {
      "condition": "high > asia_range_high and momentum > 50"
    },
    "short": {
      "condition": "low < asia_range_low and momentum < -50"
    }
  },
  "exit_rules": {
    "sl": {
      "type": "fixed",
      "params": {
        "distance": 100
      }
    },
    "tp": {
      "type": "fixed",
      "params": {
        "distance": 200
      }
    },
    "time_stop": {
      "type": "fixed",
      "params": {
        "bars": 30
      }
    }
  },
  "sizing_rules": {
    "type": "fixed",
    "params": {
      "size": 0.01
    }
  }
}
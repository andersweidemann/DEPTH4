{
  "hypothesis": "London breakout strategy is profitable on GER40 M15 when Asia range is within ATR-based bounds",
  "regime_filter": {
    "type": "atr_range_filter",
    "params": {
      "min_atr_range": 0.5,
      "max_atr_range": 2.0
    }
  },
  "entry_rule": {
    "type": "london_breakout",
    "params": {
      "asia_range_hours": [
        0,
        6
      ],
      "london_breakout_hours": [
        7,
        10
      ]
    }
  },
  "exit_rule": {
    "type": "tp_sl_time_stop",
    "params": {
      "tp": "fixed_pips",
      "sl": "fixed_pips",
      "time_stop": 60
    }
  },
  "sizing_rule": {
    "type": "fixed_fraction",
    "params": {
      "fraction": 0.02
    }
  }
}
{
  "hypothesis": "Bollinger Band touch-and-bounce reversal is profitable on XAUUSD M15",
  "regime_filter": {
    "type": "session_filter",
    "params": {
      "session_hours": [
        7,
        20
      ]
    }
  },
  "entry_rule": {
    "type": "bb_touch_bounce",
    "params": {
      "bb_period": 20,
      "bb_deviation": 2.0
    }
  },
  "exit_rule": {
    "type": "tp_sl_time_stop",
    "params": {
      "tp": "opposite_bb",
      "sl": "1.5_atr",
      "time_stop": 30
    }
  },
  "sizing_rule": {
    "type": "fixed_fraction",
    "params": {
      "fraction": 0.01
    }
  }
}
{
  "hypothesis": "Breakouts from the Asia range occur during the London session",
  "regime_filter": {
    "type": "session",
    "params": {
      "start_hour": 7,
      "end_hour": 10
    }
  },
  "entry_rules": {
    "long": {
      "condition": "high > asia_range_high && close > upper_bb"
    },
    "short": {
      "condition": "low < asia_range_low && close < lower_bb"
    }
  },
  "exit_rules": {
    "stop_loss": {
      "type": "fixed_pips",
      "params": {
        "pips": 100
      }
    },
    "take_profit": {
      "type": "fixed_pips",
      "params": {
        "pips": 500
      }
    },
    "time_stop": {
      "type": "bars",
      "params": {
        "num_bars": 20
      }
    }
  },
  "sizing_rules": {
    "type": "fixed_size",
    "params": {
      "size": 0.1
    }
  }
}
{
  "hypothesis": "Price reverts to the mean after extreme movements",
  "regime_filter": {
    "type": "atr_percentile",
    "params": {
      "period": 14,
      "percentile": 70
    }
  },
  "entry_rules": {
    "long": {
      "condition": "close < lower_bb && rsi(14) < 30"
    },
    "short": {
      "condition": "close > upper_bb && rsi(14) > 70"
    }
  },
  "exit_rules": {
    "stop_loss": {
      "type": "atr",
      "params": {
        "period": 14,
        "multiplier": 2
      }
    },
    "take_profit": {
      "type": "middle_bb"
    },
    "time_stop": {
      "type": "bars",
      "params": {
        "num_bars": 40
      }
    }
  },
  "sizing_rules": {
    "type": "fixed_fraction",
    "params": {
      "fraction": 0.02
    }
  }
}
{
  "hypothesis": "The ATR breakout strategy can be applied to BTCUSD on M15 by entering long when the price breaks out above the upper ATR-based level and short when it breaks out below the lower level.",
  "regime_filter": {
    "type": "atr_breakout",
    "params": {
      "period": 14,
      "multiplier": 2
    }
  },
  "entry_rules": {
    "long": {
      "condition": "close > upper_atr_level"
    },
    "short": {
      "condition": "close < lower_atr_level"
    }
  },
  "exit_rules": {
    "tp": {
      "type": "atr",
      "params": {
        "period": 14,
        "multiplier": 2
      }
    },
    "sl": {
      "type": "atr",
      "params": {
        "period": 14,
        "multiplier": 1.5
      }
    },
    "time_stop": {
      "type": "bars",
      "params": {
        "count": 15
      }
    }
  },
  "sizing_rules": {
    "type": "fixed",
    "params": {
      "size": 0.1
    }
  }
}
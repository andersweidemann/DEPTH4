{
  "hypothesis": "Breakout occurs when price breaks out of the Donchian channel with high volatility on BTCUSD M5",
  "regime_filter": {
    "type": "donchian_channel",
    "params": {
      "donchian_period": 20
    }
  },
  "entry_rules": {
    "long": {
      "condition": "close > upper_donchian AND atr(14) > atr(14)[1]"
    },
    "short": {
      "condition": "close < lower_donchian AND atr(14) > atr(14)[1]"
    }
  },
  "exit_rules": {
    "stop_loss": {
      "type": "fixed",
      "params": {
        "pips": 100
      }
    },
    "take_profit": {
      "type": "fixed",
      "params": {
        "pips": 500
      }
    },
    "time_stop": {
      "type": "hours",
      "params": {
        "hours": 2
      }
    }
  },
  "sizing_rules": {
    "type": "risk_percent",
    "params": {
      "risk_percent": 2
    }
  }
}
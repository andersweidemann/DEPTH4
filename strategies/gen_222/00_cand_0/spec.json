{
  "hypothesis": "Mean reversion occurs on XAUUSD M5 when price closes outside Bollinger Bands with extreme RSI readings",
  "regime_filter": {
    "type": "bb_width_percentile",
    "params": {
      "percentile": 30,
      "lookback": 100
    }
  },
  "entry_rule": {
    "type": "bb_rsi",
    "params": {
      "bb_period": 20,
      "bb_dev": 1.75,
      "rsi_period": 7,
      "rsi_thresholds": [
        10,
        90
      ]
    }
  },
  "exit_rule": {
    "type": "opposite_bb",
    "params": {}
  },
  "sl_rule": {
    "type": "atr",
    "params": {
      "atr_period": 14,
      "atr_multiplier": 1.5
    }
  },
  "tp_rule": {
    "type": "fixed_ratio",
    "params": {
      "ratio": 2
    }
  },
  "time_stop": 30,
  "sizing_rule": {
    "type": "fixed_fraction",
    "params": {
      "fraction": 0.01
    }
  }
}
{
  "hypothesis": "Breakouts occur on GER40 M15 when price closes outside Donchian channels with strong momentum",
  "regime_filter": {
    "type": "adx_threshold",
    "params": {
      "threshold": 20
    }
  },
  "entry_rule": {
    "type": "donchian_breakout",
    "params": {
      "channel_period": 20
    }
  },
  "exit_rule": {
    "type": "trailing_stop",
    "params": {
      "atr_period": 14,
      "atr_multiplier": 2
    }
  },
  "sl_rule": {
    "type": "fixed_pips",
    "params": {
      "pips": 50
    }
  },
  "tp_rule": {
    "type": "fixed_pips",
    "params": {
      "pips": 100
    }
  },
  "time_stop": 60,
  "sizing_rule": {
    "type": "fixed_fraction",
    "params": {
      "fraction": 0.02
    }
  }
}
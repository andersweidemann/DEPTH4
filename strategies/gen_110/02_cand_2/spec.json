{
  "hypothesis": "Reversals occur when price closes outside the Bollinger Bands with extreme RSI readings",
  "regime_filter": {
    "type": "bb_width_percentile",
    "params": {
      "bb_period": 20,
      "bb_dev": 1.75,
      "percentile": 70
    }
  },
  "entry_rule": {
    "type": "bb_rsi_reversal",
    "params": {
      "rsi_period": 7,
      "rsi_thresholds": [
        10,
        90
      ]
    }
  },
  "exit_rule": {
    "type": "tp_sl_time",
    "params": {
      "tp": "middle_bb",
      "sl": "2_atr",
      "time_stop": 45
    }
  },
  "sizing_rule": {
    "type": "fixed_fraction",
    "params": {
      "fraction": 0.02
    }
  }
}
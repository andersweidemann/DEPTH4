{
  "hypothesis": "Mean reversion occurs when price reaches extreme deviations from its mean, with the expectation of a reversion back to the mean.",
  "regime_filter": {
    "type": "bb_width_percentile",
    "params": {
      "period": 20,
      "deviation": 1.75,
      "percentile": 30
    }
  },
  "entry_rule": {
    "type": "mean_reversion",
    "params": {
      "bb_period": 20,
      "bb_deviation": 1.75,
      "rsi_period": 7,
      "rsi_thresholds": [
        10,
        90
      ]
    }
  },
  "exit_rule": {
    "type": "multi_exit",
    "params": {
      "take_profit": {
        "type": "opposite_bb",
        "params": {}
      },
      "stop_loss": {
        "type": "atr",
        "params": {
          "period": 14,
          "multiplier": 1.5
        }
      },
      "time_stop": {
        "type": "bars",
        "params": {
          "num_bars": 30
        }
      }
    }
  },
  "sizing_rule": {
    "type": "fixed_fraction",
    "params": {
      "fraction": 0.01
    }
  }
}
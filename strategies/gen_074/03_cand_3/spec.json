{
  "hypothesis": "RSI extremes indicate overbought or oversold conditions, leading to a mean reversion.",
  "regime_filter": {
    "type": "rsi_extremes",
    "params": {
      "rsi_period": 7,
      "thresholds": [
        10,
        90
      ]
    }
  },
  "entry_rule": {
    "type": "rsi_extremes",
    "params": {
      "rsi_period": 7,
      "thresholds": [
        10,
        90
      ]
    }
  },
  "exit_rule": {
    "type": "multi_exit",
    "params": {
      "take_profit": {
        "type": "fixed_pips",
        "params": {
          "pips": 50
        }
      },
      "stop_loss": {
        "type": "fixed_pips",
        "params": {
          "pips": 25
        }
      },
      "time_stop": {
        "type": "hours",
        "params": {
          "hours": 1
        }
      }
    }
  },
  "sizing_rule": {
    "type": "fixed_fraction",
    "params": {
      "fraction": 0.01
    }
  }
}
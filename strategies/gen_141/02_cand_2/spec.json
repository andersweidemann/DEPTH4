{
  "hypothesis": "Price reverts to the mean after touching the Bollinger Band with high RSI readings",
  "regime_filter": {
    "type": "bb_width_percentile",
    "params": {
      "percentile": 50,
      "lookback": 20
    }
  },
  "entry_rule": {
    "type": "bb_rsi_mean_reversion",
    "params": {
      "bb_period": 20,
      "bb_deviation": 2,
      "rsi_period": 7,
      "rsi_thresholds": [
        20,
        80
      ]
    }
  },
  "exit_rule": {
    "type": "middle_bb",
    "params": {}
  },
  "sl_rule": {
    "type": "atr",
    "params": {
      "atr_period": 14,
      "atr_multiplier": 2
    }
  },
  "tp_rule": {
    "type": "fixed_ratio",
    "params": {
      "ratio": 1.5
    }
  },
  "time_stop": 45,
  "sizing_rule": {
    "type": "fixed_fraction",
    "params": {
      "fraction": 0.015
    }
  }
}
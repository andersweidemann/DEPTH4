{
  "hypothesis": "BTCUSD on M5 exhibits mean reversion when price touches the upper or lower Bollinger Band with extreme RSI readings, and a trailing stop loss can help lock in profits.",
  "regime_filter": {
    "type": "bb_width_percentile",
    "params": {
      "period": 20,
      "deviation": 2.0,
      "percentile": 40
    }
  },
  "entry_rules": {
    "long": {
      "condition": "close < lower_bb && rsi(7) < 10"
    },
    "short": {
      "condition": "close > upper_bb && rsi(7) > 90"
    }
  },
  "exit_rules": {
    "sl": {
      "type": "trailing",
      "params": {
        "atr_period": 14,
        "multiplier": 1.0
      }
    },
    "tp": {
      "type": "opposite_bb"
    },
    "time_stop": {
      "type": "bars",
      "params": {
        "num_bars": 30
      }
    }
  },
  "sizing_rules": {
    "type": "fixed",
    "params": {
      "size": 0.01
    }
  }
}
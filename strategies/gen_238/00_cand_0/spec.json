{
  "hypothesis": "Mean reversion occurs in XAUUSD on M5 when price closes outside Bollinger Bands with extreme RSI readings",
  "regime_filter": {
    "type": "bb_width_percentile",
    "params": {
      "percentile": 30,
      "lookback": 100
    }
  },
  "entry_rules": {
    "long": {
      "condition": "close < lower_bb(20, 1.75) and rsi(7) < 10"
    },
    "short": {
      "condition": "close > upper_bb(20, 1.75) and rsi(7) > 90"
    }
  },
  "exit_rules": {
    "tp": {
      "type": "opposite_bb",
      "params": {
        "bb_period": 20,
        "bb_dev": 1.75
      }
    },
    "sl": {
      "type": "atr",
      "params": {
        "atr_period": 14,
        "atr_multiplier": 1.5
      }
    },
    "time_stop": {
      "type": "bars",
      "params": {
        "bars": 30
      }
    }
  },
  "sizing_rules": {
    "type": "fixed",
    "params": {
      "size": 0.1
    }
  }
}
{
  "hypothesis": "Bollinger Band touch-and-bounce reversal occurs in XAUUSD on M15",
  "regime_filter": {
    "type": "bb_width",
    "params": {
      "width": 20
    }
  },
  "entry_rules": {
    "long": {
      "condition": "close > lower_bb(20, 2.0) and close < lower_bb(20, 2.0)[1]"
    },
    "short": {
      "condition": "close < upper_bb(20, 2.0) and close > upper_bb(20, 2.0)[1]"
    }
  },
  "exit_rules": {
    "tp": {
      "type": "opposite_bb",
      "params": {
        "bb_period": 20,
        "bb_dev": 2.0
      }
    },
    "sl": {
      "type": "atr",
      "params": {
        "atr_period": 14,
        "atr_multiplier": 1.5
      }
    },
    "time_stop": {
      "type": "bars",
      "params": {
        "bars": 30
      }
    }
  },
  "sizing_rules": {
    "type": "fixed",
    "params": {
      "size": 0.1
    }
  }
}
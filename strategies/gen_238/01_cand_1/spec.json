{
  "hypothesis": "Asia-London range expansion occurs in GER40 on M15",
  "regime_filter": {
    "type": "session",
    "params": {
      "session": "london"
    }
  },
  "entry_rules": {
    "long": {
      "condition": "breakout > 1.2 * atr(14) and retest < 0.2 * atr(14)"
    },
    "short": {
      "condition": "breakout < -1.2 * atr(14) and retest > -0.2 * atr(14)"
    }
  },
  "exit_rules": {
    "tp": {
      "type": "fixed",
      "params": {
        "pips": 500
      }
    },
    "sl": {
      "type": "fixed",
      "params": {
        "pips": 100
      }
    },
    "time_stop": {
      "type": "hours",
      "params": {
        "hours": 2
      }
    }
  },
  "sizing_rules": {
    "type": "risk",
    "params": {
      "risk": 0.02
    }
  }
}
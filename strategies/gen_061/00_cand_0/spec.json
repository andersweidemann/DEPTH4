{
  "hypothesis": "Mean reversion occurs when price touches the upper or lower Bollinger Band with extreme RSI readings, and volatility is above the 30th percentile.",
  "regime_filter": {
    "type": "bb_width_percentile",
    "threshold": 30
  },
  "entry_rule": {
    "type": "bb_rsi_mean_reversion",
    "params": {
      "bb_period": 20,
      "bb_deviation": 1.75,
      "rsi_period": 7,
      "rsi_threshold": 10
    }
  },
  "exit_rule": {
    "type": "opposite_bb",
    "sl": "1.5 * atr(14)",
    "tp": "opposite_bb",
    "time_stop": 30
  },
  "sizing_rule": {
    "type": "fixed_fraction",
    "fraction": 0.01
  }
}
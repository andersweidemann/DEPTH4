{
  "hypothesis": "Breakout of the Asia range during the London session results in a profitable trade.",
  "regime_filter": {
    "type": "session",
    "start_hour": 7,
    "end_hour": 10
  },
  "entry_rule": {
    "type": "asia_london_breakout",
    "params": {
      "asia_range_start": 0,
      "asia_range_end": 6,
      "breakout_threshold": 0.5
    }
  },
  "exit_rule": {
    "type": "take_profit",
    "sl": "100 pips",
    "tp": "500 pips",
    "time_stop": 10
  },
  "sizing_rule": {
    "type": "fixed_size",
    "size": 0.1
  }
}
{
  "hypothesis": "Bollinger Band touch-and-bounce reversal occurs on XAUUSD M5",
  "regime_filter": {
    "type": "bb_width",
    "params": {
      "min_width": 0.5,
      "max_width": 2.0
    }
  },
  "entry_rules": {
    "long": {
      "condition": "close > lower_bb && close < lower_bb + 0.2 * atr(14)"
    },
    "short": {
      "condition": "close < upper_bb && close > upper_bb - 0.2 * atr(14)"
    }
  },
  "exit_rules": {
    "sl": {
      "type": "atr",
      "params": {
        "multiplier": 1.5
      }
    },
    "tp": {
      "type": "opposite_bb"
    },
    "time_stop": {
      "type": "bars",
      "params": {
        "num_bars": 30
      }
    }
  },
  "sizing_rules": {
    "type": "fixed",
    "params": {
      "size": 0.01
    }
  }
}
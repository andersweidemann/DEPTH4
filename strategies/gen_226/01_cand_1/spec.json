{
  "hypothesis": "Breakouts occur on GER40 M15 when price touches Bollinger Bands with high momentum",
  "regime_filter": {
    "type": "session_mask",
    "params": {
      "start_hour": 7,
      "end_hour": 20
    }
  },
  "entry_rule": {
    "type": "bb_touch",
    "params": {
      "bb_period": 20,
      "bb_deviation": 2.0,
      "momentum_threshold": 50
    }
  },
  "exit_rule": {
    "type": "tp_sl_time",
    "params": {
      "tp": "fixed_pips",
      "sl": "fixed_pips",
      "time_stop": 60
    }
  },
  "sizing_rule": {
    "type": "fixed_fraction",
    "params": {
      "fraction": 0.02
    }
  }
}
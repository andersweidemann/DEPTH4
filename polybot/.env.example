# ======================================================================
# polybot configuration — copy this file to `.env` and fill in.
# NEVER commit .env. NEVER paste its contents into a chat with an AI.
# ======================================================================

# ---- Polymarket CLOB endpoints (defaults are correct for mainnet) ----
POLYMARKET_CLOB_HOST=https://clob.polymarket.com
POLYMARKET_GAMMA_HOST=https://gamma-api.polymarket.com
POLYMARKET_DATA_HOST=https://data-api.polymarket.com

# ---- Wallet / authentication ----
# Polymarket CLOB is on Polygon (chain id 137).
CHAIN_ID=137

# The EOA private key that signs orders. Hex string, no 0x prefix is fine
# (either works). This wallet needs MATIC for gas (trivial amount) and
# USDC.e on Polygon to trade with. Keep this file chmod 600.
PRIVATE_KEY=

# Signature type:
#   0 = EOA (trade from the key's own address)
#   1 = Polymarket proxy (email/magic-link signup)
#   2 = Browser proxy wallet (MetaMask-style)
# If you funded your Polymarket account through the website, it is almost
# certainly type 1 or 2, and you must set FUNDER to your Polymarket deposit
# address (the one shown on the Polymarket UI as your proxy).
SIGNATURE_TYPE=0
FUNDER=

# ---- Safety switches ----
# MUST be "true" (literal string, lowercase) to send real orders.
# Anything else = dry-run (logs would-be orders, never hits the network).
LIVE_TRADING=false

# Kill switch: if this file exists on disk, the bot halts immediately.
# Create it with `touch data/KILL` to stop the bot from any terminal.
KILL_SWITCH_FILE=./data/KILL

# ---- Risk caps (enforced before every order) ----
# All amounts are in USDC.
MAX_NOTIONAL_PER_ORDER=2.0
MAX_NOTIONAL_PER_MARKET=5.0
MAX_TOTAL_EXPOSURE=25.0
MAX_ORDERS_PER_DAY=20
MAX_DAILY_LOSS=5.0

# Minimum edge (in cents) required before the bot will place an order.
# e.g. 0.02 = only trade if estimated edge is at least 2 cents.
MIN_EDGE=0.02

# ---- Strategy / runner ----
# How often (seconds) the main loop wakes up.
LOOP_INTERVAL_SEC=30

# Which strategy to run. Must match a key in polybot.strategies.REGISTRY.
STRATEGY=mispricing

# Comma-separated list of Polymarket condition_ids or slugs to trade.
# Leave blank to let the strategy pick (it will still be filtered by caps).
MARKETS=

# ---- Storage ----
JOURNAL_DB_PATH=./data/journal.db
LOG_LEVEL=INFO
